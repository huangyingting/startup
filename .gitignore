# Dependencies
node_modules/
website/node_modules/

# Astro build artifacts
.astro/
dist/
website/.astro/
website/dist/

# fetch-url on-disk cache (default location; override with FETCH_URL_CACHE_DIR)
.fetch-cache/

# startup-research per-run scratch (notes, fetched bodies, chapter packets)
.research-cache/

# Defensive: skill scratch must never live inside reports/<run>/
reports/*/.research/
reports/*/.scratch/
reports/*/.chapter*-packet.json
reports/*/.chapter*-packet.yaml
reports/*/*.tmp

# Editor caches
.cache/

# Environment variables and secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local virtual environments
.venv/
venv/