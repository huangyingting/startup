---
import '../styles/tokens.css';
import monaSansLatinWghtUrl from '@fontsource-variable/mona-sans/files/mona-sans-latin-wght-normal.woff2?url';
import { t } from '../lib/i18n';
import type { Locale } from '../lib/locale';
import { HTML_LANG, localeFile, localePath } from '../lib/locale';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  alternateLocaleHref?: string;
}
const { title, locale = 'en', description = t('deck', locale), alternateLocaleHref } = Astro.props;
const base = import.meta.env.BASE_URL;
const homeHref = localePath(base, locale);
const archiveHref = localePath(base, locale, 'archive');
const sectorsHref = localePath(base, locale, 'sectors');
const topRatedHref = localePath(base, locale, 'top-rated');
const searchHref = localePath(base, locale, 'search');
const rssHref = localeFile(base, locale, 'rss.xml');
const brandLabel = t('title', locale);
const aiNote = t('aiNote', locale);
const copyright = `© ${new Date().getUTCFullYear()} Yingting Huang`;
const altLocale: Locale = locale === 'zh' ? 'en' : 'zh';
const altLabel = altLocale === 'zh' ? t('switchToChinese', locale) : t('switchToEnglish', locale);
const altHref = alternateLocaleHref ?? localePath(base, altLocale);
const htmlLang = HTML_LANG[locale];
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preload" href={monaSansLatinWghtUrl} as="font" type="font/woff2" crossorigin />
    <link rel="alternate" type="application/rss+xml" title={`${brandLabel} RSS`} href={rssHref} />
  </head>
  <body>
    <header class="bz-utility">
      <div class="bz-container bz-utility__row">
        <a href={homeHref} class="bz-utility__brand" aria-label={brandLabel}>
          <span class="bz-utility__mark" aria-hidden="true">SD</span>
          <span>{brandLabel}</span>
        </a>
        <nav class="bz-utility__nav" aria-label="Sections">
          <a href={homeHref}>{t('latest', locale)}</a>
          <a href={archiveHref}>{t('archive', locale)}</a>
          <a href={sectorsHref}>{t('sectors', locale)}</a>
          <a href={topRatedHref}>{t('topRated', locale)}</a>
          <a href={searchHref}>{t('search', locale)}</a>
        </nav>
        <div class="bz-utility__right">
          <a class="bz-utility__link bz-mono" href={altHref} hreflang={HTML_LANG[altLocale]} aria-label={t('languageSwitcher', locale)}>{altLabel}</a>
          <a class="bz-utility__link bz-mono" href={rssHref} aria-label="RSS">RSS</a>
        </div>
      </div>
    </header>
    <main><slot /></main>
    <footer class="bz-footer">
      <div class="bz-container bz-footer__row">
        <div class="bz-footer__left">
          <span class="bz-footer__brand">{brandLabel}</span>
          <span class="bz-footer__dot" aria-hidden="true"></span>
          <span class="bz-footer__tag">{aiNote}</span>
        </div>
        <span class="bz-footer__copyright">{copyright}</span>
      </div>
    </footer>

    <style>
      .bz-utility {
        background: var(--paper);
        color: var(--ink-page);
        border-bottom: var(--report-rule);
      }
      .bz-utility__row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 60px;
        gap: var(--space-4);
        flex-wrap: wrap;
        padding-block: var(--space-2);
      }
      .bz-utility__brand {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-family: var(--font-display);
        font-weight: 700;
        font-size: var(--fs-lg);
        line-height: 1;
        letter-spacing: var(--tracking-display-tight);
        color: var(--ink-page);
        text-decoration: none;
        white-space: nowrap;
      }
      @media (min-width: 1080px) {
        .bz-utility__brand { font-size: var(--fs-xl); }
      }
      .bz-utility__brand:hover { color: var(--claret); }
      .bz-utility__mark {
        display: inline-grid;
        place-items: center;
        width: 36px;
        height: 36px;
        background: var(--claret);
        color: var(--paper);
        font-family: var(--font-display);
        font-size: var(--fs-sm);
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1;
      }
      .bz-utility__nav {
        order: 3;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: var(--space-1);
        flex: 1 0 100%;
        min-width: 0;
        overflow-x: auto;
        scrollbar-width: none;
      }
      .bz-utility__nav::-webkit-scrollbar { display: none; }
      .bz-utility__nav a {
        display: inline-flex;
        align-items: center;
        color: var(--ink-page);
        text-decoration: none;
        font-family: var(--font-sans);
        font-variant-caps: all-small-caps;
        font-weight: 700;
        font-size: var(--fs-base);
        letter-spacing: var(--tracking-display-snug);
        line-height: 1;
        padding: var(--space-2) var(--space-2);
        border-bottom: 2px solid transparent;
        white-space: nowrap;
      }
      .bz-utility__nav a:hover {
        color: var(--claret);
        border-bottom-color: var(--claret);
      }
      @media (min-width: 820px) {
        .bz-utility__row { flex-wrap: nowrap; padding-block: 0; }
        .bz-utility__nav { order: 0; justify-content: flex-end; flex: 1 1 auto; }
      }
      @media (min-width: 1080px) {
        .bz-utility__nav { gap: var(--space-2); }
        .bz-utility__nav a { padding-inline: var(--space-3); }
      }
      .bz-utility__right {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
      }
      .bz-utility__link {
        text-decoration: none;
        color: var(--claret);
        border: var(--report-rule);
        background: rgba(153, 15, 61, 0.07);
        padding: var(--space-2) var(--space-3);
        font-size: var(--fs-base);
        line-height: 1;
      }
      .bz-utility__link:hover { color: var(--ink-page); }
      .bz-footer {
        background: var(--ink-black);
        color: var(--paper);
        margin-top: var(--space-9);
        padding: var(--space-5) 0;
      }
      .bz-footer__row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-4);
        font-family: var(--font-sans);
        font-size: var(--fs-base);
      }
      .bz-footer__left {
        display: inline-flex;
        align-items: center;
        flex-wrap: wrap;
        gap: var(--space-2);
        min-width: 0;
      }
      .bz-footer__brand {
        font-family: var(--font-display);
        font-size: var(--fs-lg);
        font-weight: 700;
        letter-spacing: var(--tracking-display-tight);
        color: var(--paper);
        line-height: 1;
      }
      .bz-footer__dot {
        width: 4px;
        height: 4px;
        background: var(--paper-wheat);
        opacity: 0.55;
        transform: translateY(1px);
      }
      .bz-footer__tag,
      .bz-footer__copyright {
        color: var(--paper-wheat);
        opacity: 0.82;
        font-family: var(--font-sans);
        font-size: var(--fs-base);
        line-height: 1.35;
      }
      .bz-footer__copyright {
        text-align: right;
      }
      @media (max-width: 560px) {
        .bz-footer__row {
          align-items: flex-start;
          flex-direction: column;
          gap: var(--space-3);
        }
        .bz-footer__left { align-items: baseline; }
        .bz-footer__dot { display: none; }
        .bz-footer__copyright { text-align: left; }
      }
    </style>
  </body>
</html>
