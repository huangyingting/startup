---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DiligenceReport from '../../../components/DiligenceReport.astro';
import { loadLocalizedIndex, loadStageFiles } from '../../../content/reports-loader';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((entry) => ({ params: { run: entry.data.folderSlug }, props: { entry } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'reports'> };
const localized = loadLocalizedIndex(entry.id, 'zh') as any;
const data = localized ? { ...entry.data, ...localized } : entry.data;
const stages = loadStageFiles(entry.id, 'zh') as any;
---
<BaseLayout title={`${data.company.name} — 创业研究`} description={data.headline} lang="zh" alternateHref={`${import.meta.env.BASE_URL}${entry.data.folderSlug}/`}>
  <DiligenceReport entry={entry} data={data} stages={stages} lang="zh" />
</BaseLayout>
