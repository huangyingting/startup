---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReportCard from '../../components/ReportCard.astro';
import { t } from '../../lib/i18n';
import { sortNewest, sortTopRated } from '../../lib/reports';

const reports = await getCollection('reports');
const latest = sortNewest(reports).slice(0, 12);
const top = sortTopRated(reports)[0];
---
<BaseLayout title={t('title', 'zh')} description={t('deck', 'zh')} lang="zh">
  <section class="sr-container sr-hero">
    <h1>创业公司尽调，<br />呈现为 IC 报告。</h1>
    <p class="sr-deck">每份报告都会把证据化研究整理成风投尽调文档，包含创业公司基本介绍、封面指标、投资建议、市场规模、竞争基准、财务模型、风险热力图、估值、附录与 Mermaid 图表。</p>
  </section>

  {top && <section class="sr-container sr-section"><h2>精选报告</h2><ReportCard entry={top} lang="zh" /></section>}

  <section class="sr-container sr-section">
    <h2>更多报告</h2>
    {latest.length ? <div class="sr-grid">{latest.map((entry) => <ReportCard entry={entry} lang="zh" />)}</div> : <p>{t('noReports', 'zh')}</p>}
  </section>
</BaseLayout>
