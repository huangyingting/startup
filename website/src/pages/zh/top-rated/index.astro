---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReportCard from '../../../components/ReportCard.astro';
import { sortTopRated } from '../../../lib/reports';

const reports = sortTopRated(await getCollection('reports'));
---
<BaseLayout title="高分报告 — 创业研究" description="按整体评分排序的创业研究报告。" lang="zh">
  <section class="sr-container sr-hero"><h1>高分报告。</h1><p class="sr-deck">按整体评分排序，评分相同时优先展示较新的报告。</p></section>
  <section class="sr-container sr-section"><h2>最高评分</h2><div class="sr-grid">{reports.map((entry) => <ReportCard entry={entry} lang="zh" />)}</div></section>
</BaseLayout>
