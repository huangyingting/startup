---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DiligenceReport from '../../components/DiligenceReport.astro';
import { loadStageFiles } from '../../content/reports-loader';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((entry) => ({ params: { run: entry.data.folderSlug }, props: { entry } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'reports'> };
const stages = loadStageFiles(entry.id) as any;
---
<BaseLayout title={`${entry.data.company.name} — Startup Diligence`} description={entry.data.headline}>
  <DiligenceReport entry={entry} data={entry.data} stages={stages} />
</BaseLayout>
