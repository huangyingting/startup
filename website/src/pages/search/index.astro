---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Search — Startup Diligence">
  <section class="sr-container sr-hero"><h1>Search dossiers.</h1><p class="sr-deck">Search by company, thesis, sector, date, source count, rating signal, or diligence gap. Everything runs locally in your browser.</p></section>
  <section class="sr-container sr-section" data-search-root data-index-url={`${import.meta.env.BASE_URL}search-index.json`}>
    <input class="sr-input" type="search" placeholder="Search startup reports..." data-search-input />
    <p class="sr-muted" data-search-status>Type to search reports.</p>
    <div class="sr-grid" data-search-results></div>
  </section>
  <script>
    const root = document.querySelector('[data-search-root]');
    const input = root?.querySelector('[data-search-input]');
    const status = root?.querySelector('[data-search-status]');
    const results = root?.querySelector('[data-search-results]');
    const state = { docs: [] };
    const norm = (v) => String(v ?? '').toLowerCase().trim();
    const render = () => {
      if (!root || !input || !status || !results) return;
      const query = norm(input.value);
      if (!query) { status.textContent = 'Type at least one character to filter the dossier archive.'; results.replaceChildren(); return; }
      const terms = query.split(/\s+/).filter(Boolean);
      const matches = state.docs.filter((doc) => terms.every((term) => doc.searchText.includes(term))).slice(0, 30);
      status.textContent = `${matches.length} result${matches.length === 1 ? '' : 's'}`;
      results.replaceChildren(...matches.map((doc) => {
        const link = document.createElement('a');
        link.className = 'sr-card';
        link.href = doc.href;
        link.innerHTML = `<div class="sr-meta sr-kicker"><span>${doc.title}</span><span>·</span><span>${doc.sector}</span></div><h3>${doc.headline}</h3><p><span class="sr-score">${Number(doc.rating).toFixed(1)}</span> Overall rating · ${doc.date}</p>`;
        return link;
      }));
    };
    fetch(root?.dataset.indexUrl || '').then((r) => r.json()).then((docs) => { state.docs = Array.isArray(docs) ? docs : []; render(); }).catch(() => { if (status) status.textContent = 'Search index unavailable.'; });
    input?.addEventListener('input', render);
  </script>
</BaseLayout>
