---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortNewest, tagSlug } from '../../lib/reports';

const reports = sortNewest(await getCollection('reports'));
const sectors = [...reports.reduce((map, entry) => {
  const sector = entry.data.company.sector ?? 'Other';
  const list = map.get(sector) ?? [];
  list.push(entry);
  map.set(sector, list);
  return map;
}, new Map<string, typeof reports>()).entries()].sort((a, b) => b[1].length - a[1].length || a[0].localeCompare(b[0]));
---
<BaseLayout title="Sector index — Startup Diligence" description="Filter the dossier library by market category.">
  <section class="sr-container sr-hero">
    <h1>Sector index.</h1>
    <p class="sr-deck">Filter the dossier library by market category, from enterprise AI to climate, healthcare, consumer, and fintech opportunities.</p>
  </section>
  <section class="sr-container sr-section">
    <h2>Sectors</h2>
    <div class="sr-grid">
      {sectors.map(([sector, entries]) => {
        const avg = entries.reduce((sum, entry) => sum + entry.data.overallScore, 0) / entries.length;
        return <a class="sr-card" href={`#${tagSlug(sector)}`} id={tagSlug(sector)}><div class="sr-kicker">{sector}</div><h3>{entries.length} dossiers</h3><p>Avg rating {avg.toFixed(1)} · Recent month {entries[0].data.runDate.slice(0, 7)}</p><span class="sr-pill">Open sector →</span></a>;
      })}
    </div>
  </section>
</BaseLayout>
