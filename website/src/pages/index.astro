---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ReportCard from '../components/ReportCard.astro';
import { t } from '../lib/i18n';
import { sortNewest, sortTopRated } from '../lib/reports';

const reports = await getCollection('reports');
const latest = sortNewest(reports).slice(0, 12);
const top = sortTopRated(reports)[0];
---
<BaseLayout title={t('title')} description={t('deck')}>
  <section class="sr-container sr-hero">
    <h1>Startup research,<br />read like a venture memo.</h1>
    <p class="sr-deck">Each dossier walks a company through identity verification, evidence collection, market research, product analysis, business diligence, risk review, and a structured memo — all generated end-to-end by specialist agents.</p>
  </section>

  {top && <section class="sr-container sr-section"><h2>Featured dossier</h2><ReportCard entry={top} /></section>}

  <section class="sr-container sr-section">
    <h2>More dossiers</h2>
    {latest.length ? <div class="sr-grid">{latest.map((entry) => <ReportCard entry={entry} />)}</div> : <p>{t('noReports')}</p>}
  </section>
</BaseLayout>
