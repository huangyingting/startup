---
import type { CollectionEntry } from 'astro:content';
import ClaimRefs from './ClaimRefs.astro';
import ReportBlock from './ReportBlock.astro';
import DataTable from './DataTable.astro';
import { displayLabel } from '../lib/display';

interface Props {
  entry: CollectionEntry<'reports'>;
  data: any;
  stages: any;
}

const { data, stages } = Astro.props;

const doc = stages.fullReport ?? null;
const ledger = stages.evidence ?? {};
const claims: any[] = Array.isArray(ledger.claims) ? ledger.claims : [];
const sources: any[] = Array.isArray(ledger.sources) ? ledger.sources : [];
const figures = new Map<string, any>((doc?.figures ?? []).map((figure: any) => [figure.id, figure]));
const tables = new Map<string, any>((doc?.tables ?? []).map((table: any) => [table.id, table]));

const labels = {
  recommendation: 'Recommendation', confidence: 'Confidence', riskRating: 'Risk rating',
  valuationStance: 'Valuation stance', score: 'Score', sources: 'sources', claims: 'claims',
  figures: 'figures', tables: 'tables',
  coverMetrics: 'Cover facts', startupIntro: 'Company profile',
  founded: 'Founded', founders: 'Founders', foundingLocation: 'Founding location',
  headquarters: 'Headquarters', product: 'Product', customers: 'Customers',
  businessModel: 'Business model', stage: 'Stage', fundingStatus: 'Funding status',
  strengths: 'Top strengths', risks: 'Top risks', gaps: 'Open gaps',
  contents: 'Contents', appendix: 'Appendix', disclaimer: 'Disclaimer',
  evidence: 'Evidence index', showRefs: 'Show refs', hideRefs: 'Hide refs',
};

function arr<T = unknown>(value: T[] | undefined | null): T[] {
  return Array.isArray(value) ? value : [];
}

function metric(value: unknown, suffix = ''): string {
  if (value === null || value === undefined || value === '') return '—';
  if (typeof value === 'number') return `${value.toLocaleString()}${suffix}`;
  return String(value);
}

function moneyM(value: unknown): string {
  if (value === null || value === undefined || value === '') return '—';
  if (typeof value !== 'number') return String(value);
  if (Math.abs(value) >= 1000) {
    return `$${(value / 1000).toLocaleString(undefined, { maximumFractionDigits: 1 })}B`;
  }
  return `$${value.toLocaleString(undefined, { maximumFractionDigits: 1 })}M`;
}

function cleanHeadline(value: unknown): string {
  return String(value ?? '').replace(/(?:\s*\[C\d{3}\])+\.?$/g, '.').trim();
}

function splitClaimRefsText(value: unknown): Array<{ text?: string; ref?: string }> {
  const text = String(value ?? '');
  const parts: Array<{ text?: string; ref?: string }> = [];
  const pattern = /\[(C\d{3})\]/g;
  let lastIndex = 0;
  for (const match of text.matchAll(pattern)) {
    if (match.index > lastIndex) parts.push({ text: text.slice(lastIndex, match.index) });
    parts.push({ ref: match[1] });
    lastIndex = match.index + match[0].length;
  }
  if (lastIndex < text.length) parts.push({ text: text.slice(lastIndex) });
  return parts.length ? parts : [{ text }];
}

function blockRefs(value: any): string[] {
  return arr<string>(value?.claimRefs).slice(0, 6);
}

const coverFacts = arr(doc?.coverFacts);
const companyProfile = doc?.companyProfile
  ? {
      ...doc.companyProfile,
      summary: doc.companyProfile.summary ?? doc.companyProfile.body ?? null,
    }
  : null;

const chapters = arr<any>(doc?.chapters);
const appendices = arr<any>(doc?.appendices);
const reportFigures = arr(doc?.figures);
const reportTables = arr(doc?.tables);
const figureCount = reportFigures.length;
const tableCount = reportTables.length;

const claimLinkMap = Object.fromEntries(
  claims.map((claim: any) => [claim.id, { href: `#claim-${claim.id}`, title: claim.statement ?? claim.id }])
);

const keyMetrics = data.keyMetrics ?? {};
const fallbackMetrics = [
  ['Valuation', moneyM(keyMetrics.valuationUsdM)],
  ['Revenue run rate', moneyM(keyMetrics.revenueRunRateUsdM)],
  ['ARR', moneyM(keyMetrics.arrUsdM)],
  ['Growth', metric(keyMetrics.revenueGrowthYoYPct, '%')],
  ['NRR', metric(keyMetrics.nrrPct, '%')],
  ['Total raised', moneyM(keyMetrics.totalRaisedUsdM)],
  ['Customers', metric(keyMetrics.customerCount)],
  ['Headcount', metric(keyMetrics.headcount)],
].filter(([, value]) => value !== '—');
---
<section class="report-shell sr-container">
  <header class="report-cover">
    <div class="report-cover-main">
      <div class="cover-eyebrow">
        <span class="cover-eyebrow-tag">Diligence report</span>
        {data.company?.sector && <span class="cover-eyebrow-meta">{data.company.sector}</span>}
        {data.company?.stage && <span class="cover-eyebrow-meta">{data.company.stage}</span>}
        <span class="cover-eyebrow-meta">{data.runDate}</span>
      </div>
      <h1>{doc?.company?.name ?? data.company?.name ?? data.slug}</h1>
      {(doc?.subtitle ?? null) && <p class="report-subtitle">{doc?.subtitle}</p>}
      <p class="report-headline">{cleanHeadline(data.headline)}</p>
      <div class="report-meta-line">
        <span>{data.sourceStats.sourcesRetained} {labels.sources}</span>
        <span>{data.sourceStats.claimsReviewed} {labels.claims}</span>
        {data.sourceStats?.domainCount != null && (<span>{data.sourceStats.domainCount} domains</span>)}
        {data.sourceStats?.adverseSourceCount != null && (<span>{data.sourceStats.adverseSourceCount} adverse</span>)}
        {data.sourceStats?.unresolvedQuestionCount != null && data.sourceStats.unresolvedQuestionCount > 0 && (
          <span>{data.sourceStats.unresolvedQuestionCount} open Qs</span>
        )}
        <span>{figureCount} {labels.figures}</span>
        <span>{tableCount} {labels.tables}</span>
        <button
          type="button"
          class="evidence-toggle"
          aria-pressed="false"
          data-show-label={labels.showRefs}
          data-hide-label={labels.hideRefs}
        >{labels.showRefs}</button>
      </div>
    </div>
    <aside class={`decision-card decision-${String(data.recommendation ?? 'unknown').replace(/[^a-z0-9-]/gi, '-')}`}>
      <div class="decision-headline">
        <span class="decision-eyebrow">{labels.recommendation}</span>
        <strong class="decision-rec">{displayLabel(data.recommendation)}</strong>
      </div>
      <div class="decision-score">
        <span class="decision-score-value">{data.overallScore.toFixed(1)}</span>
        <span class="decision-score-label">{labels.score} / 10</span>
      </div>
      <dl class="decision-grid">
        <div><dt>{labels.confidence}</dt><dd>{displayLabel(data.confidence)}</dd></div>
        <div><dt>{labels.riskRating}</dt><dd>{displayLabel(data.riskRating)}</dd></div>
        <div><dt>{labels.valuationStance}</dt><dd>{displayLabel(data.valuationStance)}</dd></div>
      </dl>
    </aside>
  </header>

  <section class="report-section cover-metrics">
    <h2>{labels.coverMetrics}</h2>
    <div class="metric-grid">
      {coverFacts.length
        ? coverFacts.map((item: any, index: number) => (
            <article>
              <div class="metric-topline">
                <span class="metric-label">{item.label}</span>
                <em>{String(index + 1).padStart(2, '0')}</em>
              </div>
              <strong>{item.value == null ? '—' : `${item.value}${item.unit ? ` ${item.unit}` : ''}`}</strong>
              <ClaimRefs refs={blockRefs(item)} claims={claims} sources={sources} />
            </article>
          ))
        : fallbackMetrics.map(([label, value], index) => (
            <article>
              <div class="metric-topline">
                <span class="metric-label">{label}</span>
                <em>{String(index + 1).padStart(2, '0')}</em>
              </div>
              <strong>{value}</strong>
            </article>
          ))}
    </div>
  </section>

  {companyProfile && (
    <section class="report-section startup-intro">
      <h2>{labels.startupIntro}</h2>
      {companyProfile.heading && <p class="intro-heading"><strong>{companyProfile.heading}</strong></p>}
      {companyProfile.summary && (
        <p>
          {splitClaimRefsText(companyProfile.summary).map((part) => part.ref
            ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} />
            : part.text)}
        </p>
      )}
      <dl class="intro-grid">
        {companyProfile.foundedDate && (
          <div><dt>{labels.founded}</dt><dd>{companyProfile.foundedDate}</dd></div>
        )}
        {arr(companyProfile.founders).length > 0 && (
          <div><dt>{labels.founders}</dt><dd>{arr(companyProfile.founders).map((founder: any) => founder.name).join(', ')}</dd></div>
        )}
        {companyProfile.foundingLocation && <div><dt>{labels.foundingLocation}</dt><dd>{companyProfile.foundingLocation}</dd></div>}
        {companyProfile.headquarters && <div><dt>{labels.headquarters}</dt><dd>{companyProfile.headquarters}</dd></div>}
        {companyProfile.productSummary && <div><dt>{labels.product}</dt><dd>{companyProfile.productSummary}</dd></div>}
        {companyProfile.customerFocus && <div><dt>{labels.customers}</dt><dd>{companyProfile.customerFocus}</dd></div>}
        {companyProfile.businessModel && <div><dt>{labels.businessModel}</dt><dd>{companyProfile.businessModel}</dd></div>}
        {companyProfile.stage && <div><dt>{labels.stage}</dt><dd>{companyProfile.stage}</dd></div>}
        {companyProfile.fundingStatus && <div><dt>{labels.fundingStatus}</dt><dd>{companyProfile.fundingStatus}</dd></div>}
      </dl>
      <ClaimRefs refs={(companyProfile.claimRefs ?? []).slice(0, 8)} claims={claims} sources={sources} />
    </section>
  )}

  {(data.topStrengths.length > 0 || data.topRisks.length > 0 || data.unresolvedGaps.length > 0) && (
    <section class="report-section executive-summary">
      <h2>Executive summary</h2>
      <div class="three-col">
        <article class="summary-card summary-strengths">
          <h2>{labels.strengths}</h2>
          <ul>
            {arr(data.topStrengths).map((item) => (
              <li>{splitClaimRefsText(item).map((part) => part.ref
                ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} />
                : part.text)}</li>
            ))}
          </ul>
        </article>
        <article class="summary-card summary-risks">
          <h2>{labels.risks}</h2>
          <ul>
            {arr(data.topRisks).map((item) => (
              <li>{splitClaimRefsText(item).map((part) => part.ref
                ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} />
                : part.text)}</li>
            ))}
          </ul>
        </article>
        <article class="summary-card summary-gaps">
          <h2>{labels.gaps}</h2>
          <ul>
            {arr(data.unresolvedGaps).map((item) => (
              <li>{splitClaimRefsText(item).map((part) => part.ref
                ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} />
                : part.text)}</li>
            ))}
          </ul>
        </article>
      </div>
    </section>
  )}

  {chapters.length > 0 && (
    <section class="report-section toc-heading-section" id="contents">
      <h2>{labels.contents}</h2>
    </section>
  )}
  {chapters.length > 0 && (
    <nav class="toc-sticky" aria-label={labels.contents} data-toc>
      <ol class="toc-list" id="toc-list">
        {chapters.map((chapter: any) => (
          <li class="toc-item" data-toc-target={`chapter-${chapter.number}`}>
            <a href={`#chapter-${chapter.number}`}>
              <span class="toc-number">{String(chapter.number).padStart(2, '0')}</span>
              <span class="toc-title">{chapter.title}</span>
            </a>
          </li>
        ))}
        {appendices.map((appendix: any) => (
          <li class="toc-item toc-appendix" data-toc-target={`appendix-${appendix.id}`}>
            <a href={`#appendix-${appendix.id}`}>
              <span class="toc-number">{appendix.id}</span>
              <span class="toc-title">{appendix.title}</span>
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )}

  {chapters.map((chapter: any) => (
    <article class="report-chapter" id={`chapter-${chapter.number}`}>
      <header class="chapter-header">
        <span class="chapter-eyebrow">Chapter {String(chapter.number).padStart(2, '0')}</span>
        <h2><span class="chapter-number">{String(chapter.number).padStart(2, '0')}</span><span class="chapter-title">{chapter.title}</span></h2>
      </header>
      {arr(chapter.sections).map((section: any) => (
        <section class="chapter-section">
          <h3>{section.number} {section.title}</h3>
          {arr(section.blocks).map((block: any) => (
            <ReportBlock block={block} tables={tables} figures={figures} claims={claims} sources={sources} />
          ))}
        </section>
      ))}
    </article>
  ))}

  {appendices.map((appendix: any) => (
    <section class="report-section appendix" id={`appendix-${appendix.id}`}>
      <h2>{labels.appendix} {appendix.id}: {appendix.title}</h2>
      {arr(appendix.blocks).map((block: any) => (
        <ReportBlock block={block} tables={tables} figures={figures} claims={claims} sources={sources} />
      ))}
    </section>
  ))}

  {doc?.disclaimer && (
    <section class="report-section disclaimer"><h2>{labels.disclaimer}</h2><p>{doc.disclaimer}</p></section>
  )}

  {(claims.length > 0 || sources.length > 0) && (
    <section class="report-section evidence-index">
      <h2>{labels.evidence}</h2>
      {claims.length > 0 && (
        <DataTable title="Claims" columns={['ID', 'Statement', 'Confidence', 'Sources']}>
          {claims.map((claim: any) => (
            <tr id={`claim-${claim.id}`}>
              <td><a class="evidence-id" href={`#claim-${claim.id}`}>{claim.id}</a></td>
              <td>{claim.statement}</td>
              <td>{displayLabel(claim.confidence)}</td>
              <td>
                {(claim.sourceRefs ?? []).map((ref: string, index: number, list: string[]) => (
                  <>
                    <a href={`#source-${ref}`}>{ref}</a>{index < list.length - 1 ? ', ' : ''}
                  </>
                ))}
              </td>
            </tr>
          ))}
        </DataTable>
      )}
      {sources.length > 0 && (
        <DataTable title="Sources" columns={['ID', 'Publisher', 'Title', 'Quote']}>
          {sources.map((source: any) => (
            <tr id={`source-${source.id}`}>
              <td><a class="evidence-id" href={`#source-${source.id}`}>{source.id}</a></td>
              <td>{source.publisher}</td>
              <td>{source.url ? <a href={source.url}>{source.title}</a> : source.title}</td>
              <td>{source.keyQuote}</td>
            </tr>
          ))}
        </DataTable>
      )}
    </section>
  )}
</section>

<script type="application/json" id="claim-link-map" set:html={JSON.stringify(claimLinkMap)}></script>
<script type="module" is:inline>
  // Replace inline `[C123]` markers in body text with linked spans, and wire
  // the evidence toggle to show/hide the markers throughout the report.
  const claimLinkMapElement = document.getElementById('claim-link-map');
  const claimLinkMap = claimLinkMapElement
    ? JSON.parse(claimLinkMapElement.textContent || '{}')
    : {};

  const makeClaimRef = (ref) => {
    const link = claimLinkMap[ref] || { href: `#claim-${ref}`, title: ref };
    const span = document.createElement('span');
    span.className = 'claim-ref';
    span.append('[');
    const anchor = document.createElement('a');
    anchor.href = link.href;
    anchor.textContent = ref;
    anchor.title = link.title || ref;
    span.append(anchor, ']');
    return span;
  };

  const reportShell = document.querySelector('.report-shell');
  if (reportShell) {
    const walker = document.createTreeWalker(reportShell, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        const parent = node.parentElement;
        if (!parent || parent.closest('script, style, pre, a, .claim-ref')) return NodeFilter.FILTER_REJECT;
        return /\[C\d{3}\]/.test(node.nodeValue || '') ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
      },
    });
    const nodes = [];
    while (walker.nextNode()) nodes.push(walker.currentNode);
    for (const node of nodes) {
      const fragment = document.createDocumentFragment();
      const text = node.nodeValue || '';
      let lastIndex = 0;
      for (const match of text.matchAll(/\[(C\d{3})\]/g)) {
        if (match.index > lastIndex) fragment.append(text.slice(lastIndex, match.index));
        fragment.append(makeClaimRef(match[1]));
        lastIndex = match.index + match[0].length;
      }
      if (lastIndex < text.length) fragment.append(text.slice(lastIndex));
      node.parentNode?.replaceChild(fragment, node);
    }
  }

  const evidenceToggle = document.querySelector('.evidence-toggle');
  if (reportShell && evidenceToggle) {
    const showLabel = evidenceToggle.dataset.showLabel || 'Show refs';
    const hideLabel = evidenceToggle.dataset.hideLabel || 'Hide refs';
    const setRefsVisible = (visible) => {
      reportShell.classList.toggle('refs-visible', visible);
      evidenceToggle.setAttribute('aria-pressed', String(visible));
      evidenceToggle.textContent = visible ? hideLabel : showLabel;
    };
    evidenceToggle.addEventListener('click', () => {
      setRefsVisible(!reportShell.classList.contains('refs-visible'));
    });
    setRefsVisible(false);
  }

  // Sticky TOC: scroll-spy active state
  const tocNav = document.querySelector('[data-toc]');
  if (tocNav) {
    const items = Array.from(tocNav.querySelectorAll('.toc-item'));
    // Scroll-spy: highlight the toc-item whose target is currently most visible
    const targets = items
      .map((item) => {
        const id = item.getAttribute('data-toc-target');
        const el = id ? document.getElementById(id) : null;
        return el ? { item, el } : null;
      })
      .filter(Boolean);
    if (targets.length && 'IntersectionObserver' in window) {
      const visible = new Map();
      const setActive = (activeItem) => {
        items.forEach((item) => item.classList.toggle('is-active', item === activeItem));
      };
      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) visible.set(entry.target, entry.intersectionRatio);
          else visible.delete(entry.target);
        }
        let bestEl = null;
        let bestRatio = 0;
        for (const [el, ratio] of visible) {
          if (ratio > bestRatio) { bestRatio = ratio; bestEl = el; }
        }
        if (bestEl) {
          const match = targets.find((t) => t.el === bestEl);
          if (match) setActive(match.item);
        }
      }, { rootMargin: '-30% 0px -55% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] });
      targets.forEach(({ el }) => observer.observe(el));
    }
  }
</script>

<style>
  .report-shell {
    --report-fs-kicker: clamp(0.82rem, 0.12vw + 0.78rem, 0.9rem);
    --report-fs-caption: clamp(0.88rem, 0.14vw + 0.82rem, 0.98rem);
    --report-fs-body: clamp(1.02rem, 0.18vw + 0.96rem, 1.12rem);
    --report-fs-table: clamp(0.94rem, 0.14vw + 0.88rem, 1.02rem);
    --report-fs-note: var(--report-fs-body);
    --report-fs-subhead: clamp(1.35rem, 0.6vw + 1.05rem, 1.7rem);
    --report-fs-section: clamp(1.75rem, 1.1vw + 1.15rem, 2.2rem);
    padding-block: var(--space-6) 0;
    overflow-x: clip;
    font-size: var(--report-fs-body);
  }
  .report-cover { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 360px); gap: var(--space-7); align-items: stretch; padding: var(--space-6) var(--space-5); margin-bottom: var(--space-5); border-top: 4px solid var(--claret); border-bottom: var(--report-rule); background: linear-gradient(135deg, color-mix(in srgb, var(--claret) 5%, var(--surface-paper)) 0%, var(--surface-paper) 60%, color-mix(in srgb, var(--gold) 4%, var(--surface-paper)) 100%); }
  .report-cover-main { display: flex; flex-direction: column; gap: var(--space-3); min-width: 0; }
  .cover-eyebrow { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2) var(--space-3); margin-bottom: var(--space-2); font-family: var(--font-sans); font-size: var(--report-fs-kicker); letter-spacing: var(--tracking-eyebrow); }
  .cover-eyebrow-tag { display: inline-block; padding: 3px var(--space-2); border-radius: 999px; background: var(--claret); color: #fff7ef; font-variant-caps: all-small-caps; font-weight: 800; line-height: 1.1; }
  .cover-eyebrow-meta { color: var(--caption-gray); font-variant-caps: all-small-caps; font-weight: 700; }
  .cover-eyebrow-meta + .cover-eyebrow-meta::before { content: '·'; margin-right: var(--space-3); color: color-mix(in srgb, var(--caption-gray) 50%, transparent); }
  .report-cover h1 { margin: 0; max-width: 22ch; font-family: var(--font-display); font-size: clamp(2.4rem, 4vw + 1rem, 4rem); font-weight: 700; letter-spacing: var(--tracking-display-tight); line-height: 0.98; color: var(--ink-page); }
  .report-subtitle, .report-headline { width: 100%; max-width: 56ch; color: var(--ink-page); font-family: var(--font-sans); line-height: 1.5; }
  .report-subtitle { font-size: var(--report-fs-body); color: var(--caption-gray); margin-top: 0; }
  .report-headline { font-size: clamp(1.05rem, 0.4vw + 0.95rem, 1.2rem); font-weight: 500; }
  .report-meta-line { display: flex; flex-wrap: wrap; align-items: center; column-gap: var(--space-3); row-gap: var(--space-2); margin-top: auto; padding-top: var(--space-4); font-family: var(--font-sans); font-size: var(--report-fs-caption); }
  .report-meta-line span { color: var(--caption-gray); }
  .report-meta-line span + span:not(:last-of-type)::before { content: '·'; margin-right: var(--space-3); color: color-mix(in srgb, var(--caption-gray) 50%, transparent); }
  .evidence-toggle { appearance: none; border: 1px solid var(--claret); background: transparent; color: var(--claret); cursor: pointer; font-family: var(--font-sans); font-variant-caps: all-small-caps; font-size: var(--report-fs-caption); font-weight: 800; letter-spacing: var(--tracking-eyebrow); line-height: 1.2; padding: 4px var(--space-3); border-radius: 999px; margin-left: auto; }
  .evidence-toggle:hover, .evidence-toggle:focus-visible, .evidence-toggle[aria-pressed="true"] { background: var(--claret); color: #fff7ef; outline: none; }
  /* Decision card: hero panel with recommendation as the primary visual */
  .decision-card { --decision-accent: var(--claret); --decision-accent-soft: color-mix(in srgb, var(--claret) 12%, transparent); display: flex; flex-direction: column; gap: var(--space-4); align-self: stretch; padding: var(--space-4) var(--space-4) var(--space-4); background: var(--surface-paper); border-top: 3px solid var(--decision-accent); border-radius: var(--radius-card); box-shadow: 0 1px 0 color-mix(in srgb, var(--ink-page) 6%, transparent); }
  .decision-buy, .decision-strong-buy, .decision-invest { --decision-accent: var(--gold); }
  .decision-pass, .decision-avoid, .decision-decline { --decision-accent: var(--risk-red); }
  .decision-research-more, .decision-track, .decision-monitor { --decision-accent: var(--claret); }
  .decision-headline { display: flex; flex-direction: column; gap: var(--space-1); }
  .decision-eyebrow { font-family: var(--font-sans); font-variant-caps: all-small-caps; font-size: var(--report-fs-kicker); font-weight: 800; letter-spacing: var(--tracking-eyebrow); color: var(--caption-gray); line-height: 1.1; }
