  .report-table { min-width: 720px; border: 0; border-collapse: separate; border-spacing: 0; background: transparent; }
  .report-table caption { text-align: left; caption-side: top; padding: var(--space-3) var(--space-4); border-bottom: var(--report-rule); background: color-mix(in srgb, var(--claret) 6%, transparent); font-family: var(--font-sans); font-variant-caps: all-small-caps; font-weight: 800; letter-spacing: var(--tracking-eyebrow); color: var(--claret); }
  .report-table th, .report-table td { border-bottom: var(--report-rule); padding: var(--space-3) var(--space-4); vertical-align: top; }
  .report-table th { background: color-mix(in srgb, var(--paper) 80%, white); color: color-mix(in srgb, var(--claret) 88%, var(--ink-page)); white-space: nowrap; }
  .report-table tbody tr:nth-child(even) { background: color-mix(in srgb, var(--paper) 72%, white); }
  .report-table tbody tr:hover { background: color-mix(in srgb, var(--claret) 5%, transparent); }
  .report-table tbody tr:last-child td { border-bottom: 0; }
