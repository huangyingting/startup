---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../lib/i18n';
import ClaimRefs from './ClaimRefs.astro';
import FigureRenderer from './FigureRenderer.astro';
import { displayLabel } from '../lib/display';

interface Props {
  entry: CollectionEntry<'reports'>;
  data: any;
  stages: any;
  lang?: Lang;
}

const { data, stages, lang = 'en' } = Astro.props;
const doc = stages.reportDocument ?? null;
const ledger = stages.evidenceLedger ?? {};
const claims = Array.isArray(ledger.claims) ? ledger.claims : [];
const sources = Array.isArray(ledger.sources) ? ledger.sources : [];
const figures = new Map((doc?.figures ?? []).map((figure: any) => [figure.id, figure]));
const tables = new Map((doc?.tables ?? []).map((table: any) => [table.id, table]));

const labels = lang === 'zh'
  ? {
      recommendation: '建议', confidence: '置信度', riskRating: '风险评级', valuationStance: '估值判断', score: '评分', sources: '来源', claims: '声明', figures: '图表', tables: '表格',
      coverMetrics: '封面指标', startupIntro: '创业公司基本介绍', founded: '创立时间', founders: '创始人', foundingLocation: '创立地点', headquarters: '总部', product: '产品', customers: '客户', businessModel: '商业模式', stage: '阶段', fundingStatus: '融资状态', strengths: '核心亮点', risks: '核心风险', gaps: '未解问题', contents: '目录', bibliography: '参考文献', disclaimer: '免责声明', evidence: '证据索引', showRefs: '显示引用', hideRefs: '隐藏引用'
    }
  : {
      recommendation: 'Recommendation', confidence: 'Confidence', riskRating: 'Risk rating', valuationStance: 'Valuation stance', score: 'Score', sources: 'sources', claims: 'claims', figures: 'figures', tables: 'tables',
      coverMetrics: 'Cover metrics', startupIntro: 'Startup introduction', founded: 'Founded', founders: 'Founders', foundingLocation: 'Founding location', headquarters: 'Headquarters', product: 'Product', customers: 'Customers', businessModel: 'Business model', stage: 'Stage', fundingStatus: 'Funding status', strengths: 'Top strengths', risks: 'Top risks', gaps: 'Open gaps', contents: 'Contents', bibliography: 'Bibliography', disclaimer: 'Disclaimer', evidence: 'Evidence index', showRefs: 'Show refs', hideRefs: 'Hide refs'
    };

function arr<T = any>(value: T[] | undefined | null): T[] { return Array.isArray(value) ? value : []; }
function labelValue(value: unknown) { return displayLabel(value); }
function metric(value: unknown, suffix = '') {
  if (value === null || value === undefined || value === '') return '—';
  if (typeof value === 'number') return `${value.toLocaleString()}${suffix}`;
  return String(value);
}
function moneyM(value: unknown) {
  if (value === null || value === undefined || value === '') return '—';
  if (typeof value !== 'number') return String(value);
  if (Math.abs(value) >= 1000) return `$${(value / 1000).toLocaleString(undefined, { maximumFractionDigits: 1 })}B`;
  return `$${value.toLocaleString(undefined, { maximumFractionDigits: 1 })}M`;
}
function cleanHeadline(value: unknown) {
  return String(value ?? '').replace(/(?:\s*\[C\d{3}\])+\.?$/g, '.').trim();
}
function splitClaimRefsText(value: unknown) {
  const text = String(value ?? '');
  const parts: Array<{ text?: string; ref?: string }> = [];
  const pattern = /\[(C\d{3})\]/g;
  let lastIndex = 0;
  for (const match of text.matchAll(pattern)) {
    if (match.index > lastIndex) parts.push({ text: text.slice(lastIndex, match.index) });
    parts.push({ ref: match[1] });
    lastIndex = match.index + match[0].length;
  }
  if (lastIndex < text.length) parts.push({ text: text.slice(lastIndex) });
  return parts.length ? parts : [{ text }];
}
function hasInlineClaimRefs(value: unknown) { return /\[C\d{3}\]/.test(String(value ?? '')); }
function blockRefs(block: any) { return arr<string>(block?.claimRefs).slice(0, 6); }
function blockClass(type: string | null | undefined) { return `report-callout callout-${String(type ?? 'key-insight').replace(/[^a-z0-9-]/gi, '-')}`; }

const coverMetrics = arr(doc?.coverMetrics);
const documentStartupIntroduction = doc?.startupIntroduction ?? null;
const snapshotStartupIntroduction = stages.companySnapshot?.startupIntroduction ?? null;
const startupIntroduction = documentStartupIntroduction || snapshotStartupIntroduction
  ? {
      ...(snapshotStartupIntroduction ?? {}),
      ...(documentStartupIntroduction ?? {}),
      summary: documentStartupIntroduction?.summary ?? documentStartupIntroduction?.body ?? snapshotStartupIntroduction?.summary ?? snapshotStartupIntroduction?.body ?? null,
    }
  : null;
const chapters = arr(doc?.chapters);
const reportFigures = arr(doc?.figures);
const reportTables = arr(doc?.tables);
const figureCount = reportFigures.length || data.figureCount || 0;
const tableCount = reportTables.length || data.tableCount || 0;
const claimLinkMap = Object.fromEntries(claims.map((claim: any) => {
  return [claim.id, {
    href: `#claim-${claim.id}`,
    title: claim.statement ?? claim.id,
  }];
}));
const keyMetrics = data.keyMetrics ?? {};
const fallbackMetrics = [
  ['Valuation', moneyM(keyMetrics.valuationUsdM)],
  ['Revenue run rate', moneyM(keyMetrics.revenueRunRateUsdM)],
  ['ARR', moneyM(keyMetrics.arrUsdM)],
  ['Growth', metric(keyMetrics.revenueGrowthYoYPct, '%')],
  ['NRR', metric(keyMetrics.nrrPct, '%')],
  ['Total raised', moneyM(keyMetrics.totalRaisedUsdM)],
  ['Customers', metric(keyMetrics.customerCount)],
  ['Headcount', metric(keyMetrics.headcount)],
].filter(([, value]) => value !== '—');
---
<section class="report-shell sr-container">
  <header class="report-cover">
    <div>
      <h1>{doc?.reportMeta?.title ?? data.title}</h1>
      {(doc?.company?.subtitle ?? data.subtitle) && <p class="report-subtitle">{doc?.company?.subtitle ?? data.subtitle}</p>}
      <p class="report-headline">{cleanHeadline(data.headline)}</p>
      <div class="report-meta-line">
        <span>{data.runDate}</span>
        <span>{data.sourceStats.sourcesRetained} {labels.sources}</span>
        <span>{data.sourceStats.claimsReviewed} {labels.claims}</span>
        <span>{figureCount} {labels.figures}</span>
        <span>{tableCount} {labels.tables}</span>
        <button type="button" class="evidence-toggle" aria-pressed="false" data-show-label={labels.showRefs} data-hide-label={labels.hideRefs}>{labels.showRefs}</button>
      </div>
    </div>
    <aside class="decision-card">
      <dl>
        <div><dt>{labels.recommendation}</dt><dd>{labelValue(data.recommendation)}</dd></div>
        <div><dt>{labels.confidence}</dt><dd>{labelValue(data.confidence)}</dd></div>
        <div><dt>{labels.riskRating}</dt><dd>{labelValue(data.riskRating)}</dd></div>
        <div><dt>{labels.valuationStance}</dt><dd>{labelValue(data.valuationStance)}</dd></div>
        <div><dt>{labels.score}</dt><dd>{data.overallScore.toFixed(1)}</dd></div>
      </dl>
    </aside>
  </header>

  <section class="report-section cover-metrics">
    <h2>{labels.coverMetrics}</h2>
    <div class="metric-grid">
      {coverMetrics.length ? coverMetrics.map((item: any, index: number) => (
        <article>
          <div class="metric-topline"><span class="metric-label">{item.label}</span><em>{String(index + 1).padStart(2, '0')}</em></div>
          <strong>{item.value}</strong>
          <ClaimRefs refs={blockRefs(item)} claims={claims} sources={sources} />
        </article>
      )) : fallbackMetrics.map(([label, value], index) => <article><div class="metric-topline"><span class="metric-label">{label}</span><em>{String(index + 1).padStart(2, '0')}</em></div><strong>{value}</strong></article>)}
    </div>
  </section>

  {startupIntroduction && (
    <section class="report-section startup-intro">
      <h2>{labels.startupIntro}</h2>
      {startupIntroduction.heading && <p class="intro-heading"><strong>{startupIntroduction.heading}</strong></p>}
      {startupIntroduction.summary && <p>{splitClaimRefsText(startupIntroduction.summary).map((part) => part.ref ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} /> : part.text)}</p>}
      <dl class="intro-grid">
        {(startupIntroduction.foundedDate || startupIntroduction.foundedYear) && <div><dt>{labels.founded}</dt><dd>{startupIntroduction.foundedDate ?? startupIntroduction.foundedYear}</dd></div>}
        {arr(startupIntroduction.founders).length > 0 && <div><dt>{labels.founders}</dt><dd>{arr(startupIntroduction.founders).map((founder: any) => founder.name).join(', ')}</dd></div>}
        {startupIntroduction.foundingLocation && <div><dt>{labels.foundingLocation}</dt><dd>{startupIntroduction.foundingLocation}</dd></div>}
        {startupIntroduction.headquarters && <div><dt>{labels.headquarters}</dt><dd>{startupIntroduction.headquarters}</dd></div>}
        {startupIntroduction.productSummary && <div><dt>{labels.product}</dt><dd>{startupIntroduction.productSummary}</dd></div>}
        {startupIntroduction.customerFocus && <div><dt>{labels.customers}</dt><dd>{startupIntroduction.customerFocus}</dd></div>}
        {startupIntroduction.businessModel && <div><dt>{labels.businessModel}</dt><dd>{startupIntroduction.businessModel}</dd></div>}
        {startupIntroduction.stage && <div><dt>{labels.stage}</dt><dd>{startupIntroduction.stage}</dd></div>}
        {startupIntroduction.fundingStatus && <div><dt>{labels.fundingStatus}</dt><dd>{startupIntroduction.fundingStatus}</dd></div>}
      </dl>
      <ClaimRefs refs={arr(startupIntroduction.claimRefs).slice(0, 8)} claims={claims} sources={sources} />
    </section>
  )}

  {chapters.length > 0 && (
    <nav class="report-section toc" aria-label={labels.contents}>
      <h2>{labels.contents}</h2>
      <ol>{chapters.map((chapter: any) => <li><a href={`#chapter-${chapter.number}`}>{chapter.title}</a></li>)}</ol>
    </nav>
  )}

  {chapters.map((chapter: any) => (
    <article class="report-chapter" id={`chapter-${chapter.number}`}>
      <h2><span>{chapter.number}</span>{chapter.title}</h2>
      {arr(chapter.sections).map((section: any) => (
        <section class="chapter-section">
          <h3>{section.number} {section.title}</h3>
          {arr(section.blocks).map((block: any) => {
            const table = block.tableRef ? tables.get(block.tableRef) as any : null;
            const figure = block.figureRef ? figures.get(block.figureRef) as any : null;
            const blockHasInlineRefs = hasInlineClaimRefs(block?.body) || arr(block?.items).some((item) => hasInlineClaimRefs(item));
            return (
              <>
                {block.type === 'paragraph' && <p>{splitClaimRefsText(block.body).map((part) => part.ref ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} /> : part.text)} <ClaimRefs refs={blockHasInlineRefs ? [] : blockRefs(block)} claims={claims} sources={sources} /></p>}
                {block.type === 'list' && <><ul>{arr(block.items).map((item) => <li>{splitClaimRefsText(item).map((part) => part.ref ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} /> : part.text)}</li>)}</ul><ClaimRefs refs={blockHasInlineRefs ? [] : blockRefs(block)} claims={claims} sources={sources} /></>}
                {block.type === 'equation' && <div class="equation">{block.equation}</div>}
                {block.type === 'callout' && <aside class={blockClass(block.calloutType)}><h4>{block.title}</h4><p>{splitClaimRefsText(block.body).map((part) => part.ref ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} /> : part.text)}</p><ClaimRefs refs={blockHasInlineRefs ? [] : blockRefs(block)} claims={claims} sources={sources} /></aside>}
                {block.type === 'table' && table && <div class="table-frame"><table><caption>{table.title}</caption><thead><tr>{arr(table.columns).map((column) => <th>{column}</th>)}</tr></thead><tbody>{arr(table.rows).map((row: any[]) => <tr>{arr(row).map((cell) => <td>{splitClaimRefsText(cell).map((part) => part.ref ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} /> : part.text)}</td>)}</tr>)}</tbody></table>{table.notes && <p class="table-note">{splitClaimRefsText(table.notes).map((part) => part.ref ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} /> : part.text)}</p>}<ClaimRefs refs={blockRefs(table)} claims={claims} sources={sources} /></div>}
                {block.type === 'figure' && figure && <FigureRenderer figure={figure} claims={claims} sources={sources} />}
              </>
            );
          })}
        </section>
      ))}
    </article>
  ))}

  {(data.topStrengths.length > 0 || data.topRisks.length > 0 || data.unresolvedGaps.length > 0) && (
    <section class="report-section three-col">
      <article><h2>{labels.strengths}</h2>{arr(data.topStrengths).map((item) => <p>{splitClaimRefsText(item).map((part) => part.ref ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} /> : part.text)}</p>)}</article>
      <article><h2>{labels.risks}</h2>{arr(data.topRisks).map((item) => <p>{splitClaimRefsText(item).map((part) => part.ref ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} /> : part.text)}</p>)}</article>
      <article><h2>{labels.gaps}</h2>{arr(data.unresolvedGaps).map((item) => <p>{splitClaimRefsText(item).map((part) => part.ref ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} /> : part.text)}</p>)}</article>
    </section>
  )}

  {arr(doc?.appendices).map((appendix: any) => (
    <section class="report-section appendix">
      <h2>Appendix {appendix.id}: {appendix.title}</h2>
      {arr(appendix.blocks).map((block: any) => <p>{splitClaimRefsText(block.body ?? arr(block.items).join(' ')).map((part) => part.ref ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} /> : part.text)}</p>)}
    </section>
  ))}

  {doc?.disclaimer && <section class="report-section disclaimer"><h2>{labels.disclaimer}</h2><p>{doc.disclaimer}</p></section>}

  {(claims.length > 0 || sources.length > 0) && (
    <section class="report-section evidence-index">
      <h2>{labels.evidence}</h2>
      {claims.length > 0 && <div class="table-frame"><table><caption>Claims</caption><thead><tr><th>ID</th><th>Statement</th><th>Confidence</th><th>Sources</th></tr></thead><tbody>{claims.map((claim: any) => <tr id={`claim-${claim.id}`}><td><a class="evidence-id" href={`#claim-${claim.id}`}>{claim.id}</a></td><td>{claim.statement}</td><td>{labelValue(claim.confidence)}</td><td>{arr(claim.sourceRefs).map((sourceRef, index) => <><a href={`#source-${sourceRef}`}>{sourceRef}</a>{index < arr(claim.sourceRefs).length - 1 ? ', ' : ''}</>)}</td></tr>)}</tbody></table></div>}
      {sources.length > 0 && <div class="table-frame"><table><caption>Sources</caption><thead><tr><th>ID</th><th>Publisher</th><th>Title</th><th>Quote</th></tr></thead><tbody>{sources.map((source: any) => <tr id={`source-${source.id}`}><td><a class="evidence-id" href={`#source-${source.id}`}>{source.id}</a></td><td>{source.publisher}</td><td>{source.url ? <a href={source.url}>{source.title}</a> : source.title}</td><td>{source.keyQuote}</td></tr>)}</tbody></table></div>}
    </section>
  )}
</section>

<script type="application/json" id="claim-link-map" set:html={JSON.stringify(claimLinkMap)}></script>
<script type="module" is:inline>
  const claimLinkMapElement = document.getElementById('claim-link-map');
  const claimLinkMap = claimLinkMapElement ? JSON.parse(claimLinkMapElement.textContent || '{}') : {};
  const makeClaimRef = (ref) => {
    const link = claimLinkMap[ref] || { href: `#claim-${ref}`, title: ref };
    const span = document.createElement('span');
    span.className = 'claim-ref';
    span.append('[');
    const anchor = document.createElement('a');
    anchor.href = link.href;
    anchor.textContent = ref;
    anchor.title = link.title || ref;
    span.append(anchor, ']');
    return span;
  };
  const walker = document.createTreeWalker(document.querySelector('.report-shell'), NodeFilter.SHOW_TEXT, {
    acceptNode(node) {
      const parent = node.parentElement;
      if (!parent || parent.closest('script, style, pre, a, .claim-ref')) return NodeFilter.FILTER_REJECT;
      return /\[C\d{3}\]/.test(node.nodeValue || '') ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
    },
  });
  const rawClaimTextNodes = [];
  while (walker.nextNode()) rawClaimTextNodes.push(walker.currentNode);
  for (const node of rawClaimTextNodes) {
    const fragment = document.createDocumentFragment();
    const text = node.nodeValue || '';
    let lastIndex = 0;
    for (const match of text.matchAll(/\[(C\d{3})\]/g)) {
      if (match.index > lastIndex) fragment.append(text.slice(lastIndex, match.index));
      fragment.append(makeClaimRef(match[1]));
      lastIndex = match.index + match[0].length;
    }
    if (lastIndex < text.length) fragment.append(text.slice(lastIndex));
    node.parentNode?.replaceChild(fragment, node);
  }

  const reportShell = document.querySelector('.report-shell');
  const evidenceToggle = document.querySelector('.evidence-toggle');
  if (reportShell && evidenceToggle) {
    const showLabel = evidenceToggle.dataset.showLabel || 'Show refs';
    const hideLabel = evidenceToggle.dataset.hideLabel || 'Hide refs';
    const setRefsVisible = (visible) => {
      reportShell.classList.toggle('refs-visible', visible);
      evidenceToggle.setAttribute('aria-pressed', String(visible));
      evidenceToggle.textContent = visible ? hideLabel : showLabel;
    };
    evidenceToggle.addEventListener('click', () => setRefsVisible(!reportShell.classList.contains('refs-visible')));
    setRefsVisible(false);
  }

</script>

<style>
  .report-shell {
    --report-fs-kicker: clamp(0.82rem, 0.12vw + 0.78rem, 0.9rem);
    --report-fs-caption: clamp(0.88rem, 0.14vw + 0.82rem, 0.98rem);
    --report-fs-body: clamp(1.02rem, 0.18vw + 0.96rem, 1.12rem);
    --report-fs-table: clamp(0.94rem, 0.14vw + 0.88rem, 1.02rem);
    --report-fs-note: var(--report-fs-body);
    --report-fs-subhead: clamp(1.35rem, 0.6vw + 1.05rem, 1.7rem);
    --report-fs-section: clamp(1.75rem, 1.1vw + 1.15rem, 2.2rem);
    padding-block: var(--space-6) 0;
    overflow-x: clip;
    font-size: var(--report-fs-body);
  }
  .report-cover { display: grid; grid-template-columns: minmax(0, 1fr) minmax(260px, 340px); gap: var(--space-7); align-items: start; padding-block: 0 var(--space-6); }
  .report-cover h1 { margin: 0 0 var(--space-4); max-width: 28ch; font-family: var(--font-display); font-size: var(--fs-3xl); font-weight: 700; letter-spacing: var(--tracking-display-tight); line-height: var(--lh-display-hero); }
  .report-subtitle, .report-headline { width: 100%; color: var(--ink-page); font-family: var(--font-sans); line-height: 1.55; }
  .report-subtitle { font-size: var(--report-fs-body); color: var(--caption-gray); }
  .report-meta-line { display: flex; flex-wrap: wrap; column-gap: var(--space-4); row-gap: var(--space-2); margin-top: var(--space-4); font-family: var(--font-sans); font-size: var(--report-fs-caption); }
  .report-meta-line span { color: var(--caption-gray); }
  .evidence-toggle { appearance: none; border: var(--report-rule); background: transparent; color: var(--claret); cursor: pointer; font-family: var(--font-sans); font-variant-caps: all-small-caps; font-size: var(--report-fs-caption); font-weight: 800; letter-spacing: var(--tracking-eyebrow); line-height: 1.2; padding: 2px var(--space-2); }
  .evidence-toggle:hover, .evidence-toggle:focus-visible, .evidence-toggle[aria-pressed="true"] { border-color: var(--claret); background: color-mix(in srgb, var(--claret) 5%, var(--surface-paper)); outline: none; }
  .decision-card { align-self: start; border-top: 2px solid var(--claret); background: color-mix(in srgb, var(--surface-paper) 58%, transparent); padding: var(--space-4); }
  .decision-card dl { margin: 0; display: grid; gap: var(--space-3); }
  .decision-card div { display: grid; grid-template-columns: 1fr auto; gap: var(--space-3); }
  .decision-card dt { font-family: var(--font-sans); font-variant-caps: all-small-caps; font-size: var(--report-fs-kicker); font-weight: 700; letter-spacing: var(--tracking-eyebrow); color: var(--claret); }
  .decision-card dd { margin: 0; font-family: var(--font-display); font-size: var(--report-fs-body); font-weight: 700; color: var(--ink-page); text-align: right; }
  .report-section, .report-chapter { padding-block: var(--space-6); }
  .report-chapter { border-top: var(--report-rule); }
  .report-section h2, .report-chapter > h2 { margin: 0 0 var(--space-4); }
  .report-section h2 { font-family: var(--font-sans); font-variant-caps: all-small-caps; font-weight: 700; letter-spacing: var(--tracking-eyebrow); color: var(--claret); font-size: var(--report-fs-kicker); line-height: 1.2; }
  .report-chapter > h2 { display: grid; grid-template-columns: auto minmax(0, 1fr); gap: var(--space-3); font-family: var(--font-display); font-size: var(--report-fs-section); font-weight: 700; letter-spacing: var(--tracking-display-snug); line-height: var(--lh-display-block); }
  .report-chapter > h2 span { color: var(--claret); }
  .chapter-section { margin-top: var(--space-6); }
  .chapter-section h3 { margin-bottom: var(--space-3); font-size: var(--report-fs-subhead); font-weight: 700; letter-spacing: var(--tracking-display-snug); }
  .chapter-section p, .chapter-section li, .report-section p { width: 100%; max-width: none; font-size: var(--report-fs-body); line-height: 1.65; }
  .metric-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); border-top: 3px solid var(--claret); border-left: var(--report-rule); background: var(--surface-paper); }
  .metric-grid article { position: relative; display: grid; align-content: space-between; min-height: 10.5rem; border-right: var(--report-rule); border-bottom: var(--report-rule); background: var(--surface-paper); padding: var(--space-4); }
  .metric-grid article::before { content: ''; position: absolute; inset: 0 auto 0 0; width: 4px; background: color-mix(in srgb, var(--claret) 70%, var(--surface-paper)); }
  .metric-grid article:hover { background: color-mix(in srgb, var(--claret) 4%, var(--surface-paper)); }
  .metric-topline { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-3); margin-bottom: var(--space-4); padding-left: var(--space-2); }
  .metric-label { display: block; max-width: 18ch; font-family: var(--font-sans); font-variant-caps: all-small-caps; font-size: var(--report-fs-kicker); font-weight: 800; letter-spacing: var(--tracking-eyebrow); line-height: 1.2; color: var(--claret); }
  .metric-topline em { flex: 0 0 auto; font-family: var(--font-mono); font-size: var(--report-fs-caption); font-style: normal; font-weight: 600; color: color-mix(in srgb, var(--caption-gray) 74%, transparent); }
  .metric-grid strong { display: block; align-self: end; padding-left: var(--space-2); font-family: var(--font-display); font-size: clamp(1.55rem, 1.25vw + 1.05rem, 2.2rem); font-weight: 800; letter-spacing: -0.035em; line-height: 0.98; color: var(--ink-page); overflow-wrap: anywhere; }
  .metric-grid article > :global(.claim-ref) { align-self: end; margin-top: var(--space-3); padding-left: var(--space-2); }
  .intro-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-3); margin-top: var(--space-4); }
  .intro-grid div { background: color-mix(in srgb, var(--surface-paper) 42%, transparent); padding: var(--space-3); }
  .intro-grid dt { font-family: var(--font-sans); font-variant-caps: all-small-caps; font-size: var(--report-fs-kicker); font-weight: 700; letter-spacing: var(--tracking-eyebrow); color: var(--claret); }
  .intro-grid dd { margin: var(--space-1) 0 0; }
  .toc ol { columns: 2; }
  .toc a { color: var(--ink-page); text-decoration-color: var(--claret); }
  .report-callout { margin: var(--space-5) 0; border-left: 4px solid var(--claret); background: color-mix(in srgb, var(--claret) 5%, transparent); padding: var(--space-4); }
