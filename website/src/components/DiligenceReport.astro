  .person-avatar { display: grid; place-items: center; background: linear-gradient(135deg, var(--claret), var(--accent)); color: white; font-family: var(--font-sans); font-weight: 800; letter-spacing: .04em; }
  .person-name { font-family: var(--font-serif); font-size: var(--fs-base); font-weight: 700; color: var(--ink-page); }
