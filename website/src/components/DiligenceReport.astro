  .person-status.former { color: var(--caption-gray); }
  .risk-map { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-4); margin-bottom: var(--space-5); }
  .risk-chip { border-left: 5px solid var(--gold); padding: var(--space-4); background: var(--surface-paper); box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--hairline) 65%, transparent); }
  .risk-chip.severity-3, .risk-chip.severity-4 { border-left-color: var(--claret); }
