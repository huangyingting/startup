  .report-hero h1 { max-width: 34ch; }
  .hero-summary-card { border: var(--report-rule); background: var(--surface-paper); padding: var(--space-4); margin-top: var(--space-2); }
  .hero-summary-card dl { display: grid; gap: var(--space-3); margin: var(--space-3) 0 0; }
  .hero-summary-card div { display: grid; grid-template-columns: minmax(110px, 1fr) auto; gap: var(--space-3); align-items: baseline; padding-bottom: var(--space-2); border-bottom: var(--report-rule); }
  .hero-summary-card div:last-child { border-bottom: 0; padding-bottom: 0; }
  .hero-summary-card dt { font-family: var(--font-sans); font-size: var(--fs-xs); font-weight: 800; letter-spacing: var(--tracking-eyebrow); color: var(--claret); text-transform: uppercase; }
  .hero-summary-card dd { margin: 0; font-family: var(--font-display); font-size: var(--fs-md); font-weight: 800; line-height: 1.05; color: var(--ink-page); text-align: right; }
  .sr-section > h2,
  .executive-dashboard > div > h2 {
    display: grid;
