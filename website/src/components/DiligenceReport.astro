    font-size: var(--fs-xl);
  }
  .report-nav { position: sticky; top: 0; z-index: 30; display: flex; flex-wrap: wrap; gap: var(--space-3); margin-block: 0 var(--space-4); border-bottom: var(--report-rule); padding-block: var(--space-3) var(--space-2); background: color-mix(in srgb, var(--paper) 95%, white); backdrop-filter: blur(10px); }
  .report-nav a { display: inline-flex; align-items: center; padding: 0 0 5px; border-bottom: 2px solid transparent; font-family: var(--font-sans); font-size: var(--fs-sm); font-weight: 800; line-height: 1.15; letter-spacing: .012em; text-transform: uppercase; text-decoration: none; color: var(--caption-gray); transition: border-color 140ms ease, color 140ms ease; }
  .report-nav a:hover,
  .report-nav a:focus-visible { color: var(--claret); border-bottom-color: var(--claret); outline: none; }
