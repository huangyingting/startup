    width: fit-content;
    max-width: 100%;
    margin: 0 0 var(--space-3);
    font-family: var(--font-display);
    font-variant-caps: normal;
    font-size: clamp(1.55rem, 2.25vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.025em;
