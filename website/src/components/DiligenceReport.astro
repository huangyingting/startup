  .focus-card p { font-size: var(--fs-sm); color: var(--caption-gray); }
  .narrative-grid { display: grid; grid-template-columns: 1.2fr 1fr 1fr; gap: var(--space-6); margin-top: var(--space-6); align-items: start; }
  .score-bars, .evidence-visual { display: grid; gap: var(--space-3); }
  .score-row, .source-row { display: grid; grid-template-columns: minmax(120px, 1fr) 1.3fr 44px; gap: var(--space-3); align-items: center; font-family: var(--font-sans); font-size: var(--fs-sm); }
  .score-track, .source-track { height: 10px; border-radius: 999px; background: color-mix(in srgb, var(--hairline) 70%, transparent); overflow: hidden; }
  .score-track i, .source-track i { display: block; height: 100%; border-radius: inherit; background: var(--claret); }
  .memo-grid, .two-col, .milestone-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-6); }
  .milestone-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .report-panel { border-top: var(--report-rule); padding-block: var(--space-4) var(--space-5); }
