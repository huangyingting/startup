---
// Renders a single block from a chapter section or appendix.
// Block shapes: paragraph | list | equation | callout | table | figure.
import ClaimRefs from './ClaimRefs.astro';
import DataTable from './DataTable.astro';
import FigureRenderer from './FigureRenderer.astro';
import { hasInlineClaimRefs, splitClaimRefsText } from '../lib/claim-refs.mjs';
import { asArray, claimRefs } from '../lib/report-types';
import type { Claim, ReportBlock as ReportBlockData, ReportFigure, ReportTable, Source } from '../lib/report-types';

interface Props {
  block: ReportBlockData;
  tables: Map<string, ReportTable>;
  figures: Map<string, ReportFigure>;
  claims: Claim[];
  sources: Source[];
}

const { block, tables, figures, claims, sources } = Astro.props;

function blockClass(type: string | null | undefined): string {
  return `report-callout callout-${String(type ?? 'insight').replace(/[^a-z0-9-]/gi, '-')}`;
}

function tableColumns(value: ReportTable): unknown[] {
  return asArray(value.columns);
}

function tableRows(value: ReportTable): unknown[][] {
  return asArray<unknown[]>(value.rows);
}

function rowCells(row: unknown[]): unknown[] {
  return asArray(row);
}

const refsForFooter = (() => {
  const inline = hasInlineClaimRefs(block?.body) || asArray(block?.items).some((item) => hasInlineClaimRefs(item));
  return inline ? [] : claimRefs(block);
})();

const table = block.type === 'table' && block.tableRef ? tables.get(block.tableRef) : null;
const figure = block.type === 'figure' && block.figureRef ? figures.get(block.figureRef) : null;
---
{block.type === 'paragraph' && (
  <p>
    {splitClaimRefsText(block.body).map((part) => part.ref
      ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} />
      : part.text)}
    <ClaimRefs refs={refsForFooter} claims={claims} sources={sources} />
  </p>
)}

{block.type === 'list' && (
  <>
    <ul>
      {asArray(block.items).map((item) => (
        <li>
          {splitClaimRefsText(item).map((part) => part.ref
            ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} />
            : part.text)}
        </li>
      ))}
    </ul>
    <ClaimRefs refs={refsForFooter} claims={claims} sources={sources} />
  </>
)}

{block.type === 'equation' && <div class="equation">{block.equation}</div>}

{block.type === 'callout' && (
  <aside class={blockClass(block.calloutType)}>
    <span class="callout-eyebrow">{String(block.calloutType ?? 'insight')}</span>
    <h4>{block.title}</h4>
    <p>
      {splitClaimRefsText(block.body).map((part) => part.ref
        ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} />
        : part.text)}
    </p>
    <ClaimRefs refs={refsForFooter} claims={claims} sources={sources} />
  </aside>
)}

{block.type === 'table' && table && (
  <DataTable title={table.title} columns={tableColumns(table)}>
    {tableRows(table).map((row) => (
      <tr>
        {rowCells(row).map((cell) => (
          <td>
            {splitClaimRefsText(cell).map((part) => part.ref
              ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} />
              : part.text)}
          </td>
        ))}
      </tr>
    ))}
    {table.notes && (
      <Fragment slot="notes">
        {splitClaimRefsText(table.notes).map((part) => part.ref
          ? <ClaimRefs refs={[part.ref]} claims={claims} sources={sources} />
          : part.text)}
      </Fragment>
    )}
    <ClaimRefs slot="footer" refs={claimRefs(table)} claims={claims} sources={sources} />
  </DataTable>
)}

{block.type === 'figure' && figure && (
  <FigureRenderer figure={figure} claims={claims} sources={sources} />
)}
