---
interface Dimension { score: number; rationale: string; claimRefs?: string[]; }
interface Props { dimensions: Record<string, Dimension>; overall: number; }
const { dimensions, overall } = Astro.props;
---
<section class="sr-card">
  <div class="sr-meta sr-kicker"><span>Overall</span><span class="sr-score">{overall.toFixed(1)}</span></div>
  <div class="rating-list">
    {Object.entries(dimensions).map(([name, value]) => (
      <div class="rating-row">
        <div><strong>{name.replace(/([A-Z])/g, ' $1')}</strong><p>{value.rationale}</p></div>
        <meter min="0" max="5" value={value.score}>{value.score}</meter>
      </div>
    ))}
  </div>
</section>
<style>
  .rating-list { display: grid; gap: 14px; margin-top: 18px; }
  .rating-row { display: grid; grid-template-columns: 1fr 120px; gap: 16px; align-items: center; }
  .rating-row p { margin: 4px 0 0; color: var(--muted); font-size: .92rem; }
  .rating-row strong { text-transform: uppercase; letter-spacing: .08em; color: var(--accent); }
  meter { width: 100%; height: 12px; accent-color: var(--accent); }
  @media (max-width: 720px) { .rating-row { grid-template-columns: 1fr; } }
</style>
