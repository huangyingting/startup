---
import ClaimRefs from './ClaimRefs.astro';
import { RENDERED_FIGURE_TYPES } from '../lib/figures.mjs';

interface Props {
  figure: any;
  claims?: any[];
  sources?: any[];
}

const { figure, claims = [], sources = [] } = Astro.props;
const type = figure?.type ?? 'flow';
const layout = figure?.layout ?? 'standard';
const data = figure?.data ?? {};
const chartTypes = new Set(RENDERED_FIGURE_TYPES);
const usesD3Chart = chartTypes.has(type);
const chartId = `chart-${String(figure?.id ?? 'figure').replace(/[^a-z0-9_-]/gi, '-')}-${Math.random().toString(36).slice(2, 9)}`;
const arr = <T = any>(value: T[] | undefined | null): T[] => Array.isArray(value) ? value : [];
const blockRefs = (block: any) => arr<string>(block?.claimRefs).slice(0, 6);
const chartPayload = usesD3Chart ? { id: chartId, type, title: figure?.title, data } : null;
---

<figure class:list={['native-figure', `figure-${type}`, `layout-${layout}`]}>
  <figcaption>{figure.id}: {figure.title}</figcaption>

  {figure.summary && <p class="figure-summary">{figure.summary}</p>}

  {usesD3Chart && <div id={chartId} class:list={['d3-figure', `chart-${type}`]} data-chart-type={type}></div>}

  {type === 'other' && (
    <div class="figure-fallback" role="note">
      <strong>Generic figure</strong>
      <p>Fallback renderer for generic figures.</p>
    </div>
  )}

  {figure.approximationNotes && <p class="figure-note">{figure.approximationNotes}</p>}
  <ClaimRefs refs={blockRefs(figure)} claims={claims} sources={sources} />
  {chartPayload && <script type="application/json" class="figure-chart-data" set:html={JSON.stringify(chartPayload)}></script>}
</figure>

<script>
  import * as d3 from 'd3';

  const palette = {
    claret: '#990f3d',
    ink: '#33302e',
    muted: '#6b625c',
    border: '#d8ccc2',
    paper: '#fff7ef',
    positive: '#0f766e',
    risk: '#b42318',
    opportunity: '#b8860b',
    neutral: '#990f3d',
  };

  const arr = (value) => Array.isArray(value) ? value : [];
  const colorForTone = (tone) => {
    if (tone === 'positive' || tone === 'low') return palette.positive;
    if (tone === 'risk' || tone === 'critical' || tone === 'high') return palette.risk;
    if (tone === 'opportunity') return palette.opportunity;
    return palette.neutral;
  };
  const riskValue = (tone) => {
    if (tone === 'high' || tone === 'critical' || tone === 'risk') return 3;
    if (tone === 'medium' || tone === 'neutral') return 2;
    return 1;
  };
  const labelText = (text, max = 24) => String(text ?? '').length > max ? `${String(text).slice(0, max - 1)}…` : String(text ?? '');
  const numberValue = (value) => Number(value) || 0;
  const valueLabel = (item) => item?.displayValue ?? item?.value ?? '';
  const fullValueLabel = (item) => item?.displayValue ?? item?.value ?? item?.score ?? item?.label ?? '';

  const chartFont = {
    family: 'var(--font-sans, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif)',
    size: {
      micro: 8,
      tiny: 9.5,
      caption: 10.5,
      small: 12,
      axis: 13,
      label: 14,
      title: 16,
      value: 18,
      large: 20,
      arrow: 24,
      metric: 26,
    },
    weight: {
      regular: 650,
      body: 700,
      medium: 750,
      strong: 800,
      label: 900,
      emphasis: 950,
    },
    tracking: {
      subtle: '0.04em',
      caps: '0.08em',
    },
    lineHeight: {
      compact: 12,
      tight: 13,
      small: 15,
      label: 16,
      title: 18,
    },
    cssVar: {
      kicker: 'var(--chart-fs-kicker)',
      caption: 'var(--chart-fs-caption)',
      body: 'var(--chart-fs-body)',
      note: 'var(--chart-fs-note)',
    },
  };
  chartFont.axis = chartFont.size.axis;
  chartFont.label = chartFont.size.label;
  chartFont.small = chartFont.size.small;
  const fontSize = (name) => chartFont.size[name] ?? name;
  const fontWeight = (name) => chartFont.weight[name] ?? name;
  const tooltip = (() => {
    const node = d3.select('body').selectAll('.d3-chart-tooltip').data([null]).join('div').attr('class', 'd3-chart-tooltip').attr('role', 'tooltip');
    const move = (event) => {
      const gap = window.innerWidth < 520 ? 10 : 14;
      const pad = window.innerWidth < 520 ? 10 : 14;
      const tooltipNode = node.node();
      const box = tooltipNode?.getBoundingClientRect?.() ?? { width: 0, height: 0 };
      const spaceRight = window.innerWidth - event.clientX;
      const spaceBottom = window.innerHeight - event.clientY;
      const placeLeft = spaceRight < box.width + gap + pad && event.clientX > box.width + gap + pad;
      const placeTop = spaceBottom < box.height + gap + pad && event.clientY > box.height + gap + pad;
      const rawLeft = placeLeft ? event.clientX - box.width - gap : event.clientX + gap;
      const rawTop = placeTop ? event.clientY - box.height - gap : event.clientY + gap;
      const left = Math.max(pad, Math.min(window.innerWidth - box.width - pad, rawLeft));
      const top = Math.max(pad, Math.min(window.innerHeight - box.height - pad, rawTop));
      const pointerX = Math.max(18, Math.min(box.width - 18, event.clientX - left));
      const tooltipFont = window.innerWidth < 520 ? chartFont.size.small : window.innerWidth < 760 ? chartFont.axis : 13.8;
      node
        .attr('data-placement-x', placeLeft ? 'left' : 'right')
        .attr('data-placement-y', placeTop ? 'top' : 'bottom')
        .style('left', `${left}px`)
        .style('top', `${top}px`)
        .style('--tooltip-pointer-x', `${pointerX}px`)
        .style('--tooltip-font', `${tooltipFont}px`);
    };
    return {
      show(event, html) {
        node.html(html).classed('is-visible', true);
        move(event);
      },
      move,
      hide() {
        node.classed('is-visible', false);
      },
    };
  })();
  const escapeHtml = (value) => String(value ?? '').replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char]));
  const tooltipHtml = (title, lines = []) => `<strong>${escapeHtml(title)}</strong>${lines.filter(Boolean).map((line) => `<span>${escapeHtml(line)}</span>`).join('')}`;
  const shouldShowTooltip = () => true;
  document.addEventListener('pointerdown', (event) => {
    if (event.target?.closest?.('.d3-figure')) return;
    tooltip.hide();
  });
  const withTooltip = (selection, htmlForDatum) => selection
    .style('cursor', 'default')
    .on('pointerenter', function(event, datum) {
      d3.select(this).classed('is-hovered', true);
      if (!shouldShowTooltip()) return;
      const html = typeof htmlForDatum === 'function' ? htmlForDatum(datum) : htmlForDatum;
      tooltip.show(event, html);
    })
    .on('pointerdown', function(event, datum) {
      event.stopPropagation();
      d3.select(this).classed('is-hovered', true);
      const html = typeof htmlForDatum === 'function' ? htmlForDatum(datum) : htmlForDatum;
      tooltip.show(event, html);
    })
    .on('pointermove', (event) => {
      if (shouldShowTooltip()) tooltip.move(event);
    })
    .on('pointerleave', function() {
      d3.select(this).classed('is-hovered', false);
      tooltip.hide();
    });
  const wrapWords = (text, maxChars = 18, maxLines = 2) => {
    const words = String(text ?? '').split(/\s+/).filter(Boolean);
    if (!words.length) return [''];
    const lines = [];
    let line = '';
    words.forEach((word) => {
      const next = line ? `${line} ${word}` : word;
      if (next.length > maxChars && line) {
        lines.push(line);
        line = word;
      } else {
        line = next;
      }
    });
    if (line) lines.push(line);
    const clipped = lines.slice(0, maxLines);
    if (lines.length > maxLines) clipped[clipped.length - 1] = labelText(clipped[clipped.length - 1], Math.max(4, maxChars - 1));
    return clipped;
  };
  const renderWrappedText = (selection, text, { maxChars = 18, maxLines = 2, lineHeight = chartFont.lineHeight.small, dy = 0 } = {}) => {
    const x = selection.attr('x') ?? 0;
    selection.text(null);
    const lines = wrapWords(text, maxChars, maxLines);
    const offset = dy - ((lines.length - 1) * lineHeight) / 2;
    lines.forEach((line, index) => {
      selection.append('tspan').attr('x', x).attr('dy', index === 0 ? offset : lineHeight).text(line);
    });
  };
  const renderLineBlock = (selection, lines, { x = 0, y = 0, lineHeight = chartFont.lineHeight.small } = {}) => {
    selection.text(null).attr('x', x).attr('y', y);
    lines.forEach((line, index) => {
      selection.append('tspan').attr('x', x).attr('dy', index === 0 ? 0 : lineHeight).text(line);
    });
  };
  const svgBase = (element, height = 340) => {
    const containerWidth = Math.floor(element.getBoundingClientRect().width || 760);
    const minInternalWidth = containerWidth < 420 ? 420 : 520;
    const width = Math.max(minInternalWidth, containerWidth);
    const displayHeight = Math.ceil(height * Math.min(1, containerWidth / width));
    d3.select(element).selectAll('*').remove();
    const svg = d3.select(element)
      .append('svg')
      .attr('viewBox', `0 0 ${width} ${height}`)
      .attr('role', 'img')
      .attr('width', '100%')
      .attr('height', displayHeight)
      .style('font-family', chartFont.family)
      .style('display', 'block');
    return { svg, width, height };
  };
  const addTitle = (selection, text) => selection.attr('aria-label', String(text ?? ''));
  const axisBottom = (g, scale, y, ticks = 4) => g.append('g')
    .attr('transform', `translate(0,${y})`)
    .call(d3.axisBottom(scale).ticks(ticks).tickSizeOuter(0))
    .call((axis) => axis.select('.domain').attr('stroke', palette.border))
    .call((axis) => axis.selectAll('line').attr('stroke', palette.border))
    .call((axis) => axis.selectAll('text').attr('fill', palette.muted).attr('font-size', chartFont.axis));
  const axisLeft = (g, scale, x) => g.append('g')
    .attr('transform', `translate(${x},0)`)
    .call(d3.axisLeft(scale).tickSizeOuter(0))
    .call((axis) => axis.select('.domain').remove())
    .call((axis) => axis.selectAll('line').remove())
    .call((axis) => axis.selectAll('text').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('body')).each(function(d) {
      const text = d3.select(this);
      renderWrappedText(text, d, { maxChars: 19, maxLines: 2, lineHeight: chartFont.lineHeight.tight });
    }));

  const renderGraph = (element, payload) => {
    const containerWidth = element.getBoundingClientRect().width || 760;
    if (containerWidth < 420) {
      const nodes = arr(payload.data.nodes);
      const sequentialEdges = nodes.slice(0, -1).map((node, index) => {
        const next = nodes[index + 1];
        return {
          from: node.id ?? node.label,
          to: next.id ?? next.label,
          label: '',
        };
      });
      return renderFlow(element, { ...payload, data: { nodes, edges: sequentialEdges } });
    }
    const nodes = arr(payload.data.nodes);
    const edges = arr(payload.data.edges);
    const columns = Math.min(Math.max(nodes.length, 1), payload.type === 'decision-map' ? 3 : 2);
    const rows = Math.max(1, Math.ceil(nodes.length / columns));
    const { svg, width } = svgBase(element, Math.max(360, rows * 145 + 110));
    const margin = { top: 32, right: 36, bottom: 54, left: 36 };
    const innerW = width - margin.left - margin.right;
    const colW = innerW / columns;
    const rowH = 140;
    const defs = svg.append('defs');
    defs.append('marker').attr('id', `${payload.id}-arrow`).attr('viewBox', '0 -5 10 10').attr('refX', 9).attr('refY', 0).attr('markerWidth', 7).attr('markerHeight', 7).attr('orient', 'auto')
      .append('path').attr('d', 'M0,-5L10,0L0,5').attr('fill', palette.claret);
    const positioned = nodes.map((node, index) => {
      const col = index % columns;
      const row = Math.floor(index / columns);
      return { ...node, x: margin.left + colW * col + colW / 2, y: margin.top + rowH * row + 40 };
    });
    const cardW = Math.min(164, Math.max(104, colW - 14));
    const halfCardW = cardW / 2;
    const byId = new Map(positioned.map((node) => [node.id, node]));
    svg.append('g').selectAll('path').data(edges).join('path')
      .attr('d', (edge) => {
        const s = byId.get(edge.from);
        const t = byId.get(edge.to);
        if (!s || !t) return '';
        const midX = (s.x + t.x) / 2;
        return `M${s.x},${s.y + 28} C${midX},${s.y + 56} ${midX},${t.y - 56} ${t.x},${t.y - 31}`;
      })
      .attr('fill', 'none').attr('stroke', palette.claret).attr('stroke-width', 1.7).attr('opacity', 0.72).attr('marker-end', `url(#${payload.id}-arrow)`);
    const card = svg.append('g').selectAll('g').data(positioned).join('g').attr('transform', (node) => `translate(${node.x},${node.y})`);
    card.append('rect').attr('x', -halfCardW).attr('y', -31).attr('width', cardW).attr('height', 62).attr('rx', 4).attr('fill', '#fff7ef').attr('stroke', (node) => colorForTone(node.tone)).attr('stroke-width', 2);
    card.append('text').attr('text-anchor', 'middle').attr('y', -4).attr('fill', palette.ink).attr('font-size', chartFont.label).attr('font-weight', fontWeight('strong')).each(function(node) {
      renderWrappedText(d3.select(this), node.label, { maxChars: Math.max(11, Math.floor(cardW / 8.5)), maxLines: 2, lineHeight: chartFont.lineHeight.label, dy: -3 });
    });
    card.append('text').attr('text-anchor', 'middle').attr('y', 20).attr('fill', palette.muted).attr('font-size', chartFont.small).text((node) => labelText(node.detail, Math.max(16, Math.floor(cardW / 6.2))));
    card.each(function(node) { addTitle(d3.select(this), `${node.label}${node.detail ? ` — ${node.detail}` : ''}`); });
  };

  const renderDecisionMap = (element, payload) => {
    const nodes = arr(payload.data.nodes).map((node, index) => ({ ...node, _key: node.id ?? node.label ?? String(index + 1), _index: index }));
    const edges = arr(payload.data.edges).map((edge) => ({ ...edge, from: edge.from ?? edge.source, to: edge.to ?? edge.target }));
    if (!nodes.length) return;
    const outgoing = d3.group(edges, (edge) => edge.from);
    const incomingIds = new Set(edges.map((edge) => edge.to));
    const root = nodes.find((node) => !incomingIds.has(node._key) && arr(outgoing.get(node._key)).length) ?? nodes[0];
    const byKey = new Map(nodes.map((node) => [node._key, node]));
    const depth = new Map([[root._key, 0]]);
    const queue = [root];
    while (queue.length) {
      const current = queue.shift();
      arr(outgoing.get(current._key)).forEach((edge) => {
        const target = byKey.get(edge.to);
        if (!target || depth.has(target._key)) return;
        depth.set(target._key, (depth.get(current._key) ?? 0) + 1);
        queue.push(target);
      });
    }
    nodes.forEach((node) => {
      if (!depth.has(node._key)) depth.set(node._key, Math.min(2, node._index));
    });
    const maxDepth = Math.max(...depth.values(), 0);
    const levels = Array.from({ length: maxDepth + 1 }, () => []);
    nodes.forEach((node) => levels[depth.get(node._key) ?? 0].push(node));
    const containerWidth = element.getBoundingClientRect().width || 760;
    const compact = containerWidth < 640;
    const maxRows = Math.max(...levels.map((level) => level.length), 1);
    const compactHeight = 74 + levels.reduce((total, level, levelIndex) => {
      const rows = Math.ceil(level.length / Math.min(2, Math.max(level.length, 1)));
      return total + 28 + rows * (levelIndex === 0 ? 104 : 76) + Math.max(0, rows - 1) * 18 + (levelIndex === 0 ? 76 : 44);
    }, 0);
    const { svg, width, height } = svgBase(element, compact ? Math.max(520, compactHeight) : Math.max(330, 98 + maxRows * 106));
    const margin = compact ? { top: 36, right: 24, bottom: 34, left: 24 } : { top: 42, right: 34, bottom: 36, left: 34 };
    const innerW = width - margin.left - margin.right;
    const innerH = height - margin.top - margin.bottom;
    const levelW = innerW / Math.max(maxDepth + 1, 1);
    const compactColW = (innerW - 18) / 2;
    const cardW = compact ? Math.min(178, Math.max(142, compactColW - 12)) : Math.min(170, Math.max(126, levelW - 30));
    const cardH = compact ? 76 : 72;
    const rootW = compact ? Math.min(172, Math.max(138, innerW * 0.48)) : Math.min(176, Math.max(132, levelW - 24));
    const rootH = compact ? 104 : 112;
    const positioned = [];
    const headerPositions = [];
    if (compact) {
      let y = margin.top;
      levels.forEach((level, levelIndex) => {
        const columns = Math.min(2, Math.max(level.length, 1));
        const rows = Math.ceil(level.length / columns);
        const nodeH = levelIndex === 0 ? rootH : cardH;
        const sectionW = columns * cardW + Math.max(0, columns - 1) * 18;
        headerPositions.push({ x: width / 2, y: y + 2 });
        y += 32;
        level.forEach((node, index) => {
          const col = index % columns;
          const row = Math.floor(index / columns);
          positioned.push({ ...node, _level: levelIndex, x: width / 2 - sectionW / 2 + cardW / 2 + col * (cardW + 18), y: y + nodeH / 2 + row * (nodeH + 18) });
        });
        y += rows * nodeH + Math.max(0, rows - 1) * 18 + (levelIndex === 0 ? 76 : 44);
      });
    } else {
      levels.forEach((level, levelIndex) => {
        const gap = innerH / Math.max(level.length, 1);
        headerPositions.push({ x: margin.left + levelW * levelIndex + levelW / 2, y: 24 });
        level.forEach((node, rowIndex) => {
          positioned.push({ ...node, _level: levelIndex, x: margin.left + levelW * levelIndex + levelW / 2, y: margin.top + gap * rowIndex + gap / 2 });
        });
      });
    }
    const positionByKey = new Map(positioned.map((node) => [node._key, node]));
    const defs = svg.append('defs');
    defs.append('marker').attr('id', `${payload.id}-decision-arrow`).attr('viewBox', '0 -5 10 10').attr('refX', 8.2).attr('refY', 0).attr('markerWidth', 5.8).attr('markerHeight', 5.8).attr('orient', 'auto')
      .append('path').attr('d', 'M0,-4L9,0L0,4').attr('fill', palette.claret);
    const nodeShadow = defs.append('filter').attr('id', `${payload.id}-decision-node-shadow`).attr('x', '-18%').attr('y', '-24%').attr('width', '136%').attr('height', '156%');
    nodeShadow.append('feDropShadow').attr('dx', 0).attr('dy', 5).attr('stdDeviation', 5).attr('flood-color', 'rgba(51,48,46,0.16)');
    const rootShadow = defs.append('filter').attr('id', `${payload.id}-decision-root-shadow`).attr('x', '-18%').attr('y', '-20%').attr('width', '136%').attr('height', '148%');
    rootShadow.append('feDropShadow').attr('dx', 0).attr('dy', 4).attr('stdDeviation', 4).attr('flood-color', 'rgba(15,118,110,0.16)');
    const headers = ['Decision', 'Options', 'Outcomes'];
    svg.append('g').selectAll('text').data(levels).join('text')
      .attr('x', (_level, index) => headerPositions[index]?.x ?? width / 2)
      .attr('y', (_level, index) => headerPositions[index]?.y ?? 24)
      .attr('text-anchor', 'middle')
      .attr('fill', palette.claret)
      .attr('font-size', chartFont.small)
      .attr('font-weight', fontWeight('emphasis'))
      .attr('letter-spacing', chartFont.tracking.caps)
      .text((_level, index) => headers[index] ?? `Step ${index + 1}`);
    const edgeLayer = svg.append('g');
    const routedEdges = edges.map((edge) => ({ ...edge, source: positionByKey.get(edge.from), target: positionByKey.get(edge.to) })).filter((edge) => edge.source && edge.target);
    const edgeEndpoints = (edge) => {
      if (compact) {
        const sourceH = edge.source._key === root._key ? rootH / 2 : cardH / 2;
        const targetH = edge.target._key === root._key ? rootH / 2 : cardH / 2;
        const sx = edge.source.x;
        const tx = edge.target.x;
        const sy = edge.source.y + sourceH + 10;
        const ty = edge.target.y - targetH - 12;
        return { sx, tx, midX: (sx + tx) / 2, midY: (sy + ty) / 2, sy, ty };
      }
      const sourceW = edge.source._key === root._key ? rootW / 2 : cardW / 2;
      const targetW = edge.target._key === root._key ? rootW / 2 : cardW / 2;
      const sx = edge.source.x + sourceW + 10;
      const tx = edge.target.x - targetW - 12;
      const midX = (sx + tx) / 2;
      return { sx, tx, midX, sy: edge.source.y, ty: edge.target.y };
    };
    const edgePath = (edge) => {
      const { sx, tx, midX, midY, sy, ty } = edgeEndpoints(edge);
      if (compact) return `M${sx},${sy} C${sx},${midY} ${tx},${midY} ${tx},${ty}`;
      if (edge.source._key === root._key && edge.target._level === 1) {
        const busX = Math.min(tx - 58, Math.max(sx + 54, midX - 18));
        return `M${sx},${sy} H${busX} V${ty} H${tx}`;
      }
      return `M${sx},${sy} C${midX},${sy} ${midX},${ty} ${tx},${ty}`;
    };
    edgeLayer.selectAll('path.visible-edge').data(routedEdges).join('path')
      .attr('class', 'visible-edge')
      .attr('d', edgePath)
      .attr('fill', 'none')
      .attr('stroke', palette.claret)
      .attr('stroke-width', 1.7)
      .attr('opacity', 0.68)
      .attr('marker-end', `url(#${payload.id}-decision-arrow)`);
    const hitEdges = edgeLayer.selectAll('path.edge-hit').data(routedEdges).join('path')
      .attr('class', 'edge-hit')
      .attr('d', edgePath)
      .attr('fill', 'none')
      .attr('stroke', 'transparent')
      .attr('stroke-width', 16);
    hitEdges.each(function(edge) { addTitle(d3.select(this), `${edge.source.label} → ${edge.target.label}${edge.label ? ` — ${edge.label}` : ''}`); });
    withTooltip(hitEdges, (edge) => tooltipHtml(`${edge.source.label} → ${edge.target.label}`, [edge.label ? `Condition: ${edge.label}` : null, edge.target.detail]));
    const nodeLayer = svg.append('g');
    const rootNode = positioned.find((node) => node._key === root._key) ?? positioned[0];
    const rootGroup = nodeLayer.append('g').datum(rootNode).attr('transform', (node) => `translate(${node.x},${node.y})`);
    rootGroup.append('rect')
      .attr('x', -rootW / 2)
      .attr('y', -rootH / 2)
      .attr('width', rootW)
      .attr('height', rootH)
      .attr('rx', 24)
      .attr('fill', '#fffaf5')
      .attr('stroke', (node) => colorForTone(node.tone))
      .attr('stroke-width', 1.8)
      .attr('stroke-opacity', 0.86);
    rootGroup.append('rect')
      .attr('x', -rootW / 2 + 14)
      .attr('y', -rootH / 2 + 14)
      .attr('width', rootW - 28)
      .attr('height', rootH - 28)
      .attr('rx', 18)
      .attr('fill', 'rgba(15, 118, 110, 0.055)')
      .attr('stroke', 'none');
    const rootGlyph = rootGroup.append('g').attr('transform', 'translate(0,-13)');
    rootGlyph.append('circle').attr('cx', 0).attr('cy', -5).attr('r', 3.5).attr('fill', palette.claret).attr('opacity', 0.9);
