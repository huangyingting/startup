          .attr('width', pillW)
          .attr('height', compact ? 20 : 22)
          .attr('rx', compact ? 10 : 11)
          .attr('fill', isOutput ? 'rgba(153,15,61,0.08)' : 'rgba(255,250,245,0.78)')
          .attr('stroke', isOutput ? 'rgba(153,15,61,0.22)' : 'rgba(212,196,184,0.72)');
        pillGroup.append('text')
          .attr('x', pillW / 2)
          .attr('y', compact ? 14 : 15)
          .attr('text-anchor', 'middle')
          .attr('fill', isOutput ? palette.claret : palette.ink)
          .attr('font-size', pillSize)
          .attr('font-weight', fontWeight('strong'))
          .text(text);
        xCursor += pillW + 8;
      });
    });
    groups.each(function(d) {
      const modules = stackListText(d.modules);
      const outputs = stackListText(d.outputs);
      addTitle(d3.select(this), `${d.label}${d.detail ? ` — ${d.detail}` : ''}${modules ? `; modules: ${modules}` : ''}${outputs ? `; outputs: ${outputs}` : ''}`);
    });
    withTooltip(groups, (d) => tooltipHtml(d.label, [d.detail, stackListText(d.modules) ? `Modules: ${stackListText(d.modules)}` : '', stackListText(d.outputs) ? `Outputs: ${stackListText(d.outputs)}` : '']));
  };

  const renderPyramid = (element, payload) => {
    const items = normalizedItems(payload.data);
    // Probe container width up front so we can compute per-layer text wrapping
    // before allocating the SVG canvas. We need final card heights to set
    // svgBase height correctly.
    const containerWidth = Math.floor(element.getBoundingClientRect().width || 760);
    const internalWidth = Math.max(containerWidth < 420 ? 420 : 520, containerWidth);
    const margin = { top: 28, right: 34, bottom: 34, left: 34 };
    const maxW = internalWidth - margin.left - margin.right;
    const padX = 22;
    const labelLineH = 22;
    const detailLineH = 16;
    const padTop = 12;
    const padBottom = 12;
    const gapBetweenLabelDetail = 8;
    const gapBetweenLayers = 10;
    const labelFont = chartFont.size.large;
    const detailFont = chartFont.small;
    // Estimate characters that fit in a layer of width `w` for given font
    // size; `0.55em` is a conservative average glyph width.
    const charsPerLine = (w, fontSize) => Math.max(8, Math.floor((w - padX * 2) / (fontSize * 0.55)));
    const wrap = (text, maxChars) => wrapWords(text, maxChars, 99);
    const layout = items.map((item, index) => {
      const w = maxW * (1 - index * 0.1);
      const labelLines = wrap(item.label, charsPerLine(w, labelFont));
      const detailLines = item.detail ? wrap(item.detail, charsPerLine(w, detailFont)) : [];
      const cardH = Math.max(
        66,
        padTop + labelLines.length * labelLineH + (detailLines.length ? gapBetweenLabelDetail + detailLines.length * detailLineH : 0) + padBottom,
      );
      return { item, index, w, labelLines, detailLines, cardH };
    });
    let cursorY = margin.top;
    for (const entry of layout) { entry.y = cursorY; cursorY += entry.cardH + gapBetweenLayers; }
    const svgHeight = Math.max(300, cursorY - gapBetweenLayers + margin.bottom);
    const { svg, width } = svgBase(element, svgHeight);
    const groups = svg.append('g').selectAll('g').data(layout).join('g').attr('transform', (entry) => `translate(${(width - entry.w) / 2},${entry.y})`);
    groups.append('rect').attr('width', (entry) => entry.w).attr('height', (entry) => entry.cardH).attr('rx', 14).attr('fill', (_entry, index) => d3.interpolateRgb('#fff7ef', '#ead8cf')(index / Math.max(1, layout.length - 1))).attr('stroke', (entry) => colorForTone(entry.item.tone)).attr('stroke-width', 1.7);
    groups.append('text')
      .attr('x', padX)
      .attr('y', padTop + labelFont)
      .attr('fill', palette.claret)
      .attr('font-size', labelFont)
      .attr('font-weight', fontWeight('emphasis'))
      .each(function(entry) { renderLineBlock(d3.select(this), entry.labelLines, { x: padX, y: padTop + labelFont, lineHeight: labelLineH }); });
    groups.filter((entry) => entry.detailLines.length > 0).append('text')
      .attr('x', padX)
      .attr('fill', palette.ink)
      .attr('font-size', detailFont)
      .attr('font-weight', fontWeight('medium'))
      .each(function(entry) {
        const startY = padTop + entry.labelLines.length * labelLineH + gapBetweenLabelDetail + detailFont;
        renderLineBlock(d3.select(this), entry.detailLines, { x: padX, y: startY, lineHeight: detailLineH });
      });
    groups.each(function(entry) { addTitle(d3.select(this), `${entry.item.label}${entry.item.detail ? ` — ${entry.item.detail}` : ''}`); });
  };

  const renderJourneyMap = (element, payload) => {
    const items = normalizedItems(payload.data);
    const margin = { top: 34, right: 34, bottom: 46, left: 34 };
    const { svg, width, height } = svgBase(element, 360);
    const x = d3.scalePoint().domain(items.map((d) => d.label)).range([margin.left + 22, width - margin.right - 22]).padding(0.5);
    const yMid = height / 2;
    const line = d3.line().curve(d3.curveCatmullRom.alpha(0.6)).x((d) => x(d.label)).y((d, index) => yMid + (index % 2 === 0 ? -28 : 28));
    svg.append('path').attr('d', line(items)).attr('fill', 'none').attr('stroke', palette.claret).attr('stroke-width', 3).attr('opacity', 0.8);
    const groups = svg.append('g').selectAll('g').data(items).join('g').attr('transform', (d, index) => `translate(${x(d.label)},${yMid + (index % 2 === 0 ? -28 : 28)})`);
    groups.append('circle').attr('r', 18).attr('fill', (d) => colorForTone(d.tone)).attr('stroke', '#fff7ef').attr('stroke-width', 3);
    groups.append('text').attr('text-anchor', 'middle').attr('y', 4).attr('fill', '#fff7ef').attr('font-size', chartFont.small).attr('font-weight', fontWeight('label')).text((d) => d._index + 1);
    groups.append('rect').attr('x', -72).attr('y', (_d, index) => index % 2 === 0 ? -92 : 34).attr('width', 144).attr('height', 52).attr('rx', 9).attr('fill', '#fff7ef').attr('stroke', palette.border);
    groups.append('text').attr('x', 0).attr('y', (_d, index) => index % 2 === 0 ? -68 : 57).attr('text-anchor', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.small).attr('font-weight', fontWeight('strong')).each(function(d) { renderWrappedText(d3.select(this), d.label, { maxChars: 18, maxLines: 2, lineHeight: chartFont.lineHeight.tight }); });
    groups.each(function(d) { addTitle(d3.select(this), `${d.label}${d.detail ? ` — ${d.detail}` : ''}`); });
  };

  const renderKpi = (element, payload) => {
    const items = normalizedItems({ items: payload.data.items ?? payload.data.nodes });
    d3.select(element).selectAll('*').remove();
    const grid = d3.select(element).append('div').attr('class', 'kpi-grid');
    const cards = grid.selectAll('div.kpi-card').data(items).join('div')
      .attr('class', (d) => `kpi-card kpi-tone-${d.tone || 'neutral'}`);
