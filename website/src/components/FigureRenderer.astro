  const renderWaterfall = (element, payload) => {
    const items = arr(payload.data.items);
    const totalLike = (item, index) => index === 0 || index === items.length - 1 || ['total', 'subtotal'].includes(String(item.kind ?? item.role ?? '').toLowerCase());
    let running = 0;
    const points = items.map((item, index) => {
      const value = numberValue(item.value);
      const isTotal = totalLike(item, index);
      const from = isTotal ? 0 : running;
      const to = isTotal ? value : running + value;
      if (index === 0) running = value;
      else if (!isTotal) running = to;
      else running = value;
      return { ...item, index, value, isTotal, from, to, low: Math.min(from, to), high: Math.max(from, to), cumulative: to };
    });
    const containerWidth = element.getBoundingClientRect().width || 760;
    const compact = containerWidth < 640;
    const { svg, width, height } = svgBase(element, compact ? 380 : 360);
    const margin = compact ? { top: 54, right: 24, bottom: 104, left: 50 } : { top: 54, right: 38, bottom: 86, left: 62 };
    const yMin = Math.min(0, d3.min(points, (d) => d.low) || 0);
    const yMax = Math.max(1, d3.max(points, (d) => d.high) || 0);
    const x = d3.scaleBand().domain(items.map((d) => d.label)).range([margin.left, width - margin.right]).padding(compact ? 0.26 : 0.32);
    const y = d3.scaleLinear().domain([yMin, yMax]).nice().range([height - margin.bottom, margin.top]);
    const defs = svg.append('defs');
    const shadow = defs.append('filter').attr('id', `${payload.id}-waterfall-shadow`).attr('x', '-18%').attr('y', '-28%').attr('width', '136%').attr('height', '156%');
    shadow.append('feDropShadow').attr('dx', 0).attr('dy', 4).attr('stdDeviation', 4).attr('flood-color', 'rgba(51,48,46,0.14)');
