  const renderBar = (element, payload) => {
    const items = arr(payload.data.items).length ? arr(payload.data.items) : arr(arr(payload.data.series)[0]?.points);
    const { svg, width, height } = svgBase(element, Math.max(260, items.length * 42 + 78));
    const margin = { top: 18, right: 112, bottom: 38, left: Math.min(220, Math.max(152, Math.max(...items.map((item) => String(item.label ?? '').length), 8) * 7.5)) };
    const x = d3.scaleLinear().domain([0, d3.max(items, (d) => numberValue(d.value)) || 1]).nice().range([margin.left, width - margin.right]);
    const y = d3.scaleBand().domain(items.map((d) => d.label)).range([margin.top, height - margin.bottom]).padding(0.26);
    axisBottom(svg, x, height - margin.bottom);
    axisLeft(svg, y, margin.left);
    const bars = svg.append('g').selectAll('rect').data(items).join('rect')
      .attr('x', x(0)).attr('y', (d) => y(d.label)).attr('width', (d) => Math.max(2, x(numberValue(d.value)) - x(0))).attr('height', y.bandwidth())
      .attr('rx', 4).attr('fill', (d) => colorForTone(d.tone));
    bars.each(function(d) { addTitle(d3.select(this), `${d.label}: ${valueLabel(d)}`); });
    svg.append('g').selectAll('text').data(items).join('text')
      .attr('x', (d) => Math.min(width - margin.right + 6, x(numberValue(d.value)) + 8)).attr('y', (d) => y(d.label) + y.bandwidth() / 2 + 4)
      .attr('fill', palette.ink).attr('font-size', chartFont.label).attr('font-weight', fontWeight('strong')).text((d) => labelText(valueLabel(d), 16));
  };

  const renderWaterfall = (element, payload) => {
    const items = arr(payload.data.items);
    const totalLike = (item, index) => index === 0 || index === items.length - 1 || ['total', 'subtotal'].includes(String(item.kind ?? item.role ?? '').toLowerCase());
    let running = 0;
    const points = items.map((item, index) => {
      const value = numberValue(item.value);
      const isTotal = totalLike(item, index);
      const from = isTotal ? 0 : running;
      const to = isTotal ? value : running + value;
      if (index === 0) running = value;
      else if (!isTotal) running = to;
      else running = value;
      return { ...item, index, value, isTotal, from, to, low: Math.min(from, to), high: Math.max(from, to), cumulative: to };
    });
    const containerWidth = element.getBoundingClientRect().width || 760;
    const compact = containerWidth < 640;
    const { svg, width, height } = svgBase(element, compact ? 380 : 360);
    const margin = compact ? { top: 54, right: 24, bottom: 104, left: 50 } : { top: 54, right: 38, bottom: 86, left: 62 };
    const yMin = Math.min(0, d3.min(points, (d) => d.low) || 0);
    const yMax = Math.max(1, d3.max(points, (d) => d.high) || 0);
    const x = d3.scaleBand().domain(items.map((d) => d.label)).range([margin.left, width - margin.right]).padding(compact ? 0.26 : 0.32);
    const y = d3.scaleLinear().domain([yMin, yMax]).nice().range([height - margin.bottom, margin.top]);
    const defs = svg.append('defs');
    const shadow = defs.append('filter').attr('id', `${payload.id}-waterfall-shadow`).attr('x', '-18%').attr('y', '-28%').attr('width', '136%').attr('height', '156%');
    shadow.append('feDropShadow').attr('dx', 0).attr('dy', 4).attr('stdDeviation', 4).attr('flood-color', 'rgba(51,48,46,0.14)');
    svg.append('rect')
      .attr('x', margin.left)
      .attr('y', margin.top)
      .attr('width', width - margin.left - margin.right)
      .attr('height', height - margin.top - margin.bottom)
      .attr('rx', 18)
      .attr('fill', 'rgba(255,250,245,0.55)')
      .attr('stroke', 'none');
    svg.append('line')
      .attr('x1', margin.left + 8)
      .attr('x2', width - margin.right - 8)
      .attr('y1', y(0))
      .attr('y2', y(0))
      .attr('stroke', palette.border)
      .attr('stroke-width', 1.4)
      .attr('stroke-dasharray', '4 5');
    svg.append('text')
      .attr('x', margin.left + 10)
      .attr('y', margin.top - 18)
      .attr('fill', palette.muted)
      .attr('font-size', chartFont.small)
      .attr('font-weight', fontWeight('label'))
      .attr('letter-spacing', chartFont.tracking.subtle)
      .text('Waterfall bridge');
    svg.append('text')
      .attr('x', width - margin.right - 10)
      .attr('y', margin.top - 18)
      .attr('text-anchor', 'end')
      .attr('fill', palette.muted)
      .attr('font-size', chartFont.small)
      .attr('font-weight', fontWeight('strong'))
      .text(`${labelText(points[0]?.label ?? 'Start', 14)} → ${labelText(points.at(-1)?.label ?? 'End', 14)}`);
    axisLeft(svg, y, margin.left);
    svg.selectAll('.tick text').attr('font-size', chartFont.small);
    const connectors = points.slice(0, -1).map((point, index) => ({ from: point, to: points[index + 1] }));
    svg.append('g').selectAll('line.waterfall-connector').data(connectors).join('line')
      .attr('class', 'waterfall-connector')
      .attr('x1', (d) => x(d.from.label) + x.bandwidth())
      .attr('x2', (d) => x(d.to.label))
      .attr('y1', (d) => y(d.from.to))
      .attr('y2', (d) => y(d.from.to))
      .attr('stroke', palette.muted)
      .attr('stroke-width', 1.4)
      .attr('stroke-dasharray', '5 5')
      .attr('opacity', 0.7);
    const bars = svg.append('g').selectAll('g.waterfall-step').data(points).join('g')
      .attr('class', 'waterfall-step');
    bars.append('rect')
      .attr('class', (d) => `waterfall-bar ${d.isTotal ? 'waterfall-total' : d.value < 0 ? 'waterfall-negative' : 'waterfall-positive'}`)
      .attr('x', (d) => x(d.label))
      .attr('width', x.bandwidth())
      .attr('y', (d) => y(d.high))
      .attr('height', (d) => Math.max(4, y(d.low) - y(d.high)))
      .attr('fill', (d) => d.isTotal ? palette.claret : d.value < 0 ? palette.risk : colorForTone(d.tone ?? 'positive'))
      .attr('stroke', '#fff7ef')
      .attr('stroke-width', 2.5)
      .attr('rx', 8);
    bars.append('text')
      .attr('x', (d) => x(d.label) + x.bandwidth() / 2)
      .attr('y', (d) => {
        const barTop = y(d.high);
        const barBottom = y(d.low);
        const inside = barBottom - barTop > 28;
        if (inside) return barTop + (barBottom - barTop) / 2 + 5;
        return d.value < 0 ? barBottom + 14 : barTop - 8;
      })
      .attr('text-anchor', 'middle')
      .attr('fill', (d) => y(d.low) - y(d.high) > 28 ? '#fff7ef' : palette.ink)
      .attr('font-size', compact ? chartFont.size.caption : chartFont.small)
      .attr('font-weight', fontWeight('emphasis'))
      .text((d) => labelText(valueLabel(d) || d.value, 9));
    bars.append('text')
      .attr('x', (d) => x(d.label) + x.bandwidth() / 2)
      .attr('y', height - margin.bottom + 24)
      .attr('text-anchor', 'middle')
      .attr('fill', palette.ink)
      .attr('font-size', compact ? chartFont.size.tiny : chartFont.small)
      .attr('font-weight', fontWeight('strong'))
      .each(function(d) {
        renderWrappedText(d3.select(this), d.label, { maxChars: compact ? 8 : 10, maxLines: 2, lineHeight: chartFont.lineHeight.compact });
      });
    bars.append('text')
      .attr('x', (d) => x(d.label) + x.bandwidth() / 2)
      .attr('y', height - margin.bottom + (compact ? 54 : 50))
      .attr('text-anchor', 'middle')
      .attr('fill', palette.muted)
      .attr('font-size', compact ? chartFont.size.micro : chartFont.size.tiny)
      .attr('font-weight', fontWeight('strong'))
      .text((d) => d.isTotal ? 'total' : d.value < 0 ? 'drag' : 'lift');
    bars.each(function(d) { addTitle(d3.select(this), `${d.label}: ${valueLabel(d) || d.value}; cumulative ${d.to}`); });
    withTooltip(bars, (d) => tooltipHtml(d.label, [d.isTotal ? `Total: ${valueLabel(d) || d.value}` : `Change: ${valueLabel(d) || d.value}`, `Cumulative: ${d.to}`]));
  };

  const renderFunnel = (element, payload) => {
    const items = arr(payload.data.items).length ? arr(payload.data.items) : arr(arr(payload.data.series)[0]?.points);
    const containerWidth = element.getBoundingClientRect().width || 760;
    const compact = containerWidth < 640;
    const { svg, width, height } = svgBase(element, Math.max(compact ? 360 : 330, items.length * (compact ? 58 : 54) + 90));
    const margin = compact ? { top: 48, right: 72, bottom: 28, left: 106 } : { top: 50, right: 124, bottom: 30, left: 134 };
    const max = Math.max(...items.map((d) => numberValue(d.value)), 1);
    const stageGap = compact ? 8 : 9;
    const stageH = Math.min(compact ? 46 : 44, (height - margin.top - margin.bottom) / Math.max(items.length, 1) - stageGap);
    const top = margin.top;
    const barLeft = margin.left;
    const barRight = width - margin.right;
    const barMaxW = barRight - barLeft;
    const minW = Math.max(34, barMaxW * 0.12);
    const widthScale = d3.scaleLinear().domain([0, max]).range([minW, barMaxW]);
    const cx = barLeft + barMaxW / 2;
    const defs = svg.append('defs');
    const shadow = defs.append('filter').attr('id', `${payload.id}-funnel-shadow`).attr('x', '-10%').attr('y', '-35%').attr('width', '120%').attr('height', '170%');
    shadow.append('feDropShadow').attr('dx', 0).attr('dy', 4).attr('stdDeviation', 4).attr('flood-color', 'rgba(51,48,46,0.14)');
    const funnelColors = ['#a81749', '#b42351', '#c2415a', '#d1942f', '#0f766e'];
    const colorAt = (index) => funnelColors[Math.min(index, funnelColors.length - 1)] ?? colorForTone(index === items.length - 1 ? 'positive' : 'neutral');
    const rows = items.map((item, index) => {
      const y = top + index * (stageH + stageGap);
      const value = numberValue(item.value);
      const previous = index > 0 ? numberValue(items[index - 1]?.value) : value;
      const conversion = index === 0 || previous === 0 ? null : value / previous;
      const share = max === 0 ? 0 : value / max;
      const w = widthScale(value);
      return { item, index, y, w, value, conversion, share };
    });
    svg.append('rect')
      .attr('x', margin.left - (compact ? 88 : 112))
      .attr('y', margin.top - 30)
      .attr('width', width - margin.left - margin.right + (compact ? 178 : 236))
      .attr('height', height - margin.top - margin.bottom + 52)
      .attr('rx', 22)
      .attr('fill', 'rgba(255,250,245,0.58)')
      .attr('stroke', 'none');
    svg.append('text')
      .attr('x', cx)
      .attr('y', margin.top - 18)
      .attr('text-anchor', 'middle')
      .attr('fill', palette.muted)
      .attr('font-size', chartFont.small)
      .attr('font-weight', fontWeight('label'))
      .attr('letter-spacing', chartFont.tracking.subtle)
      .text('Conversion levels');
    const stages = svg.append('g').selectAll('g.funnel-stage').data(rows).join('g')
      .attr('class', 'funnel-stage');
    stages.append('rect')
      .attr('class', 'funnel-level-track')
      .attr('x', barLeft)
      .attr('y', (d) => d.y)
      .attr('width', barMaxW)
      .attr('height', stageH)
      .attr('rx', 12)
      .attr('fill', 'rgba(212,196,184,0.14)')
      .attr('stroke', 'rgba(212,196,184,0.38)');
    stages.append('rect')
      .attr('class', 'funnel-level-rect')
      .attr('x', (d) => cx - d.w / 2)
      .attr('y', (d) => d.y)
      .attr('width', (d) => d.w)
      .attr('height', stageH)
      .attr('rx', 12)
      .attr('fill', (d) => colorAt(d.index));
    stages.append('text')
      .attr('x', cx)
      .attr('y', (d) => d.y + stageH / 2 + 5)
      .attr('text-anchor', 'middle')
      .attr('fill', '#fff7ef')
      .attr('font-size', compact ? chartFont.size.caption : chartFont.small)
      .attr('font-weight', fontWeight('emphasis'))
      .text((d) => compact ? `${d3.format('.0%')(d.share)}` : `${d.index + 1} · ${d3.format('.0%')(d.share)}`);
    stages.append('text')
      .attr('x', margin.left - 14)
      .attr('y', (d) => d.y + stageH / 2 + 5)
      .attr('text-anchor', 'end')
      .attr('fill', palette.ink)
      .attr('font-size', compact ? chartFont.size.caption : chartFont.small)
      .attr('font-weight', fontWeight('label'))
      .text((d) => labelText(d.item.label, compact ? 18 : 16));
    stages.append('text')
      .attr('x', width - margin.right + 14)
      .attr('y', (d) => d.y + stageH / 2 + (compact ? 5 : -3))
      .attr('text-anchor', 'start')
      .attr('fill', palette.muted)
      .attr('font-size', compact ? chartFont.size.tiny : chartFont.small)
      .attr('font-weight', fontWeight('strong'))
      .text((d) => valueLabel(d.item));
    if (!compact) {
      stages.append('text')
        .attr('x', width - margin.right + 14)
        .attr('y', (d) => d.y + stageH / 2 + 15)
        .attr('fill', palette.muted)
        .attr('font-size', chartFont.small)
        .attr('font-weight', fontWeight('medium'))
        .text((d) => d.conversion == null ? 'entry' : `${d3.format('.0%')(d.conversion)} prior`);
    }
    stages.each(function(d) { addTitle(d3.select(this), `${d.item.label}: ${valueLabel(d.item)}${d.conversion == null ? '' : `; ${d3.format('.0%')(d.conversion)} from prior`}`); });
    withTooltip(stages, (d) => tooltipHtml(d.item.label, [valueLabel(d.item), d.conversion == null ? 'Entry stage' : `${d3.format('.0%')(d.conversion)} from prior`, d.item.detail]));
  };

  const renderRange = (element, payload) => {
    const items = arr(payload.data.items);
    if (!items.length) return;
    const lowOf = (item) => numberValue(item.low ?? item.min);
    const highOf = (item) => numberValue(item.high ?? item.max ?? item.value);
    const midOf = (item) => numberValue(item.mid ?? item.value ?? ((lowOf(item) + highOf(item)) / 2));
    const min = Math.min(...items.map(lowOf), ...items.map(midOf), 0);
    const max = Math.max(...items.map(highOf), ...items.map(midOf), 1);
    const span = Math.max(max - min, 1e-9);
    const pct = (value) => `${((value - min) / span) * 100}%`;
    const rangeColor = (item) => {
      const label = String(item.label ?? '').toLowerCase();
      if (item.tone === 'risk' || label.includes('stress') || label.includes('bear')) return palette.risk;
      if (item.tone === 'positive' || label.includes('bull')) return palette.positive;
      if (item.tone === 'opportunity') return palette.opportunity;
      if (label.includes('base')) return palette.claret;
      return colorForTone(item.tone);
    };
    const formatNumber = (value) => {
      const n = Number(value);
      if (!Number.isFinite(n)) return String(value ?? '');
      const abs = Math.abs(n);
      if (abs >= 1000) return d3.format(',.0f')(n);
      if (abs >= 100) return d3.format(',.1f')(n);
      return d3.format(',.2~f')(n);
    };
    const tickFormat = (value) => formatNumber(value);
    const ticks = d3.scaleLinear().domain([min, max]).nice().ticks(4);
    if (ticks[0] !== min) ticks.unshift(min);
    if (ticks[ticks.length - 1] !== max) ticks.push(max);
    d3.select(element).selectAll('*').remove();
    const root = d3.select(element).append('div').attr('class', 'range-list');
    items.forEach((item) => {
      const low = lowOf(item);
      const mid = midOf(item);
      const high = highOf(item);
      const fill = rangeColor(item);
      const summaryText = item.displayValue ?? `${formatNumber(low)} – ${formatNumber(high)}`;
      const row = root.append('div').attr('class', 'range-row')
        .datum({ label: safeText(item), low, mid, high, summary: summaryText, detail: item.detail });
      row.append('div').attr('class', 'range-row-label').text(safeText(item));
      const trackCell = row.append('div').attr('class', 'range-row-track-cell');
      const track = trackCell.append('div').attr('class', 'range-row-track');
      track.append('div').attr('class', 'range-row-band')
        .style('left', pct(low))
        .style('width', `calc(${pct(high)} - ${pct(low)})`)
        .style('background', fill);
      track.append('div').attr('class', 'range-row-mid-dot').style('left', pct(mid));
      const meta = trackCell.append('div').attr('class', 'range-row-meta');
      meta.append('span').attr('class', 'range-row-meta-low').text(formatNumber(low));
      meta.append('span').attr('class', 'range-row-meta-mid').text(`mid ${formatNumber(mid)}`);
      meta.append('span').attr('class', 'range-row-meta-high').text(formatNumber(high));
      row.append('div').attr('class', 'range-row-summary').text(summaryText);
      if (item.detail) row.append('div').attr('class', 'range-row-detail').text(item.detail);
    });
    const axis = root.append('div').attr('class', 'range-axis');
    ticks.forEach((tickValue) => {
      axis.append('span')
        .attr('class', 'range-axis-tick')
        .style('left', pct(tickValue))
        .text(tickFormat(tickValue));
    });
    withTooltip(root.selectAll('.range-row'), (d) => tooltipHtml(d.label, [`Low: ${formatNumber(d.low)}`, `Mid: ${formatNumber(d.mid)}`, `High: ${formatNumber(d.high)}`, d.detail]));
  };

  const renderQuadrant = (element, payload) => {
    const points = arr(payload.data.points);
    const axisLabel = (raw, fallback) => {
      if (raw == null) return fallback;
      if (typeof raw === 'string' || typeof raw === 'number') return String(raw);
      if (typeof raw === 'object' && typeof raw.label === 'string') return raw.label;
      return fallback;
    };
    const xAxisLabel = axisLabel(payload.data.xAxis ?? payload.data.xLabel ?? payload.data.x, 'X');
    const yAxisLabel = axisLabel(payload.data.yAxis ?? payload.data.yLabel ?? payload.data.y, 'Y');
    const xs = points.map((p) => Number(p.x)).filter(Number.isFinite);
    const ys = points.map((p) => Number(p.y)).filter(Number.isFinite);
    const allValues = [...xs, ...ys];
    const finiteMin = allValues.length ? Math.min(...allValues) : 0;
    const finiteMax = allValues.length ? Math.max(...allValues) : 100;
    const isTenPointScore = finiteMin >= 0 && finiteMax <= 10;
    const isUnitScore = finiteMin >= 0 && finiteMax <= 1;
    const isPercentScore = !isTenPointScore && !isUnitScore && finiteMin >= 0 && finiteMax <= 100;
    const referenceValue = isTenPointScore ? 5 : isUnitScore ? 0.5 : 50;
    const safeRange = (vals) => {
      if (vals.length === 0) return isTenPointScore ? { min: 0, max: 10 } : isUnitScore ? { min: 0, max: 1 } : { min: 0, max: 100 };
      if (isTenPointScore) return { min: 0, max: 10 };
      if (isUnitScore) return { min: 0, max: 1 };
      if (isPercentScore) return { min: 0, max: 100 };
      const lo = Math.min(...vals);
      const hi = Math.max(...vals);
      const distance = Math.max(Math.abs(lo - referenceValue), Math.abs(hi - referenceValue), 10);
      const roundedDistance = Math.ceil(distance / 5) * 5;
      return { min: referenceValue - roundedDistance, max: referenceValue + roundedDistance };
    };
    const xRange = safeRange(xs);
    const yRange = safeRange(ys);
    const containerWidth = element.getBoundingClientRect().width || 760;
    const compact = containerWidth < 640;
    const { svg, width, height } = svgBase(element, compact ? 420 : 380);
    const margin = compact ? { top: 52, right: 34, bottom: 60, left: 52 } : { top: 54, right: 42, bottom: 60, left: 70 };
    const plotW = width - margin.left - margin.right;
    const plotH = height - margin.top - margin.bottom;
    const x = d3.scaleLinear().domain([xRange.min, xRange.max]).range([margin.left, width - margin.right]);
    const y = d3.scaleLinear().domain([yRange.min, yRange.max]).range([height - margin.bottom, margin.top]);
    const refX = Math.max(margin.left, Math.min(width - margin.right, x(referenceValue)));
    const refY = Math.max(margin.top, Math.min(height - margin.bottom, y(referenceValue)));
    const defs = svg.append('defs');
    const shadow = defs.append('filter').attr('id', `${payload.id}-quadrant-shadow`).attr('x', '-20%').attr('y', '-24%').attr('width', '140%').attr('height', '152%');
    shadow.append('feDropShadow').attr('dx', 0).attr('dy', 5).attr('stdDeviation', 5).attr('flood-color', 'rgba(51,48,46,0.16)');
    const panel = svg.append('g');
    const quadrants = [
      { label: 'Specialist depth', x: margin.left, y: margin.top, w: refX - margin.left, h: refY - margin.top, fill: 'rgba(15,118,110,0.07)' },
      { label: 'Leader zone', x: refX, y: margin.top, w: width - margin.right - refX, h: refY - margin.top, fill: 'rgba(153,15,61,0.07)' },
      { label: 'Watchlist', x: margin.left, y: refY, w: refX - margin.left, h: height - margin.bottom - refY, fill: 'rgba(180,35,24,0.055)' },
      { label: 'Scale path', x: refX, y: refY, w: width - margin.right - refX, h: height - margin.bottom - refY, fill: 'rgba(184,134,11,0.075)' },
    ].filter((q) => q.w > 2 && q.h > 2);
    panel.append('rect')
      .attr('x', margin.left)
      .attr('y', margin.top)
      .attr('width', plotW)
      .attr('height', plotH)
      .attr('rx', 18)
      .attr('fill', '#fffaf5')
      .attr('stroke', palette.border);
    panel.selectAll('rect.quadrant-zone').data(quadrants).join('rect')
      .attr('class', 'quadrant-zone')
      .attr('x', (q) => q.x)
      .attr('y', (q) => q.y)
      .attr('width', (q) => q.w)
      .attr('height', (q) => q.h)
      .attr('fill', (q) => q.fill)
      .attr('clip-path', null);
    panel.append('line').attr('x1', refX).attr('x2', refX).attr('y1', margin.top + 10).attr('y2', height - margin.bottom - 10).attr('stroke', palette.claret).attr('stroke-width', 1.5).attr('stroke-dasharray', '5 6').attr('opacity', 0.58);
    panel.append('line').attr('x1', margin.left + 10).attr('x2', width - margin.right - 10).attr('y1', refY).attr('y2', refY).attr('stroke', palette.claret).attr('stroke-width', 1.5).attr('stroke-dasharray', '5 6').attr('opacity', 0.58);
    panel.append('circle').attr('cx', refX).attr('cy', refY).attr('r', 5).attr('fill', '#fffaf5').attr('stroke', palette.claret).attr('stroke-width', 2).attr('opacity', 0.85);
    panel.selectAll('text.quadrant-label').data(quadrants).join('text')
      .attr('class', 'quadrant-label')
      .attr('x', (q) => q.x + q.w / 2)
      .attr('y', (q) => q.y + q.h / 2)
      .attr('text-anchor', 'middle')
      .attr('dominant-baseline', 'middle')
      .attr('fill', palette.muted)
      .attr('font-size', compact ? chartFont.size.caption : chartFont.size.label)
      .attr('font-weight', fontWeight('label'))
      .attr('letter-spacing', chartFont.tracking.caps)
      .attr('opacity', 0.32)
      .style('text-transform', 'uppercase')
      .style('pointer-events', 'none')
      .text((q) => q.label);
    const tickValues = (range) => Array.from(new Set([range.min, referenceValue, range.max]));
    const tickFormat = isUnitScore ? d3.format('.1f') : d3.format('~g');
    svg.append('g')
      .attr('transform', `translate(0,${height - margin.bottom})`)
      .call(d3.axisBottom(x).tickValues(tickValues(xRange)).tickFormat(tickFormat).tickSizeOuter(0))
      .call((axis) => axis.select('.domain').attr('stroke', palette.border))
      .call((axis) => axis.selectAll('line').attr('stroke', palette.border).attr('opacity', 0.65))
      .call((axis) => axis.selectAll('text').attr('fill', palette.muted).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('strong')));
    svg.append('g')
      .attr('transform', `translate(${margin.left},0)`)
      .call(d3.axisLeft(y).tickValues(tickValues(yRange)).tickFormat(tickFormat).tickSizeOuter(0))
      .call((axis) => axis.select('.domain').attr('stroke', palette.border))
      .call((axis) => axis.selectAll('line').attr('stroke', palette.border).attr('opacity', 0.65))
      .call((axis) => axis.selectAll('text').attr('fill', palette.muted).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('strong')));
    svg.selectAll('.domain').attr('stroke', palette.border);
    svg.selectAll('.tick line').attr('stroke', palette.border).attr('opacity', 0.65);
    svg.append('text').attr('x', margin.left + plotW / 2).attr('y', height - margin.bottom + 42).attr('text-anchor', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('label')).text(xAxisLabel);
    svg.append('text').attr('transform', `translate(${compact ? 18 : 24},${margin.top + plotH / 2}) rotate(-90)`).attr('text-anchor', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('label')).text(yAxisLabel);
    const plotPoints = points.map((point, index) => {
      const targetX = x(numberValue(point.x));
      const targetY = y(numberValue(point.y));
      return { ...point, _index: index, _valueX: point.x, _valueY: point.y, _targetX: targetX, _targetY: targetY, x: targetX, y: targetY };
    });
    d3.forceSimulation(plotPoints)
      .force('x', d3.forceX((d) => d._targetX).strength(0.28))
      .force('y', d3.forceY((d) => d._targetY).strength(0.28))
      .force('collide', d3.forceCollide(compact ? 18 : 20))
      .stop()
      .tick(90);
    plotPoints.forEach((point) => {
      point.x = Math.max(margin.left + 18, Math.min(width - margin.right - 18, point.x));
      point.y = Math.max(margin.top + 18, Math.min(height - margin.bottom - 18, point.y));
    });
    const dots = svg.append('g').selectAll('g.quadrant-point').data(plotPoints).join('g').attr('class', 'quadrant-point').attr('transform', (d) => `translate(${d.x},${d.y})`);
    dots.append('circle').attr('r', compact ? 15 : 17).attr('fill', (d) => colorForTone(d.tone)).attr('stroke', '#fff7ef').attr('stroke-width', 3).attr('opacity', 0.96);
    dots.append('circle').attr('r', compact ? 7 : 8).attr('fill', '#fff7ef').attr('opacity', 0.18);
    dots.append('text').attr('text-anchor', 'middle').attr('dominant-baseline', 'middle').attr('fill', '#fff7ef').attr('font-size', compact ? chartFont.size.caption : chartFont.size.caption).attr('font-weight', fontWeight('emphasis')).text((d) => d._index + 1);
    // Inline text labels next to each dot collide badly when points cluster
    // along a quadrant boundary. Rely on the numbered badge inside the dot
    // plus the HTML legend below for identification; tooltips handle hover.
    dots.each(function(d) { addTitle(d3.select(this), `${d.label}: ${xAxisLabel} ${d._valueX}; ${yAxisLabel} ${d._valueY}`); });
    withTooltip(dots, (d) => tooltipHtml(d.label, [`${xAxisLabel}: ${d._valueX}`, `${yAxisLabel}: ${d._valueY}`, d.detail]));
    // HTML legend: responsive flow grid, wraps cleanly at any width.
    const legendHost = d3.select(element).append('div').attr('class', 'quadrant-legend');
    const legendItems = legendHost.selectAll('div.quadrant-legend-item').data(plotPoints).join('div')
      .attr('class', 'quadrant-legend-item');
    legendItems.append('span')
      .attr('class', 'quadrant-legend-badge')
      .style('background', (d) => colorForTone(d.tone))
      .text((d) => d._index + 1);
    legendItems.append('span').attr('class', 'quadrant-legend-label').text((d) => d.label);
    withTooltip(legendItems, (d) => tooltipHtml(d.label, [`${xAxisLabel}: ${d._valueX}`, `${yAxisLabel}: ${d._valueY}`, d.detail]));
  };

  const renderHeatmap = (element, payload) => {
    const columns = arr(payload.data.columns);
    const rows = arr(payload.data.rows);
    const cellDetail = (cell) => (cell && typeof cell === 'object') ? (cell.detail ?? cell.note ?? '') : '';
    const cellTone = (cell) => (cell && typeof cell === 'object') ? cell.tone : undefined;
    d3.select(element).selectAll('*').remove();
    const root = d3.select(element).append('div').attr('class', 'matrix-table');
    root.style('--matrix-cols', String(Math.max(columns.length, 1)));
    // Desktop / tablet: CSS grid table. Header row first, then data rows.
    const grid = root.append('div').attr('class', 'matrix-grid').attr('role', 'table');
    const headerRow = grid.append('div').attr('class', 'matrix-row matrix-row-head').attr('role', 'row');
    headerRow.append('div').attr('class', 'matrix-cell matrix-corner').attr('role', 'columnheader').attr('aria-hidden', 'true');
    headerRow.selectAll('div.matrix-col-head').data(columns).join('div')
      .attr('class', 'matrix-cell matrix-col-head')
      .attr('role', 'columnheader')
      .text((d) => safeText(d));
    rows.forEach((row) => {
      const rowEl = grid.append('div').attr('class', 'matrix-row matrix-row-body').attr('role', 'row');
      rowEl.append('div').attr('class', 'matrix-cell matrix-rowlabel').attr('role', 'rowheader').text(safeText(row?.label));
      arr(row?.values).forEach((cell, colIndex) => {
        const rawText = safeText(cell);
        const isEmpty = cell == null || rawText === '';
        const text = isEmpty ? '—' : rawText;
        const detail = cellDetail(cell);
        const dataCell = rowEl.append('div')
          .attr('class', `matrix-cell matrix-data matrix-tone-${cellTone(cell) || 'neutral'}${isEmpty ? ' matrix-empty' : ''}`)
          .attr('role', 'cell')
          .text(text);
        dataCell.datum({ row: safeText(row?.label), column: safeText(columns[colIndex]), text: isEmpty ? 'No data' : text, detail });
      });
    });
    withTooltip(grid.selectAll('.matrix-data'), (d) => tooltipHtml(`${d.row} × ${d.column}`, [d.text, d.detail]));
    // Narrow viewports: card-per-row layout (one card per data row, listing
    // each column as a labelled key/value). CSS picks which one is visible.
    const cards = root.append('div').attr('class', 'matrix-cards');
    rows.forEach((row) => {
      const card = cards.append('div').attr('class', 'matrix-card');
      card.append('div').attr('class', 'matrix-card-title').text(safeText(row?.label));
      arr(row?.values).forEach((cell, colIndex) => {
        const rawText = safeText(cell);
        const isEmpty = cell == null || rawText === '';
        // Skip drawing a card row entry when the cell is empty AND has no
        // tone signal worth showing. Keeps the mobile card list tight.
        if (isEmpty && !cellTone(cell)) return;
        const text = isEmpty ? '—' : rawText;
        const detail = cellDetail(cell);
        const item = card.append('div').attr('class', `matrix-card-item matrix-tone-${cellTone(cell) || 'neutral'}${isEmpty ? ' matrix-empty' : ''}`);
        item.datum({ row: safeText(row?.label), column: safeText(columns[colIndex]), text: isEmpty ? 'No data' : text, detail });
        item.append('div').attr('class', 'matrix-card-key').text(safeText(columns[colIndex]));
        item.append('div').attr('class', 'matrix-card-val').text(text);
        if (detail) item.append('div').attr('class', 'matrix-card-detail').text(detail);
      });
    });
    withTooltip(cards.selectAll('.matrix-card-item'), (d) => tooltipHtml(`${d.row} × ${d.column}`, [d.text, d.detail]));
  };

  const renderCohort = (element, payload) => {
    const columns = arr(payload.data.columns);
    const rows = arr(payload.data.rows);
    const { svg, width, height } = svgBase(element, Math.max(340, rows.length * 58 + 92));
    const margin = { top: 58, right: 24, bottom: 26, left: 156 };
    const x = d3.scaleBand().domain(columns).range([margin.left, width - margin.right]).padding(0.08);
    const y = d3.scaleBand().domain(rows.map((row) => row.label)).range([margin.top, height - margin.bottom]).padding(0.08);
    // Adaptive color scale. Default to retention percentages 0–100 (the
    // canonical cohort use case) but fall back to the observed numeric range
    // so misuses with ordinal scoring (e.g. 0–3) still produce visible
    // contrast instead of a single flat color.
    const numericValues = [];
    for (const row of rows) for (const cell of arr(row.values)) {
      const value = Number(cell?.value ?? String(cell?.label ?? '').replace(/[^0-9.-]/g, ''));
      if (Number.isFinite(value)) numericValues.push(value);
    }
    const dataMin = numericValues.length ? Math.min(...numericValues) : 0;
    const dataMax = numericValues.length ? Math.max(...numericValues) : 100;
    const fitsPercent = dataMin >= 0 && dataMax <= 100 && dataMax > 10;
    const colorDomain = fitsPercent
      ? [0, 50, 100]
      : dataMax === dataMin
        ? [dataMin, dataMin, dataMax + 1]
        : [dataMin, (dataMin + dataMax) / 2, dataMax];
    const color = d3.scaleLinear().domain(colorDomain).range(['#f4c7bd', '#f2d8a0', '#0f766e']);
    svg.append('g').selectAll('text').data(columns).join('text').attr('x', (d) => x(d) + x.bandwidth() / 2).attr('y', margin.top - 16).attr('text-anchor', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('strong')).text((d) => labelText(d, 14));
    svg.append('g').selectAll('text').data(rows).join('text').attr('x', margin.left - 12).attr('y', (d) => y(d.label) + y.bandwidth() / 2 + 4).attr('text-anchor', 'end').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('strong')).each(function(d) {
      renderWrappedText(d3.select(this), d.label, { maxChars: 20, maxLines: 2, lineHeight: chartFont.lineHeight.tight });
    });
    const cells = [];
    rows.forEach((row) => arr(row.values).forEach((cell, colIndex) => {
      const value = Number(cell?.value ?? String(cell?.label ?? '').replace(/[^0-9.-]/g, ''));
      cells.push({ row: row.label, column: columns[colIndex], cell, value: Number.isFinite(value) ? value : 0 });
    }));
    const g = svg.append('g').selectAll('g').data(cells).join('g');
    g.append('rect').attr('x', (d) => x(d.column)).attr('y', (d) => y(d.row)).attr('width', x.bandwidth()).attr('height', y.bandwidth()).attr('rx', 7).attr('fill', (d) => color(d.value)).attr('stroke', '#fff7ef').attr('stroke-width', 3);
    g.append('text').attr('x', (d) => x(d.column) + x.bandwidth() / 2).attr('y', (d) => y(d.row) + y.bandwidth() / 2).attr('text-anchor', 'middle').attr('dominant-baseline', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.small).attr('font-weight', fontWeight('strong')).each(function(d) {
      const cellLabel = safeText(d.cell) || (Number.isFinite(d.value) ? String(d.value) : '');
      renderWrappedText(d3.select(this), cellLabel, { maxChars: Math.max(7, Math.floor(x.bandwidth() / 7)), maxLines: Math.max(1, Math.floor(y.bandwidth() / 16)), lineHeight: chartFont.lineHeight.tight });
    });
    g.each(function(d) { addTitle(d3.select(this), `${d.row} × ${d.column}: ${safeText(d.cell) || d.value}`); });
    withTooltip(g, (d) => tooltipHtml(`${d.row} × ${d.column}`, [safeText(d.cell) || String(d.value), d.cell?.detail]));
  };

  const RENDERERS = {
    timeline: renderTimeline,
    flow: renderFlow,
    stack: renderStack,
    pyramid: renderPyramid,
    'journey-map': renderJourneyMap,
    kpi: renderKpi,
    waterfall: renderWaterfall,
    funnel: renderFunnel,
    range: renderRange,
    bar: renderBar,
    matrix: renderHeatmap,
    cohort: renderCohort,
    quadrant: renderQuadrant,
    dag: renderDag,
  };

  const normalizeRenderedTypography = (element) => {
    d3.select(element)
      .selectAll('svg text')
      .attr('font-family', chartFont.family);
  };

  const normalizeRenderedFlatStyle = (element) => {
    const svg = d3.select(element).select('svg');
    svg.selectAll('filter').remove();
    svg.selectAll('[filter]').attr('filter', null);
    svg.selectAll('[style*="drop-shadow"], [style*="box-shadow"]').style('filter', null).style('box-shadow', null);
  };

  const renderD3 = (element, payload) => {
    try {
      const result = RENDERERS[payload.type]?.(element, payload);
      normalizeRenderedTypography(element);
      normalizeRenderedFlatStyle(element);
      return result;
    } catch (error) {
      console.error(`[FigureRenderer] Failed to render ${payload?.id ?? payload?.type ?? 'figure'}`, error);
      d3.select(element).selectAll('*').remove();
      d3.select(element).append('div').attr('class', 'figure-render-error').text('Figure could not be rendered.');
      return null;
    }
  };

  const payloadByScript = new WeakMap();
  const scriptByChartId = new Map();
  const chartScripts = () => Array.from(document.querySelectorAll('script.figure-chart-data'));
  const payloadForScript = (script) => {
    if (!payloadByScript.has(script)) payloadByScript.set(script, JSON.parse(script.textContent || '{}'));
    return payloadByScript.get(script);
  };

  const RESIZE_RERENDER_DELTA_PX = 32;
  const RESIZE_RERENDER_DEBOUNCE_MS = 180;
  const pendingResizeRenders = new WeakMap();
  const flushResizeRender = (element) => {
    const handle = pendingResizeRenders.get(element);
    if (handle) {
      window.clearTimeout(handle);
      pendingResizeRenders.delete(element);
    }
    const script = scriptByChartId.get(element.id);
    if (!script) return;
    const payload = payloadForScript(script);
    renderD3(element, payload);
    script.dataset.rendered = 'true';
    element.dataset.renderState = 'rendered';
    element.dataset.renderWidth = String(Math.round(element.getBoundingClientRect().width || 0));
  };
  const chartResizeObserver = 'ResizeObserver' in window ? new ResizeObserver((entries) => {
    for (const entry of entries) {
      const element = entry.target;
      const nextWidth = Math.round(entry.contentRect.width || 0);
      const prevWidth = Number(element.dataset.renderWidth || 0);
      if (!nextWidth || (prevWidth && Math.abs(nextWidth - prevWidth) < RESIZE_RERENDER_DELTA_PX)) continue;
      const existing = pendingResizeRenders.get(element);
      if (existing) window.clearTimeout(existing);
      const handle = window.setTimeout(() => flushResizeRender(element), RESIZE_RERENDER_DEBOUNCE_MS);
      pendingResizeRenders.set(element, handle);
    }
  }) : null;

  const renderChartScript = (script, { force = false } = {}) => {
    if (!force && script.dataset.rendered === 'true') return;
    const payload = payloadForScript(script);
    const element = document.getElementById(payload.id);
    if (!element) return;
    element.dataset.renderState = 'rendering';
    renderD3(element, payload);
    element.dataset.renderWidth = String(Math.round(element.getBoundingClientRect().width || 0));
    if (chartResizeObserver && script.dataset.observed !== 'true') {
      chartResizeObserver.observe(element);
      script.dataset.observed = 'true';
    }
    script.dataset.rendered = 'true';
    element.dataset.renderState = 'rendered';
  };

  const renderAllCharts = ({ force = false } = {}) => {
    chartScripts().forEach((script) => renderChartScript(script, { force }));
  };

  const initializeCharts = () => {
    chartScripts().forEach((script) => {
      const payload = payloadForScript(script);
      const element = document.getElementById(payload.id);
      if (!element) return;
      scriptByChartId.set(payload.id, script);
      element.dataset.renderState = script.dataset.rendered === 'true' ? 'rendered' : 'pending';
    });
    renderAllCharts();
  };
  initializeCharts();
  window.addEventListener('beforeprint', () => renderAllCharts());
  let resizeTimer = null;
  window.addEventListener('resize', () => {
    if (chartResizeObserver) return;
    window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => {
      chartScripts().forEach((script) => { script.dataset.rendered = 'false'; });
      renderAllCharts({ force: true });
    }, 140);
  });
</script>

<style>
  /*
