    const measuredWidth = (value) => {
      measureText.text(String(value ?? ''));
      return measureText.node()?.getComputedTextLength?.() ?? String(value ?? '').length * 8;
    };
    const splitTokenBySvgWidth = (token) => {
      const chunks = [];
      let chunk = '';
      Array.from(String(token ?? '')).forEach((char) => {
        const next = `${chunk}${char}`;
        if (chunk && measuredWidth(next) > textW) {
          chunks.push(chunk);
          chunk = char;
        } else {
          chunk = next;
        }
      });
      if (chunk) chunks.push(chunk);
      return chunks;
    };
