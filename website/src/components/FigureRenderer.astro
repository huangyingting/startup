      point.y = Math.max(margin.top + 18, Math.min(height - margin.bottom - 18, point.y));
    });
    const competitors = svg.append('g').selectAll('g.positioning-point').data(plotted).join('g')
      .attr('class', 'positioning-point')
      .attr('transform', (d) => `translate(${d.x},${d.y})`);
    competitors.append('circle').attr('r', compact ? 8 : 9).attr('fill', (d) => colorForTone(d.tone)).attr('stroke', '#fff7ef').attr('stroke-width', 2.5);
    competitors.append('text')
      .attr('x', (d) => d.x > margin.left + plotW * 0.68 ? -14 : 14)
      .attr('y', 4)
      .attr('text-anchor', (d) => d.x > margin.left + plotW * 0.68 ? 'end' : 'start')
      .attr('fill', palette.ink)
      .attr('font-size', compact ? chartFont.size.caption : chartFont.small)
      .attr('font-weight', fontWeight('label'))
      .text((d) => labelText(d.label, compact ? 22 : 24));
    competitors.each(function(d) { addTitle(d3.select(this), `${d.label}: ${xAxisLabel} ${d._valueX}; ${yAxisLabel} ${d._valueY}`); });
    withTooltip(competitors, (d) => tooltipHtml(d.label, [`${xAxisLabel}: ${d._valueX}`, `${yAxisLabel}: ${d._valueY}`, d.detail]));
  };

  const renderSensitivity = (element, payload) => {
    const series = arr(payload.data.series)[0] ?? {};
    renderBars(element, { ...payload, data: { items: arr(series.points) } });
  };

  const renderScatter = (element, payload) => {
    const points = arr(payload.data.points).length ? arr(payload.data.points) : arr(arr(payload.data.series)[0]?.points);
    const mapped = points.map((point) => ({ ...point, x: numberValue(point.x ?? point.value?.[0]), y: numberValue(point.y ?? point.value?.[1]) }));
    renderQuadrant(element, { ...payload, data: { ...payload.data, points: mapped } });
  };

  const GRAPH_TYPES = new Set(['decision-map', 'evidence-map', 'scenario-tree', 'dependency-map']);
  const HEATMAP_TYPES = new Set(['matrix', 'heatmap']);
  const RENDERERS = {
    timeline: renderTimeline,
    flow: renderFlow,
    stack: renderStack,
    'layered-lens': renderLayeredLens,
    bridge: renderBridge,
    'journey-map': renderJourneyMap,
    'logic-chain': renderLogicChain,
    'causal-map': renderCausalMap,
    scorecard: renderScorecard,
    waterfall: renderWaterfall,
    funnel: renderFunnel,
    range: renderRange,
    bars: renderBars,
    cohort: renderCohort,
    scatter: renderScatter,
    sensitivity: renderSensitivity,
  };

  const normalizeRenderedTypography = (element) => {
    d3.select(element)
      .selectAll('svg text')
      .attr('font-family', chartFont.family);
  };

  const normalizeRenderedFlatStyle = (element) => {
    const svg = d3.select(element).select('svg');
    svg.selectAll('filter').remove();
    svg.selectAll('[filter]').attr('filter', null);
    svg.selectAll('[style*="drop-shadow"], [style*="box-shadow"]').style('filter', null).style('box-shadow', null);
  };

  const renderD3 = (element, payload) => {
    let result;
    if (payload.type === 'decision-map') result = renderDecisionMap(element, payload);
    else if (payload.type === 'evidence-map') result = renderEvidenceMap(element, payload);
    else if (payload.type === 'scenario-tree') result = renderScenarioTree(element, payload);
    else if (payload.type === 'dependency-map') result = renderDependencyMap(element, payload);
    else if (GRAPH_TYPES.has(payload.type)) result = renderGraph(element, payload);
    else if (payload.type === 'quadrant') result = renderQuadrant(element, payload);
    else if (payload.type === 'positioning-map') result = renderPositioningMap(element, payload);
    else if (HEATMAP_TYPES.has(payload.type)) result = renderHeatmap(element, payload);
    else result = RENDERERS[payload.type]?.(element, payload);
    normalizeRenderedTypography(element);
    normalizeRenderedFlatStyle(element);
    return result;
  };

  const renderCharts = () => {
    document.querySelectorAll('script.figure-chart-data').forEach((script) => {
      if (script.dataset.rendered === 'true') return;
      const payload = JSON.parse(script.textContent || '{}');
      const element = document.getElementById(payload.id);
      if (!element) return;
      renderD3(element, payload);
      script.dataset.rendered = 'true';
    });
  };
  renderCharts();
  window.addEventListener('resize', () => {
    document.querySelectorAll('script.figure-chart-data').forEach((script) => {
      script.dataset.rendered = 'false';
    });
    renderCharts();
  });
</script>

