          const route = routeGrid({ x: sourcePort.outX, y: sourcePort.outY }, { x: targetPort.outX, y: targetPort.outY }, edge, usedSegments);
          const path = route
            ? simplifyPath([{ x: sourcePort.x, y: sourcePort.y }, ...route, { x: targetPort.x, y: targetPort.y }])
            : simplifyPath([{ x: sourcePort.x, y: sourcePort.y }, { x: sourcePort.outX, y: sourcePort.outY }, { x: targetPort.outX, y: sourcePort.outY }, { x: targetPort.outX, y: targetPort.outY }, { x: targetPort.x, y: targetPort.y }]);
          const hits = pathHits(path, edge);
          const score = hits * 100000 + pathOverlapPenalty(path, usedSegments) + portPenalty(edge, sourcePort, targetPort) + pathBends(path) * 48 + pathLength(path);
          if (score < bestScore) { bestScore = score; best = path; }
        }
        // Pairs are sorted by ascending portPenalty; once we have a clean
        // direct path the remaining (higher-penalty) pairs almost never win.
        // Break to skip the expensive grid search on the rest.
        if (directIsClean && bestScore < 100000) break;
      }
      return best ?? [];
    };
    const routedPathByEdge = new Map();
    const usedSegments = [];
    const routeOrder = [...routedEdges].sort((a, b) => ((b.target._stage - b.source._stage) - (a.target._stage - a.source._stage)) || (a.source._stage - b.source._stage) || (a.source.y - b.source.y) || (a.target.y - b.target.y));
    for (const edge of routeOrder) {
      const path = choosePath(edge, usedSegments);
