  const renderBar = (element, payload) => {
    const items = arr(payload.data.items).length ? arr(payload.data.items) : arr(arr(payload.data.series)[0]?.points);
    const { svg, width, height } = svgBase(element, Math.max(260, items.length * 42 + 78));
    const margin = { top: 18, right: 112, bottom: 38, left: Math.min(220, Math.max(152, Math.max(...items.map((item) => String(item.label ?? '').length), 8) * 7.5)) };
