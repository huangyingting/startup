---
import ClaimRefs from './ClaimRefs.astro';

interface Props {
  figure: any;
  claims?: any[];
  sources?: any[];
}

const { figure, claims = [], sources = [] } = Astro.props;
const type = figure?.type ?? 'flow';
const layout = figure?.layout ?? 'standard';
const data = figure?.data ?? {};
const chartTypes = new Set(['timeline', 'flow', 'decision-map', 'evidence-map', 'scenario-tree', 'dependency-map', 'bars', 'waterfall', 'funnel', 'range', 'quadrant', 'positioning-map', 'matrix', 'heatmap', 'cohort', 'sensitivity', 'scatter', 'stack', 'layered-lens', 'bridge', 'journey-map', 'logic-chain', 'causal-map', 'scorecard']);
const usesD3Chart = chartTypes.has(type);
const chartId = `chart-${String(figure?.id ?? 'figure').replace(/[^a-z0-9_-]/gi, '-')}-${Math.random().toString(36).slice(2, 9)}`;
const arr = <T = any>(value: T[] | undefined | null): T[] => Array.isArray(value) ? value : [];
const blockRefs = (block: any) => arr<string>(block?.claimRefs).slice(0, 6);
const chartPayload = usesD3Chart ? { id: chartId, type, title: figure?.title, data } : null;
---

<figure class:list={['native-figure', `figure-${type}`, `layout-${layout}`]}>
  <figcaption>{figure.id}: {figure.title}</figcaption>

  {figure.summary && <p class="figure-summary">{figure.summary}</p>}

  {usesD3Chart && <div id={chartId} class:list={['d3-figure', `chart-${type}`]} data-chart-type={type}></div>}

  {type === 'other' && (
    <div class="figure-fallback" role="note">
      <strong>Structured figure data available</strong>
      <p>This figure type does not yet have a dedicated renderer. Use a generic type such as <code>logic-chain</code>, <code>causal-map</code>, <code>stack</code>, <code>heatmap</code>, <code>bars</code>, <code>funnel</code>, <code>cohort</code>, <code>range</code>, <code>scorecard</code>, or <code>scatter</code> for automatic visual rendering.</p>
    </div>
  )}

  {figure.approximationNotes && <p class="figure-note">{figure.approximationNotes}</p>}
  <ClaimRefs refs={blockRefs(figure)} claims={claims} sources={sources} />
  {chartPayload && <script type="application/json" class="figure-chart-data" set:html={JSON.stringify(chartPayload)}></script>}
</figure>

<script>
  import * as d3 from 'd3';

  const palette = {
    claret: '#990f3d',
    ink: '#33302e',
    muted: '#6b625c',
    border: '#d8ccc2',
    paper: '#fff7ef',
    positive: '#0f766e',
    risk: '#b42318',
    opportunity: '#b8860b',
    neutral: '#990f3d',
  };

  const arr = (value) => Array.isArray(value) ? value : [];
  const colorForTone = (tone) => {
    if (tone === 'positive' || tone === 'low') return palette.positive;
    if (tone === 'risk' || tone === 'critical' || tone === 'high') return palette.risk;
    if (tone === 'opportunity') return palette.opportunity;
    return palette.neutral;
  };
  const riskValue = (tone) => {
    if (tone === 'high' || tone === 'critical' || tone === 'risk') return 3;
    if (tone === 'medium' || tone === 'neutral') return 2;
    return 1;
  };
  const labelText = (text, max = 24) => String(text ?? '').length > max ? `${String(text).slice(0, max - 1)}…` : String(text ?? '');
  const numberValue = (value) => Number(value) || 0;
  const valueLabel = (item) => item?.displayValue ?? item?.value ?? '';
  const fullValueLabel = (item) => item?.displayValue ?? item?.value ?? item?.score ?? item?.label ?? '';

  const chartFont = { axis: 13, label: 14, small: 12 };
  const tooltip = (() => {
    const node = d3.select('body').selectAll('.d3-chart-tooltip').data([null]).join('div').attr('class', 'd3-chart-tooltip');
    const move = (event) => {
      const offset = 14;
      const tooltipNode = node.node();
      const box = tooltipNode?.getBoundingClientRect?.() ?? { width: 0, height: 0 };
      const left = Math.max(8, Math.min(window.innerWidth - box.width - 8, event.clientX + offset));
      const top = Math.max(8, Math.min(window.innerHeight - box.height - 8, event.clientY + offset));
      node.style('left', `${left}px`).style('top', `${top}px`);
    };
    return {
      show(event, html) {
        node.html(html).classed('is-visible', true);
        move(event);
      },
      move,
      hide() {
        node.classed('is-visible', false);
      },
    };
  })();
  const escapeHtml = (value) => String(value ?? '').replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char]));
  const tooltipHtml = (title, lines = []) => `<strong>${escapeHtml(title)}</strong>${lines.filter(Boolean).map((line) => `<span>${escapeHtml(line)}</span>`).join('')}`;
  const shouldShowTooltip = () => window.innerWidth >= 700 && !window.matchMedia?.('(pointer: coarse)')?.matches;
  const withTooltip = (selection, htmlForDatum) => selection
    .style('cursor', 'default')
    .on('pointerenter', function(event, datum) {
      d3.select(this).classed('is-hovered', true);
      if (!shouldShowTooltip()) return;
      const html = typeof htmlForDatum === 'function' ? htmlForDatum(datum) : htmlForDatum;
      tooltip.show(event, html);
    })
    .on('pointermove', (event) => {
      if (shouldShowTooltip()) tooltip.move(event);
    })
    .on('pointerleave', function() {
      d3.select(this).classed('is-hovered', false);
      tooltip.hide();
    });
  const wrapWords = (text, maxChars = 18, maxLines = 2) => {
    const words = String(text ?? '').split(/\s+/).filter(Boolean);
    if (!words.length) return [''];
    const lines = [];
    let line = '';
    words.forEach((word) => {
      const next = line ? `${line} ${word}` : word;
      if (next.length > maxChars && line) {
        lines.push(line);
        line = word;
      } else {
        line = next;
      }
    });
    if (line) lines.push(line);
    const clipped = lines.slice(0, maxLines);
    if (lines.length > maxLines) clipped[clipped.length - 1] = labelText(clipped[clipped.length - 1], Math.max(4, maxChars - 1));
    return clipped;
  };
  const renderWrappedText = (selection, text, { maxChars = 18, maxLines = 2, lineHeight = 15, dy = 0 } = {}) => {
    const x = selection.attr('x') ?? 0;
    selection.text(null);
    const lines = wrapWords(text, maxChars, maxLines);
    const offset = dy - ((lines.length - 1) * lineHeight) / 2;
    lines.forEach((line, index) => {
      selection.append('tspan').attr('x', x).attr('dy', index === 0 ? offset : lineHeight).text(line);
    });
  };
  const svgBase = (element, height = 340) => {
    const containerWidth = Math.floor(element.getBoundingClientRect().width || 760);
    const width = Math.max(520, containerWidth);
    const displayHeight = Math.ceil(height * Math.min(1, containerWidth / width));
    d3.select(element).selectAll('*').remove();
    const svg = d3.select(element)
      .append('svg')
      .attr('viewBox', `0 0 ${width} ${height}`)
      .attr('role', 'img')
      .attr('width', '100%')
      .attr('height', displayHeight)
      .style('display', 'block');
    return { svg, width, height };
  };
  const addTitle = (selection, text) => selection.attr('aria-label', String(text ?? ''));
  const axisBottom = (g, scale, y, ticks = 4) => g.append('g')
    .attr('transform', `translate(0,${y})`)
    .call(d3.axisBottom(scale).ticks(ticks).tickSizeOuter(0))
    .call((axis) => axis.select('.domain').attr('stroke', palette.border))
    .call((axis) => axis.selectAll('line').attr('stroke', palette.border))
    .call((axis) => axis.selectAll('text').attr('fill', palette.muted).attr('font-size', chartFont.axis));
  const axisLeft = (g, scale, x) => g.append('g')
    .attr('transform', `translate(${x},0)`)
    .call(d3.axisLeft(scale).tickSizeOuter(0))
    .call((axis) => axis.select('.domain').remove())
    .call((axis) => axis.selectAll('line').remove())
    .call((axis) => axis.selectAll('text').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', 700).each(function(d) {
      const text = d3.select(this);
      renderWrappedText(text, d, { maxChars: 19, maxLines: 2, lineHeight: 13 });
    }));

  const renderGraph = (element, payload) => {
    const nodes = arr(payload.data.nodes);
    const edges = arr(payload.data.edges);
    const columns = Math.min(Math.max(nodes.length, 1), payload.type === 'decision-map' ? 3 : 2);
    const rows = Math.max(1, Math.ceil(nodes.length / columns));
    const { svg, width } = svgBase(element, Math.max(360, rows * 145 + 110));
    const margin = { top: 32, right: 36, bottom: 54, left: 36 };
    const innerW = width - margin.left - margin.right;
    const colW = innerW / columns;
    const rowH = 140;
    const defs = svg.append('defs');
    defs.append('marker').attr('id', `${payload.id}-arrow`).attr('viewBox', '0 -5 10 10').attr('refX', 9).attr('refY', 0).attr('markerWidth', 7).attr('markerHeight', 7).attr('orient', 'auto')
      .append('path').attr('d', 'M0,-5L10,0L0,5').attr('fill', palette.claret);
    const positioned = nodes.map((node, index) => {
      const col = index % columns;
      const row = Math.floor(index / columns);
      return { ...node, x: margin.left + colW * col + colW / 2, y: margin.top + rowH * row + 40 };
    });
    const byId = new Map(positioned.map((node) => [node.id, node]));
    svg.append('g').selectAll('path').data(edges).join('path')
      .attr('d', (edge) => {
        const s = byId.get(edge.from);
        const t = byId.get(edge.to);
        if (!s || !t) return '';
        const midX = (s.x + t.x) / 2;
        return `M${s.x},${s.y + 28} C${midX},${s.y + 56} ${midX},${t.y - 56} ${t.x},${t.y - 31}`;
      })
      .attr('fill', 'none').attr('stroke', palette.claret).attr('stroke-width', 1.7).attr('opacity', 0.72).attr('marker-end', `url(#${payload.id}-arrow)`);
    const card = svg.append('g').selectAll('g').data(positioned).join('g').attr('transform', (node) => `translate(${node.x},${node.y})`);
    card.append('rect').attr('x', -82).attr('y', -31).attr('width', 164).attr('height', 62).attr('rx', 4).attr('fill', '#fff7ef').attr('stroke', (node) => colorForTone(node.tone)).attr('stroke-width', 2);
    card.append('text').attr('text-anchor', 'middle').attr('y', -4).attr('fill', palette.ink).attr('font-size', chartFont.label).attr('font-weight', 800).each(function(node) {
      renderWrappedText(d3.select(this), node.label, { maxChars: 18, maxLines: 2, lineHeight: 14, dy: -3 });
    });
    card.append('text').attr('text-anchor', 'middle').attr('y', 20).attr('fill', palette.muted).attr('font-size', chartFont.small).text((node) => labelText(node.detail, 26));
    card.each(function(node) { addTitle(d3.select(this), `${node.label}${node.detail ? ` — ${node.detail}` : ''}`); });
  };

  const renderFlow = (element, payload) => {
    const nodes = arr(payload.data.nodes).map((node, index) => ({ ...node, _index: index, _key: node.id ?? node.label ?? String(index + 1) }));
    const edges = arr(payload.data.edges);
    const edgeBetween = (source, target) => edges.find((edge) => {
      const from = edge.from ?? edge.source;
      const to = edge.to ?? edge.target;
      return (from === source._key || from === source.id || from === source.label) && (to === target._key || to === target.id || to === target.label);
    });
    const containerWidth = element.getBoundingClientRect().width || 760;
    const compact = containerWidth < 520;
    const cardH = compact ? 96 : 118;
    const gap = compact ? 18 : 34;
    const margin = compact ? { top: 14, right: 18, bottom: 18, left: 16 } : { top: 24, right: 34, bottom: 30, left: 30 };
    const { svg, width, height } = svgBase(element, Math.max(260, margin.top + margin.bottom + nodes.length * cardH + Math.max(0, nodes.length - 1) * gap));
    const railX = margin.left + (compact ? 24 : 34);
    const cardX = margin.left + (compact ? 64 : 96);
    const cardW = width - cardX - margin.right;
    const defs = svg.append('defs');
    const gradient = defs.append('linearGradient').attr('id', `${payload.id}-flow-card-bg`).attr('x1', '0%').attr('x2', '100%');
    gradient.append('stop').attr('offset', '0%').attr('stop-color', '#fff7ef');
    gradient.append('stop').attr('offset', '100%').attr('stop-color', '#fbf0e8');
    defs.append('filter').attr('id', `${payload.id}-flow-shadow`).attr('x', '-8%').attr('y', '-16%').attr('width', '116%').attr('height', '132%')
      .append('feDropShadow').attr('dx', 0).attr('dy', 2).attr('stdDeviation', 3).attr('flood-color', '#33302e').attr('flood-opacity', 0.12);
    defs.append('marker').attr('id', `${payload.id}-flow-arrow`).attr('viewBox', '0 0 10 10').attr('refX', 8.5).attr('refY', 5).attr('markerWidth', 7).attr('markerHeight', 7).attr('orient', 'auto')
      .append('path').attr('d', 'M0,0 L10,5 L0,10 Z').attr('fill', palette.claret);
    const stepY = (index) => margin.top + index * (cardH + gap);
    const connectorData = nodes.slice(0, -1).map((node, index) => ({ source: node, target: nodes[index + 1], edge: edgeBetween(node, nodes[index + 1]), index }));
    const visibleEdgeLabel = (edge) => {
      const label = String(edge?.label ?? '').trim();
      if (!label || ['therefore', 'decision', 'next'].includes(label.toLowerCase())) return null;
      return label;
    };
    const connectors = svg.append('g').selectAll('g').data(connectorData).join('g');
    connectors.append('line')
      .attr('x1', railX)
      .attr('x2', railX)
      .attr('y1', (d) => stepY(d.index) + cardH / 2 + (compact ? 18 : 24))
      .attr('y2', (d) => stepY(d.index + 1) + cardH / 2 - (compact ? 18 : 24))
      .attr('stroke', palette.claret)
      .attr('stroke-width', compact ? 2 : 2.4)
      .attr('stroke-linecap', 'round')
      .attr('marker-end', `url(#${payload.id}-flow-arrow)`);
    const connectorLabels = svg.append('g').selectAll('g').data(connectorData.filter((d) => visibleEdgeLabel(d.edge))).join('g');
    connectorLabels.append('rect')
      .attr('x', railX - 42)
      .attr('y', (d) => (stepY(d.index) + stepY(d.index + 1) + cardH) / 2 - 12)
      .attr('width', 84)
      .attr('height', 24)
      .attr('rx', 12)
      .attr('fill', palette.paper)
      .attr('stroke', palette.border);
    connectorLabels.append('text')
      .attr('x', railX)
      .attr('y', (d) => (stepY(d.index) + stepY(d.index + 1) + cardH) / 2 + 4)
      .attr('text-anchor', 'middle')
      .attr('fill', palette.claret)
      .attr('font-size', chartFont.small)
      .attr('font-weight', 900)
      .text((d) => labelText(visibleEdgeLabel(d.edge), 12));
    const railNodes = svg.append('g').selectAll('g').data(nodes).join('g').attr('transform', (_node, index) => `translate(${railX},${stepY(index) + cardH / 2})`);
    railNodes.append('circle').attr('r', compact ? 17 : 22).attr('fill', '#fff7ef').attr('stroke', (node) => colorForTone(node.tone)).attr('stroke-width', compact ? 2.4 : 3);
    railNodes.append('circle').attr('r', compact ? 12 : 16).attr('fill', (node) => colorForTone(node.tone));
    railNodes.append('text').attr('y', compact ? 4 : 5).attr('text-anchor', 'middle').attr('fill', '#fff7ef').attr('font-size', compact ? 10 : 12).attr('font-weight', 950).text((node) => node._index + 1);
    const cards = svg.append('g').selectAll('g').data(nodes).join('g').attr('transform', (_node, index) => `translate(${cardX},${stepY(index)})`);
    cards.append('rect')
      .attr('width', cardW)
      .attr('height', cardH)
      .attr('rx', 12)
      .attr('fill', (_node, index) => index === 0 ? 'rgba(15, 118, 110, 0.08)' : index === nodes.length - 1 ? 'rgba(153, 15, 61, 0.08)' : `url(#${payload.id}-flow-card-bg)`)
      .attr('stroke', (node) => colorForTone(node.tone))
      .attr('stroke-width', 1.9)
      .attr('filter', `url(#${payload.id}-flow-shadow)`);
    cards.append('rect').attr('width', compact ? 5 : 7).attr('height', cardH).attr('rx', 4).attr('fill', (node) => colorForTone(node.tone));
    const textX = compact ? 18 : 24;
    cards.append('text').attr('x', textX).attr('y', compact ? 18 : 26).attr('fill', palette.claret).attr('font-size', compact ? 8.5 : 10).attr('font-weight', 900).attr('letter-spacing', '0.08em').text((node) => node._index === nodes.length - 1 ? 'DECISION' : node.tone === 'risk' || node.tone === 'critical' || node.tone === 'high' ? 'CONSTRAINT' : 'EVIDENCE');
    cards.append('text').attr('x', textX).attr('y', compact ? 40 : 52).attr('fill', palette.ink).attr('font-size', compact ? 14.5 : 17).attr('font-weight', 950).each(function(node) {
      renderWrappedText(d3.select(this), node.label, { maxChars: Math.max(compact ? 22 : 24, Math.floor((cardW - textX * 2) / (compact ? 7.8 : 8.4))), maxLines: 2, lineHeight: compact ? 15 : 18 });
    });
    cards.append('text').attr('x', textX).attr('y', compact ? 66 : 84).attr('fill', palette.muted).attr('font-size', compact ? 10.5 : chartFont.small).attr('font-weight', 680).each(function(node) {
      renderWrappedText(d3.select(this), node.detail, { maxChars: Math.max(compact ? 34 : 40, Math.floor((cardW - textX * 2) / (compact ? 6.2 : 6.5))), maxLines: compact ? 2 : 3, lineHeight: compact ? 12 : 15 });
    });
    cards.each(function(node) { addTitle(d3.select(this), `${node._index + 1}. ${node.label}${node.detail ? ` — ${node.detail}` : ''}`); });
  };

  const firstNonEmpty = (...values) => values.find((value) => Array.isArray(value) && value.length > 0) ?? [];
  const normalizedItems = (data) => firstNonEmpty(data.items, data.nodes, data.layers, arr(data.series)[0]?.points, data.points).map((item, index) => ({ ...item, _index: index, label: item.label ?? item.name ?? item.id ?? `Item ${index + 1}`, detail: item.detail ?? item.description ?? item.summary }));

  const renderTimeline = (element, payload) => {
    const items = normalizedItems(payload.data);
    const margin = { top: 26, right: 34, bottom: 32, left: 34 };
    const rowH = 92;
    const { svg, width, height } = svgBase(element, Math.max(260, margin.top + margin.bottom + items.length * rowH));
    const railX = margin.left + 20;
    svg.append('line').attr('x1', railX).attr('x2', railX).attr('y1', margin.top + 8).attr('y2', height - margin.bottom - 8).attr('stroke', palette.claret).attr('stroke-width', 2.4).attr('opacity', 0.8);
    const rows = svg.append('g').selectAll('g').data(items).join('g').attr('transform', (_d, index) => `translate(0,${margin.top + index * rowH})`);
    rows.append('circle').attr('cx', railX).attr('cy', 28).attr('r', 9).attr('fill', (d) => colorForTone(d.tone)).attr('stroke', '#fff7ef').attr('stroke-width', 3);
    rows.append('rect').attr('x', railX + 26).attr('y', 0).attr('width', width - railX - margin.right - 26).attr('height', 68).attr('rx', 10).attr('fill', (d, index) => index % 2 === 0 ? 'rgba(153, 15, 61, 0.055)' : '#fff7ef').attr('stroke', palette.border);
    rows.append('text').attr('x', railX + 44).attr('y', 20).attr('fill', palette.claret).attr('font-size', chartFont.small).attr('font-weight', 900).text((d) => labelText(d.date ?? d.period ?? d.year ?? d.label, 24));
    rows.append('text').attr('x', railX + 44).attr('y', 42).attr('fill', palette.ink).attr('font-size', chartFont.label).attr('font-weight', 900).text((d) => labelText(d.label, 48));
    rows.append('text').attr('x', railX + 44).attr('y', 61).attr('fill', palette.muted).attr('font-size', chartFont.small).text((d) => labelText(d.detail, 86));
    rows.each(function(d) { addTitle(d3.select(this), `${d.date ?? ''} ${d.label}${d.detail ? ` — ${d.detail}` : ''}`); });
  };

  const renderStack = (element, payload) => {
    const layers = normalizedItems({ layers: payload.data.layers ?? payload.data.items ?? payload.data.nodes });
    const margin = { top: 24, right: 30, bottom: 28, left: 30 };
    const layerH = 92;
    const { svg, width, height } = svgBase(element, Math.max(280, margin.top + margin.bottom + layers.length * layerH));
    const cardW = width - margin.left - margin.right;
    const groups = svg.append('g').selectAll('g').data(layers).join('g').attr('transform', (_d, index) => `translate(${margin.left},${margin.top + index * layerH})`);
    groups.append('rect').attr('width', cardW).attr('height', 72).attr('rx', 12).attr('fill', (_d, index) => d3.interpolateRgb('#fff7ef', '#f4e6dc')(Math.min(0.85, index / Math.max(1, layers.length)))).attr('stroke', (d) => colorForTone(d.tone)).attr('stroke-width', 1.6);
    groups.append('rect').attr('width', 6).attr('height', 72).attr('rx', 3).attr('fill', (d) => colorForTone(d.tone));
    groups.append('text').attr('x', 22).attr('y', 26).attr('fill', palette.ink).attr('font-size', chartFont.label).attr('font-weight', 900).text((d) => labelText(d.label, 52));
    groups.append('text').attr('x', 22).attr('y', 48).attr('fill', palette.muted).attr('font-size', chartFont.small).text((d) => labelText(d.detail, 78));
    groups.append('text').attr('x', cardW - 20).attr('y', 42).attr('text-anchor', 'end').attr('fill', palette.claret).attr('font-size', 18).attr('font-weight', 900).text((_d, index) => String(index + 1).padStart(2, '0'));
    groups.each(function(d) { addTitle(d3.select(this), `${d.label}${d.detail ? ` — ${d.detail}` : ''}`); });
  };

  const renderLayeredLens = (element, payload) => {
    const items = normalizedItems(payload.data);
    const margin = { top: 28, right: 34, bottom: 34, left: 34 };
    const layerH = 86;
    const { svg, width, height } = svgBase(element, Math.max(300, margin.top + margin.bottom + items.length * layerH));
    const maxW = width - margin.left - margin.right;
    const groups = svg.append('g').selectAll('g').data(items).join('g').attr('transform', (_d, index) => {
      const w = maxW * (1 - index * 0.1);
      return `translate(${(width - w) / 2},${margin.top + index * layerH})`;
    });
    groups.append('rect').attr('width', (_d, index) => maxW * (1 - index * 0.1)).attr('height', 66).attr('rx', 14).attr('fill', (_d, index) => d3.interpolateRgb('#fff7ef', '#ead8cf')(index / Math.max(1, items.length - 1))).attr('stroke', (d) => colorForTone(d.tone)).attr('stroke-width', 1.7);
    groups.append('text').attr('x', 22).attr('y', 27).attr('fill', palette.claret).attr('font-size', 20).attr('font-weight', 950).text((d) => labelText(d.label, 18));
    groups.append('text').attr('x', 22).attr('y', 50).attr('fill', palette.ink).attr('font-size', chartFont.small).attr('font-weight', 750).text((d) => labelText(d.detail, 74));
    groups.each(function(d) { addTitle(d3.select(this), `${d.label}${d.detail ? ` — ${d.detail}` : ''}`); });
  };

  const renderBridge = (element, payload) => {
    const items = normalizedItems(payload.data);
    renderFlow(element, { ...payload, data: { nodes: items, edges: items.slice(0, -1).map((item, index) => ({ from: item.label, to: items[index + 1].label, label: index === 0 ? 'bridge' : 'constraint' })) } });
  };

  const renderJourneyMap = (element, payload) => {
    const items = normalizedItems(payload.data);
    const margin = { top: 34, right: 34, bottom: 46, left: 34 };
    const { svg, width, height } = svgBase(element, 360);
