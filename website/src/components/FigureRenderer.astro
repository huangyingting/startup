---
import ClaimRefs from './ClaimRefs.astro';

interface Props {
  figure: any;
  claims?: any[];
  sources?: any[];
}

const { figure, claims = [], sources = [] } = Astro.props;
const type = figure?.type ?? 'flow';
const layout = figure?.layout ?? 'standard';
const data = figure?.data ?? {};
const chartTypes = new Set(['flow', 'decision-map', 'evidence-map', 'bars', 'metric-bars', 'pie', 'waterfall', 'quadrant', 'competitive-matrix', 'matrix', 'risk-heatmap', 'sensitivity', 'xy']);
const usesCanvasChart = chartTypes.has(type);
const chartId = `chart-${String(figure?.id ?? 'figure').replace(/[^a-z0-9_-]/gi, '-')}-${Math.random().toString(36).slice(2, 9)}`;
const arr = <T = any>(value: T[] | undefined | null): T[] => Array.isArray(value) ? value : [];
const toneClass = (tone: unknown) => `tone-${String(tone ?? 'neutral').replace(/[^a-z0-9-]/gi, '-')}`;
const blockRefs = (block: any) => arr<string>(block?.claimRefs).slice(0, 6);
const timelineItems = arr(data.items);
const stackLayers = arr(data.layers ?? data.items);
const marketSizingNodes = arr(data.nodes ?? data.items);
const unitEconomicsNodes = arr(data.nodes ?? data.items);
const customerSurfaceNodes = arr(data.nodes ?? data.items);
const recommendationNodes = arr(data.nodes ?? data.items);
const transmissionNodes = arr(data.nodes ?? data.items);
const transmissionEdges = arr(data.edges);
const transmissionSourceIds = new Set(transmissionEdges.map((edge: any) => edge.from));
const transmissionTargetIds = new Set(transmissionEdges.map((edge: any) => edge.to));
const transmissionSources = transmissionNodes.filter((node: any) => !transmissionTargetIds.has(node.id));
const transmissionBridges = transmissionNodes.filter((node: any) => transmissionSourceIds.has(node.id) && transmissionTargetIds.has(node.id));
const transmissionOutcomes = transmissionNodes.filter((node: any) => transmissionTargetIds.has(node.id) && !transmissionSourceIds.has(node.id));
const moduleItems = (layer: any) => arr(layer?.modules ?? layer?.items);
const outputItems = (layer: any) => arr<string>(layer?.outputs);
const chartPayload = usesCanvasChart ? { id: chartId, type, title: figure?.title, data } : null;
---

<figure class:list={['native-figure', `figure-${type}`, `layout-${layout}`]}>
  <figcaption>{figure.id}: {figure.title}</figcaption>

  {figure.summary && <p class="figure-summary">{figure.summary}</p>}

  {type === 'timeline' && (
    <ol class="timeline-viz">
      {timelineItems.map((item: any) => (
        <li>
          <span class="timeline-marker">{item.date ?? item.label}</span>
          <strong>{item.label}</strong>
          {item.detail && <p>{item.detail}</p>}
        </li>
      ))}
    </ol>
  )}

  {(type === 'flow' || type === 'decision-map' || type === 'evidence-map') && <div id={chartId} class="echart-figure chart-relationship" data-chart-type={type}></div>}

  {(type === 'bars' || type === 'metric-bars' || type === 'pie' || type === 'waterfall') && <div id={chartId} class="echart-figure chart-bars" data-chart-type={type}></div>}

  {(type === 'quadrant' || type === 'competitive-matrix') && (
    <div id={chartId} class="echart-figure chart-quadrant" data-chart-type={type}></div>
  )}

  {(type === 'matrix' || type === 'risk-heatmap') && <div id={chartId} class="echart-figure chart-heatmap" data-chart-type={type}></div>}

  {type === 'stack' && (
    <div class="stack-viz">
      {stackLayers.map((layer: any) => (
        <article class:list={['stack-layer', toneClass(layer.tone)]}>
          <span></span>
          <strong>{layer.label}</strong>
          {layer.detail && <p>{layer.detail}</p>}
        </article>
      ))}
    </div>
  )}

  {type === 'market-sizing-lens' && (
    <div class="market-sizing-viz" aria-label={`${figure.title} market sizing lens`}>
      <div class="market-sizing-axis">
        <span>Broad market envelope</span>
        <span>Served footprint</span>
      </div>
      <div class="market-sizing-stack">
        {marketSizingNodes.map((node: any, index: number) => {
          const label = String(node.label ?? node.id ?? 'Layer');
          const width = index === 0 ? '100%' : index === 1 ? '86%' : index === 2 ? '68%' : '76%';
          return (
            <article class:list={['market-layer', `layer-${index + 1}`, toneClass(node.tone)]} style={`--market-layer-width: ${width}`}>
              <div class="market-layer-head">
                <span>{label}</span>
                <strong>{label === 'TAM' ? 'Addressable universe' : label === 'SAM' ? 'Commercially reachable market' : label === 'SOM' ? 'Evidence-backed served footprint' : node.label}</strong>
              </div>
              {node.detail && <p>{node.detail}</p>}
            </article>
          );
        })}
      </div>
      <div class="market-sizing-warning">
        <strong>No unsupported market math</strong>
        <p>Dollar TAM/SAM/SOM values stay out of the chart unless the evidence ledger contains a defensible source.</p>
      </div>
    </div>
  )}

  {type === 'unit-economics-waterfall' && (
    <div class="unit-economics-viz" aria-label={`${figure.title} unit economics waterfall`}>
      <section class="unit-anchor-card">
        <span>Public anchor</span>
        <strong>{unitEconomicsNodes[0]?.label ?? 'Known input'}</strong>
        {unitEconomicsNodes[0]?.detail && <p>{unitEconomicsNodes[0].detail}</p>}
      </section>
      <div class="unit-waterfall-chain">
        {unitEconomicsNodes.slice(1).map((node: any, index: number) => {
          const isOutcome = index === unitEconomicsNodes.slice(1).length - 1;
          return (
            <article class:list={['unit-step-card', toneClass(node.tone), isOutcome && 'is-outcome']}>
              <div class="unit-step-kicker">
                <span>{String(index + 2).padStart(2, '0')}</span>
                <em>{isOutcome ? 'Underwriting blocker' : 'Missing bridge'}</em>
              </div>
              <strong>{node.label}</strong>
              {node.detail && <p>{node.detail}</p>}
            </article>
          );
        })}
      </div>
    </div>
  )}

  {type === 'customer-surface-map' && (
    <div class="customer-surface-viz" aria-label={`${figure.title} customer surface map`}>
      {customerSurfaceNodes.map((node: any, index: number) => {
        let role = 'expansion';
        if (index === 0) role = 'entry';
        else if (index < 3) role = 'segment';
        return (
          <article class:list={['customer-surface-card', `surface-${role}`, `surface-${index + 1}`, toneClass(node.tone)]}>
            <div class="surface-kicker">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <em>{role === 'entry' ? 'Acquisition surface' : role === 'segment' ? 'Customer segment' : 'Expansion loop'}</em>
            </div>
            <strong>{node.label}</strong>
            {node.detail && <p>{node.detail}</p>}
          </article>
        );
      })}
    </div>
  )}

  {type === 'architecture-stack' && (
    <div class="architecture-viz" aria-label={`${figure.title} architecture diagram`}>
      {stackLayers.map((layer: any, index: number) => (
        <article class:list={['arch-layer', toneClass(layer.tone)]}>
          <div class="arch-layer-head">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{layer.label}</strong>
            {layer.detail && <p>{layer.detail}</p>}
          </div>
          <div class="arch-layer-body">
            {moduleItems(layer).length > 0 ? (
              <div class="arch-modules">
                {moduleItems(layer).map((module: any) => (
                  <section class:list={['arch-module', toneClass(module.tone ?? layer.tone)]}>
                    <strong>{module.label ?? module}</strong>
                    {module.detail && <p>{module.detail}</p>}
                  </section>
                ))}
              </div>
            ) : layer.detail ? (
              <p class="arch-detail">{layer.detail}</p>
            ) : null}
            {outputItems(layer).length > 0 && (
              <ul class="arch-outputs" aria-label="Layer outputs">
                {outputItems(layer).map((output) => <li>{output}</li>)}
              </ul>
            )}
          </div>
        </article>
      ))}
    </div>
  )}

  {type === 'recommendation-logic' && (
    <div class="recommendation-viz" aria-label={`${figure.title} recommendation logic`}>
      {recommendationNodes.map((node: any, index: number) => {
        const isOutcome = /recommendation|decision|outcome/i.test(String(node.label ?? '')) || index === recommendationNodes.length - 1;
        return (
          <article class:list={['logic-card', toneClass(node.tone), isOutcome && 'is-outcome']}>
            <div class="logic-kicker">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <em>{isOutcome ? 'Decision' : node.tone === 'risk' || node.tone === 'critical' || node.tone === 'high' ? 'Constraint' : 'Evidence'}</em>
            </div>
            <strong>{node.label}</strong>
            {node.detail && <p>{node.detail}</p>}
          </article>
        );
      })}
    </div>
  )}

  {type === 'risk-transmission-map' && (
    <div class="risk-transmission-viz" aria-label={`${figure.title} risk transmission map`}>
      <section class="risk-column risk-inputs">
        <div class="risk-column-head"><span>01</span><strong>Risk sources</strong></div>
        <div class="risk-card-list">
          {transmissionSources.map((node: any) => (
            <article class:list={['risk-card', toneClass(node.tone)]}>
              <strong>{node.label}</strong>
              {node.detail && <p>{node.detail}</p>}
            </article>
          ))}
        </div>
      </section>
      <section class="risk-column risk-bridge">
        <div class="risk-column-head"><span>02</span><strong>Transmission pressure</strong></div>
        <div class="risk-card-list">
          {(transmissionBridges.length ? transmissionBridges : transmissionNodes.slice(-2, -1)).map((node: any) => (
            <article class:list={['risk-card', 'is-bridge', toneClass(node.tone)]}>
              <strong>{node.label}</strong>
              {node.detail && <p>{node.detail}</p>}
            </article>
          ))}
        </div>
      </section>
      <section class="risk-column risk-outcomes">
        <div class="risk-column-head"><span>03</span><strong>Underwriting impact</strong></div>
        <div class="risk-card-list">
          {(transmissionOutcomes.length ? transmissionOutcomes : transmissionNodes.slice(-1)).map((node: any) => (
            <article class:list={['risk-card', 'is-outcome', toneClass(node.tone)]}>
              <strong>{node.label}</strong>
              {node.detail && <p>{node.detail}</p>}
            </article>
          ))}
        </div>
      </section>
    </div>
  )}

  {(type === 'sensitivity' || type === 'xy') && <div id={chartId} class="echart-figure chart-sensitivity" data-chart-type={type}></div>}

  {type === 'other' && (
    <div class="figure-fallback" role="note">
      <strong>Structured figure data available</strong>
      <p>This figure type does not yet have a dedicated renderer. Use a semantic type such as <code>recommendation-logic</code>, <code>risk-transmission-map</code>, <code>architecture-stack</code>, <code>risk-heatmap</code>, <code>metric-bars</code>, or <code>xy</code> for automatic visual rendering.</p>
    </div>
  )}

  {figure.approximationNotes && <p class="figure-note">{figure.approximationNotes}</p>}
  <ClaimRefs refs={blockRefs(figure)} claims={claims} sources={sources} />
  {chartPayload && <script type="application/json" class="figure-chart-data" set:html={JSON.stringify(chartPayload)}></script>}
</figure>

<script>
  import * as echarts from 'echarts/core';
  import { BarChart, GraphChart, HeatmapChart, ScatterChart } from 'echarts/charts';
  import { GridComponent, MarkLineComponent, TooltipComponent, VisualMapComponent } from 'echarts/components';
  import { CanvasRenderer } from 'echarts/renderers';

  echarts.use([BarChart, GraphChart, HeatmapChart, ScatterChart, GridComponent, MarkLineComponent, TooltipComponent, VisualMapComponent, CanvasRenderer]);

  const palette = {
    claret: '#990f3d',
    ink: '#33302e',
    muted: '#6b625c',
    border: '#d8ccc2',
    paper: '#fff7ef',
    positive: '#0f766e',
    risk: '#b42318',
    opportunity: '#b8860b',
    neutral: '#990f3d',
  };

  const arr = (value) => Array.isArray(value) ? value : [];
  const colorForTone = (tone) => {
    if (tone === 'positive' || tone === 'low') return palette.positive;
    if (tone === 'risk' || tone === 'critical' || tone === 'high') return palette.risk;
    if (tone === 'opportunity') return palette.opportunity;
    return palette.neutral;
  };
  const riskValue = (tone) => {
    if (tone === 'high' || tone === 'critical' || tone === 'risk') return 3;
    if (tone === 'medium' || tone === 'neutral') return 2;
    return 1;
  };
  const baseText = {
    fontFamily: 'Mona Sans, Noto Sans SC, sans-serif',
    color: palette.ink,
  };
  const chartFont = {
    axis: 14,
    label: 14,
    heatmap: 13,
    tooltip: 14,
  };
  const axisStyle = {
    axisLine: { lineStyle: { color: palette.border } },
    axisTick: { lineStyle: { color: palette.border } },
    axisLabel: { color: palette.muted, fontSize: chartFont.axis },
    splitLine: { lineStyle: { color: '#eaded4' } },
  };
  const tooltip = {
    trigger: 'item',
    confine: true,
    backgroundColor: '#fff7ef',
    borderColor: palette.border,
    textStyle: { color: palette.ink, fontSize: chartFont.tooltip },
  };
  const labelText = (text, max = 24) => String(text ?? '').length > max ? `${String(text).slice(0, max - 1)}…` : String(text ?? '');
  const numberValue = (value) => Number(value) || 0;
  const valueLabel = (item) => item?.displayValue ?? item?.value ?? '';

  const graphOption = (payload) => {
    const nodes = arr(payload.data.nodes);
    const edges = arr(payload.data.edges);
    const columns = Math.min(Math.max(nodes.length, 1), payload.type === 'decision-map' ? 5 : 4);
    const chartNodes = nodes.map((node, index) => {
      const col = index % columns;
      const row = Math.floor(index / columns);
      return {
        id: node.id,
        name: node.label,
        value: node.detail,
        x: col * 210,
        y: row * 135,
        symbolSize: 54,
        itemStyle: { color: colorForTone(node.tone), borderColor: '#fff7ef', borderWidth: 3 },
        label: { show: true, formatter: labelText(node.label, 26), color: palette.ink, fontSize: chartFont.label, fontWeight: 700, position: 'bottom', width: 172, overflow: 'break' },
        tooltip: { formatter: `<strong>${node.label}</strong><br/>${node.detail ?? ''}` },
      };
    });
    return {
      textStyle: baseText,
      tooltip,
      animationDuration: 500,
      grid: { left: 8, right: 8, top: 8, bottom: 8 },
      series: [{
        type: 'graph',
        layout: 'none',
        coordinateSystem: null,
        roam: false,
        draggable: false,
        edgeSymbol: ['none', 'arrow'],
        edgeSymbolSize: [0, 11],
        symbol: 'rect',
        data: chartNodes,
        links: edges.map((edge) => ({ source: edge.from, target: edge.to, label: { show: Boolean(edge.label), formatter: edge.label, color: palette.muted, fontSize: chartFont.heatmap }, lineStyle: { color: palette.claret, width: 1.6, curveness: 0.08 } })),
        lineStyle: { color: palette.claret, width: 1.6, opacity: 0.75, curveness: 0.08 },
        emphasis: { focus: 'adjacency' },
      }],
    };
  };

  const barOption = (payload) => {
    const items = arr(payload.data.items).length ? arr(payload.data.items) : arr(arr(payload.data.series)[0]?.points);
    const isMetric = payload.type === 'metric-bars';
    return {
      textStyle: baseText,
      tooltip,
      grid: { left: isMetric ? 172 : 150, right: 62, top: 12, bottom: 22 },
      xAxis: { type: 'value', ...axisStyle },
      yAxis: { type: 'category', data: items.map((item) => item.label), inverse: true, axisLabel: { color: palette.ink, fontSize: chartFont.axis, width: 172, overflow: 'truncate' }, axisLine: { show: false }, axisTick: { show: false } },
      series: [{
        type: 'bar',
        data: items.map((item) => ({ value: numberValue(item.value), itemStyle: { color: colorForTone(item.tone) }, label: { formatter: valueLabel(item) } })),
        barWidth: isMetric ? 20 : 18,
        itemStyle: { borderColor: palette.paper, borderWidth: 1 },
        label: { show: true, position: 'right', color: palette.ink, fontFamily: 'Mona Sans, Noto Sans SC, sans-serif', fontSize: chartFont.label, fontWeight: isMetric ? 800 : 650 },
      }],
    };
  };

  const waterfallOption = (payload) => {
    const items = arr(payload.data.items);
    let running = 0;
    const bases = [];
    const values = [];
    items.forEach((item) => {
      const value = numberValue(item.value);
      const start = Math.min(running, running + value);
      bases.push(start);
      values.push({ value: Math.abs(value), rawValue: value, label: { formatter: valueLabel(item) }, itemStyle: { color: value < 0 ? palette.risk : colorForTone(item.tone) } });
      running += value;
    });
    return {
      textStyle: baseText,
      tooltip: { ...tooltip, formatter: (params) => `<strong>${params.name}</strong><br/>${params.data?.rawValue ?? params.value}` },
      grid: { left: 50, right: 32, top: 18, bottom: 72 },
      xAxis: { type: 'category', data: items.map((item) => item.label), axisLabel: { color: palette.ink, fontSize: chartFont.axis, interval: 0, width: 118, overflow: 'break', lineHeight: 18 }, axisLine: { lineStyle: { color: palette.border } }, axisTick: { show: false } },
      yAxis: { type: 'value', ...axisStyle },
      series: [
        { type: 'bar', stack: 'total', data: bases, itemStyle: { color: 'transparent' }, emphasis: { disabled: true }, silent: true },
        { type: 'bar', stack: 'total', data: values, barWidth: 24, label: { show: true, position: 'top', color: palette.ink, fontSize: chartFont.label, fontWeight: 700 } },
      ],
    };
  };

  const quadrantOption = (payload) => {
    const points = arr(payload.data.points);
    return {
      textStyle: baseText,
      tooltip,
      grid: { left: 44, right: 28, top: 24, bottom: 44 },
      xAxis: { min: 0, max: 100, name: payload.data.xAxis ?? 'X', nameLocation: 'middle', nameGap: 28, ...axisStyle },
      yAxis: { min: 0, max: 100, name: payload.data.yAxis ?? 'Y', nameLocation: 'middle', nameGap: 32, ...axisStyle },
      series: [{
        type: 'scatter',
        symbolSize: 24,
        data: points.map((point) => ({ name: point.label, value: [Number(point.x) || 50, Number(point.y) || 50], itemStyle: { color: colorForTone(point.tone) }, label: { formatter: point.label } })),
        label: { show: true, position: 'right', color: palette.ink, fontSize: chartFont.label, fontWeight: 700 },
        markLine: { silent: true, symbol: 'none', lineStyle: { color: palette.border, type: 'dashed' }, data: [{ xAxis: 50 }, { yAxis: 50 }] },
      }],
    };
  };

  const heatmapOption = (payload) => {
    const columns = arr(payload.data.columns);
    const rows = arr(payload.data.rows);
    const cells = [];
    const heatColors = {
      1: '#dcebe7',
      2: '#f2d8a0',
      3: '#c94f43',
    };
    const heatTextColors = {
      1: palette.ink,
      2: palette.ink,
      3: '#fff7ef',
    };
    const riskLabel = (value) => value >= 3 ? 'High' : value === 2 ? 'Medium' : 'Low';
    const rowLabelWidth = Math.min(196, Math.max(128, Math.max(...rows.map((row) => String(row.label ?? '').length), 8) * 8));
    rows.forEach((row, rowIndex) => arr(row.values).forEach((cell, colIndex) => {
      const value = riskValue(cell.tone);
      const label = cell.label ?? cell;
      cells.push({
        value: [colIndex, rowIndex, value, label, cell.tone ?? riskLabel(value).toLowerCase(), row.label ?? '', columns[colIndex] ?? ''],
        itemStyle: {
          color: heatColors[value],
          borderColor: '#fff7ef',
          borderWidth: 4,
          borderRadius: 7,
        },
        label: {
          color: heatTextColors[value],
          fontWeight: value >= 2 ? 800 : 650,
        },
      });
    }));
    return {
      textStyle: baseText,
      backgroundColor: '#fff7ef',
      tooltip: {
        ...tooltip,
        extraCssText: 'box-shadow: none; border-radius: 0; line-height: 1.45;',
        formatter: (params) => {
          const value = params.value ?? [];
          const severity = riskLabel(Number(value[2]) || 1);
          return `<strong>${value[5] ?? ''} × ${value[6] ?? ''}</strong><br/><span style="color:${palette.muted}">${severity} signal</span><br/>${value[3] ?? ''}`;
        },
      },
      grid: { left: rowLabelWidth, right: 22, top: 42, bottom: 38, containLabel: false },
      xAxis: {
        type: 'category',
        data: columns,
        position: 'top',
        axisLabel: { color: palette.ink, fontSize: chartFont.axis, fontWeight: 800, margin: 12, interval: 0, width: 118, overflow: 'break', lineHeight: 18 },
        axisLine: { show: false },
        axisTick: { show: false },
        splitArea: { show: true, areaStyle: { color: ['rgba(255,241,229,.38)', 'rgba(255,247,239,.44)'] } },
      },
      yAxis: {
        type: 'category',
        data: rows.map((row) => row.label),
        inverse: true,
        axisLabel: { color: palette.ink, fontSize: chartFont.axis, fontWeight: 800, margin: 14, width: rowLabelWidth - 18, overflow: 'break', lineHeight: 18 },
        axisLine: { show: false },
        axisTick: { show: false },
        splitArea: { show: true, areaStyle: { color: ['rgba(255,247,239,.34)', 'rgba(255,241,229,.42)'] } },
      },
      visualMap: { show: false, min: 1, max: 3, inRange: { color: [heatColors[1], heatColors[2], heatColors[3]] } },
      series: [{
        type: 'heatmap',
        data: cells,
        label: { show: true, formatter: (params) => labelText(params.value?.[3], 34), fontSize: chartFont.heatmap, lineHeight: 18, overflow: 'break' },
        emphasis: { itemStyle: { shadowBlur: 0, borderColor: palette.claret, borderWidth: 2 } },
      }],
    };
  };

  const sensitivityOption = (payload) => {
    const series = arr(payload.data.series)[0] ?? {};
    const points = arr(series.points);
    return {
      textStyle: baseText,
      tooltip,
      grid: { left: 122, right: 54, top: 22, bottom: 24 },
      xAxis: { type: 'value', ...axisStyle },
      yAxis: { type: 'category', data: points.map((point) => point.label), inverse: true, axisLabel: { color: palette.ink, fontSize: chartFont.axis, width: 156, overflow: 'truncate' }, axisLine: { show: false }, axisTick: { show: false } },
      series: [{ type: 'bar', data: points.map((point) => ({ value: Number(point.value) || 0, label: { formatter: point.displayValue ?? point.value } })), barWidth: 20, itemStyle: { color: palette.claret }, label: { show: true, position: 'right', color: palette.ink, fontSize: chartFont.label } }],
    };
  };

  const xyOption = (payload) => {
    const points = arr(payload.data.points).length ? arr(payload.data.points) : arr(arr(payload.data.series)[0]?.points);
    return {
      textStyle: baseText,
      tooltip: { ...tooltip, formatter: (params) => `<strong>${params.name}</strong><br/>x: ${params.value?.[0] ?? ''}<br/>y: ${params.value?.[1] ?? ''}` },
      grid: { left: 54, right: 32, top: 28, bottom: 50 },
      xAxis: { type: 'value', name: payload.data.xAxis ?? 'X', nameLocation: 'middle', nameGap: 32, ...axisStyle },
      yAxis: { type: 'value', name: payload.data.yAxis ?? 'Y', nameLocation: 'middle', nameGap: 38, ...axisStyle },
      series: [{
        type: 'scatter',
        symbolSize: 24,
        data: points.map((point) => ({ name: point.label, value: [numberValue(point.x ?? point.value?.[0]), numberValue(point.y ?? point.value?.[1])], itemStyle: { color: colorForTone(point.tone) } })),
        label: { show: true, position: 'right', color: palette.ink, fontSize: chartFont.label, fontWeight: 700, formatter: (params) => labelText(params.name, 22) },
      }],
    };
  };

  const optionFor = (payload) => {
    if (['flow', 'decision-map', 'evidence-map'].includes(payload.type)) return graphOption(payload);
    if (payload.type === 'waterfall') return waterfallOption(payload);
    if (['bars', 'metric-bars', 'pie'].includes(payload.type)) return barOption(payload);
    if (['quadrant', 'competitive-matrix'].includes(payload.type)) return quadrantOption(payload);
