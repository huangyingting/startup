  const firstNonEmpty = (...values) => values.find((value) => Array.isArray(value) && value.length > 0) ?? [];
  const normalizedItems = (data) => firstNonEmpty(data.items, data.nodes, data.layers, arr(data.series)[0]?.points, data.points).map((item, index) => ({ ...item, _index: index, label: item.label ?? item.name ?? item.id ?? `Item ${index + 1}`, detail: item.detail ?? item.description ?? item.summary }));

  const renderTimeline = (element, payload) => {
    const items = normalizedItems(payload.data);
    const margin = { top: 26, right: 34, bottom: 32, left: 34 };
    const containerWidth = Math.floor(element.getBoundingClientRect().width || 760);
    const width = Math.max(containerWidth < 420 ? 420 : 520, containerWidth);
    const { svg } = svgBase(element, 260);
    const railX = margin.left + 20;
    const cardX = railX + 26;
    const cardW = width - railX - margin.right - 26;
    const textX = railX + 44;
    const textW = Math.max(80, cardW - 36);
    const measureText = svg.append('text').attr('visibility', 'hidden').attr('x', -9999).attr('y', -9999);
    const measuredWidth = (value) => {
      measureText.text(String(value ?? ''));
      return measureText.node()?.getComputedTextLength?.() ?? String(value ?? '').length * 8;
    };
    const splitTokenBySvgWidth = (token) => {
      const chunks = [];
      let chunk = '';
      Array.from(String(token ?? '')).forEach((char) => {
        const next = `${chunk}${char}`;
        if (chunk && measuredWidth(next) > textW) {
          chunks.push(chunk);
          chunk = char;
        } else {
          chunk = next;
        }
      });
      if (chunk) chunks.push(chunk);
      return chunks;
    };
    const wrapWithSvgMeasure = (text, { fontSize, fontWeight }) => {
      measureText.attr('font-size', fontSize).attr('font-weight', fontWeight).attr('font-family', chartFont.family);
      const tokens = String(text ?? '').split(/\s+/).filter(Boolean);
      if (!tokens.length) return [''];
      const lines = [];
      let line = '';
      tokens.flatMap((token) => measuredWidth(token) > textW ? splitTokenBySvgWidth(token) : token).forEach((token) => {
        const next = line ? `${line} ${token}` : token;
        if (line && measuredWidth(next) > textW) {
          lines.push(line);
          line = token;
        } else {
          line = next;
        }
      });
      if (line) lines.push(line);
      return lines;
    };
    const rowGap = 24;
    let cursorY = margin.top;
    const rowsData = items.map((item) => {
      const dateLines = wrapWithSvgMeasure(item.date ?? item.period ?? item.year ?? item.label, { fontSize: chartFont.small, fontWeight: 900 });
      const labelLines = wrapWithSvgMeasure(item.label, { fontSize: chartFont.label, fontWeight: 900 });
      const detailLines = wrapWithSvgMeasure(item.detail, { fontSize: chartFont.small, fontWeight: 400 });
      const cardH = Math.max(78, 18 + dateLines.length * 15 + 8 + labelLines.length * 18 + 8 + detailLines.length * 15 + 16);
      const row = { ...item, dateLines, labelLines, detailLines, cardH, y: cursorY };
      cursorY += cardH + rowGap;
      return row;
    });
    const totalHeight = Math.max(260, cursorY - rowGap + margin.bottom);
    const displayHeight = Math.ceil(totalHeight * Math.min(1, containerWidth / width));
    svg.attr('viewBox', `0 0 ${width} ${totalHeight}`).attr('height', displayHeight);
    measureText.remove();
    svg.append('line').attr('x1', railX).attr('x2', railX).attr('y1', margin.top + 8).attr('y2', totalHeight - margin.bottom - 8).attr('stroke', palette.claret).attr('stroke-width', 2.4).attr('opacity', 0.8);
    const rows = svg.append('g').selectAll('g').data(rowsData).join('g').attr('transform', (d) => `translate(0,${d.y})`);
    rows.append('circle').attr('cx', railX).attr('cy', (d) => Math.min(32, d.cardH / 2)).attr('r', 9).attr('fill', (d) => colorForTone(d.tone)).attr('stroke', '#fff7ef').attr('stroke-width', 3);
    rows.append('rect').attr('x', cardX).attr('y', 0).attr('width', cardW).attr('height', (d) => d.cardH).attr('rx', 10).attr('fill', (d, index) => index % 2 === 0 ? 'rgba(153, 15, 61, 0.055)' : '#fff7ef').attr('stroke', palette.border);
    rows.append('text').attr('fill', palette.claret).attr('font-size', chartFont.small).attr('font-weight', fontWeight('label')).each(function(d) {
      renderLineBlock(d3.select(this), d.dateLines, { x: textX, y: 20, lineHeight: chartFont.lineHeight.small });
    });
    rows.append('text').attr('fill', palette.ink).attr('font-size', chartFont.label).attr('font-weight', fontWeight('label')).each(function(d) {
      renderLineBlock(d3.select(this), d.labelLines, { x: textX, y: 20 + d.dateLines.length * chartFont.lineHeight.small + 10, lineHeight: chartFont.lineHeight.title });
