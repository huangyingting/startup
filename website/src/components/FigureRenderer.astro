      .attr('letter-spacing', chartFont.tracking.subtle)
      .text('Waterfall bridge');
    svg.append('text')
      .attr('x', width - margin.right - 10)
      .attr('y', margin.top - 18)
      .attr('text-anchor', 'end')
      .attr('fill', palette.muted)
      .attr('font-size', chartFont.small)
      .attr('font-weight', fontWeight('strong'))
      .text(`${labelText(points[0]?.label ?? 'Start', 14)} → ${labelText(points.at(-1)?.label ?? 'End', 14)}`);
    axisLeft(svg, y, margin.left);
    svg.selectAll('.tick text').attr('font-size', chartFont.small);
    const connectors = points.slice(0, -1).map((point, index) => ({ from: point, to: points[index + 1] }));
    svg.append('g').selectAll('line.waterfall-connector').data(connectors).join('line')
      .attr('class', 'waterfall-connector')
      .attr('x1', (d) => x(d.from.label) + x.bandwidth())
      .attr('x2', (d) => x(d.to.label))
      .attr('y1', (d) => y(d.from.to))
      .attr('y2', (d) => y(d.from.to))
      .attr('stroke', palette.muted)
      .attr('stroke-width', 1.4)
      .attr('stroke-dasharray', '5 5')
      .attr('opacity', 0.7);
    const bars = svg.append('g').selectAll('g.waterfall-step').data(points).join('g')
      .attr('class', 'waterfall-step');
    bars.append('rect')
      .attr('class', (d) => `waterfall-bar ${d.isTotal ? 'waterfall-total' : d.value < 0 ? 'waterfall-negative' : 'waterfall-positive'}`)
      .attr('x', (d) => x(d.label))
      .attr('width', x.bandwidth())
      .attr('y', (d) => y(d.high))
      .attr('height', (d) => Math.max(4, y(d.low) - y(d.high)))
      .attr('fill', (d) => d.isTotal ? palette.claret : d.value < 0 ? palette.risk : colorForTone(d.tone ?? 'positive'))
      .attr('stroke', '#fff7ef')
      .attr('stroke-width', 2.5)
      .attr('rx', 8);
    bars.append('text')
      .attr('x', (d) => x(d.label) + x.bandwidth() / 2)
