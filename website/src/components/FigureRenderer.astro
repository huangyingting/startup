  const renderQuadrant = (element, payload) => {
    const points = arr(payload.data.points);
    const xAxisLabel = payload.data.xAxis ?? payload.data.xLabel ?? payload.data.x ?? (payload.type === 'positioning-map' ? 'Distribution leverage' : 'X');
    const yAxisLabel = payload.data.yAxis ?? payload.data.yLabel ?? payload.data.y ?? (payload.type === 'positioning-map' ? 'Workflow depth' : 'Y');
    const xs = points.map((p) => Number(p.x)).filter(Number.isFinite);
    const ys = points.map((p) => Number(p.y)).filter(Number.isFinite);
    const allValues = [...xs, ...ys];
    const finiteMin = allValues.length ? Math.min(...allValues) : 0;
    const finiteMax = allValues.length ? Math.max(...allValues) : 100;
    const isTenPointScore = finiteMin >= 0 && finiteMax <= 10;
    const isUnitScore = finiteMin >= 0 && finiteMax <= 1;
    const referenceValue = isTenPointScore ? 5 : isUnitScore ? 0.5 : 50;
    const safeRange = (vals) => {
      if (vals.length === 0) return isTenPointScore ? { min: 0, max: 10 } : isUnitScore ? { min: 0, max: 1 } : { min: 0, max: 100 };
      if (isTenPointScore) return { min: 0, max: 10 };
      if (isUnitScore) return { min: 0, max: 1 };
      const lo = Math.min(...vals);
      const hi = Math.max(...vals);
      const padBase = Math.max((hi - lo) * 0.18, 6);
      let min = Math.floor((lo - padBase) / 5) * 5;
      let max = Math.ceil((hi + padBase) / 5) * 5;
      // For 0-100-style scores, keep the midpoint reference visible when relevant.
      if (lo >= referenceValue) min = Math.min(min, referenceValue - 5);
      if (hi <= referenceValue) max = Math.max(max, referenceValue + 5);
      min = Math.max(0, min);
      max = Math.min(100, max);
      if (max - min < 20) {
        const center = (min + max) / 2;
        min = Math.max(0, Math.floor((center - 10) / 5) * 5);
        max = Math.min(100, Math.ceil((center + 10) / 5) * 5);
      }
      return { min, max };
    };
    const xRange = safeRange(xs);
    const yRange = safeRange(ys);
    const { svg, width, height } = svgBase(element, Math.max(380, points.length * 28 + 130));
    const margin = { top: 34, right: 190, bottom: 64, left: 62 };
    const x = d3.scaleLinear().domain([xRange.min, xRange.max]).range([margin.left, width - margin.right]);
    const y = d3.scaleLinear().domain([yRange.min, yRange.max]).range([height - margin.bottom, margin.top]);
    svg.append('rect').attr('x', margin.left).attr('y', margin.top).attr('width', width - margin.left - margin.right).attr('height', height - margin.top - margin.bottom).attr('fill', 'rgba(153, 15, 61, 0.025)').attr('stroke', palette.border);
    if (xRange.min < referenceValue && xRange.max > referenceValue) svg.append('line').attr('x1', x(referenceValue)).attr('x2', x(referenceValue)).attr('y1', margin.top).attr('y2', height - margin.bottom).attr('stroke', palette.border).attr('stroke-dasharray', '4 4');
    if (yRange.min < referenceValue && yRange.max > referenceValue) svg.append('line').attr('x1', margin.left).attr('x2', width - margin.right).attr('y1', y(referenceValue)).attr('y2', y(referenceValue)).attr('stroke', palette.border).attr('stroke-dasharray', '4 4');
    axisBottom(svg, x, height - margin.bottom);
    axisLeft(svg, y, margin.left);
    svg.append('text').attr('x', width / 2).attr('y', height - 18).attr('text-anchor', 'middle').attr('fill', palette.muted).attr('font-size', chartFont.axis).attr('font-weight', 800).text(xAxisLabel);
    svg.append('text').attr('transform', `translate(18,${height / 2}) rotate(-90)`).attr('text-anchor', 'middle').attr('fill', palette.muted).attr('font-size', chartFont.axis).attr('font-weight', 800).text(yAxisLabel);
    const plotPoints = points.map((point, index) => {
      const targetX = x(numberValue(point.x));
      const targetY = y(numberValue(point.y));
      return { ...point, _index: index, _valueX: point.x, _valueY: point.y, _targetX: targetX, _targetY: targetY, x: targetX, y: targetY };
    });
    d3.forceSimulation(plotPoints)
      .force('x', d3.forceX((d) => d._targetX).strength(0.28))
      .force('y', d3.forceY((d) => d._targetY).strength(0.28))
      .force('collide', d3.forceCollide(14))
      .stop()
      .tick(90);
    plotPoints.forEach((point) => {
      point.x = Math.max(margin.left + 14, Math.min(width - margin.right - 14, point.x));
      point.y = Math.max(margin.top + 14, Math.min(height - margin.bottom - 14, point.y));
    });
    const dots = svg.append('g').selectAll('g').data(plotPoints).join('g').attr('transform', (d) => `translate(${d.x},${d.y})`);
    dots.append('circle').attr('r', 11).attr('fill', (d) => colorForTone(d.tone)).attr('stroke', '#fff7ef').attr('stroke-width', 2);
    dots.append('text').attr('text-anchor', 'middle').attr('dominant-baseline', 'middle').attr('fill', '#fff7ef').attr('font-size', 11).attr('font-weight', 900).text((d) => d._index + 1);
    dots.each(function(d) { addTitle(d3.select(this), `${d.label}: ${xAxisLabel} ${d._valueX}; ${yAxisLabel} ${d._valueY}`); });
    withTooltip(dots, (d) => tooltipHtml(d.label, [`${xAxisLabel}: ${d._valueX}`, `${yAxisLabel}: ${d._valueY}`, d.detail]));
    const legendX = width - margin.right + 24;
    const legend = svg.append('g').attr('transform', `translate(${legendX},${margin.top + 6})`);
    legend.append('text').attr('x', 0).attr('y', 0).attr('fill', palette.muted).attr('font-size', chartFont.small).attr('font-weight', 900).text('Points');
    const legendRows = legend.selectAll('g').data(points.map((point, index) => ({ ...point, _index: index }))).join('g').attr('transform', (_d, index) => `translate(0,${20 + index * 26})`);
    legendRows.append('circle').attr('cx', 6).attr('cy', -4).attr('r', 7).attr('fill', (d) => colorForTone(d.tone));
    legendRows.append('text').attr('x', 6).attr('y', 0).attr('text-anchor', 'middle').attr('fill', '#fff7ef').attr('font-size', 8).attr('font-weight', 900).text((d) => d._index + 1);
    legendRows.append('text').attr('x', 20).attr('y', 0).attr('fill', palette.ink).attr('font-size', chartFont.small).attr('font-weight', 800).text((d) => labelText(d.label, 20));
    withTooltip(legendRows, (d) => tooltipHtml(d.label, [`${xAxisLabel}: ${d.x}`, `${yAxisLabel}: ${d.y}`, d.detail]));
  };

  const renderHeatmap = (element, payload) => {
