---
import ClaimRefs from './ClaimRefs.astro';

interface Props {
  figure: any;
  claims?: any[];
  sources?: any[];
}

const { figure, claims = [], sources = [] } = Astro.props;
const type = figure?.type ?? 'flow';
const layout = figure?.layout ?? 'standard';
const data = figure?.data ?? {};
const chartTypes = new Set(['flow', 'decision-map', 'evidence-map', 'scenario-tree', 'dependency-map', 'bars', 'waterfall', 'funnel', 'range', 'quadrant', 'positioning-map', 'matrix', 'heatmap', 'cohort', 'sensitivity', 'scatter']);
const usesD3Chart = chartTypes.has(type);
const chartId = `chart-${String(figure?.id ?? 'figure').replace(/[^a-z0-9_-]/gi, '-')}-${Math.random().toString(36).slice(2, 9)}`;
const arr = <T = any>(value: T[] | undefined | null): T[] => Array.isArray(value) ? value : [];
const toneClass = (tone: unknown) => `tone-${String(tone ?? 'neutral').replace(/[^a-z0-9-]/gi, '-')}`;
const blockRefs = (block: any) => arr<string>(block?.claimRefs).slice(0, 6);
const timelineItems = arr(data.items);
const stackLayers = arr(data.layers ?? data.items);
const marketSizingNodes = arr(data.nodes ?? data.items);
const unitEconomicsNodes = arr(data.nodes ?? data.items);
const customerSurfaceNodes = arr(data.nodes ?? data.items);
const recommendationNodes = arr(data.nodes ?? data.items);
const scorecardItems = arr(data.items ?? data.nodes);
const transmissionNodes = arr(data.nodes ?? data.items);
const transmissionEdges = arr(data.edges);
const transmissionSourceIds = new Set(transmissionEdges.map((edge: any) => edge.from));
const transmissionTargetIds = new Set(transmissionEdges.map((edge: any) => edge.to));
const transmissionSources = transmissionNodes.filter((node: any) => !transmissionTargetIds.has(node.id));
const transmissionBridges = transmissionNodes.filter((node: any) => transmissionSourceIds.has(node.id) && transmissionTargetIds.has(node.id));
const transmissionOutcomes = transmissionNodes.filter((node: any) => transmissionTargetIds.has(node.id) && !transmissionSourceIds.has(node.id));
const layerLabel = (layer: any) => layer?.label ?? layer?.name ?? layer?.id ?? 'Layer';
const layerDetail = (layer: any) => layer?.detail ?? layer?.description ?? null;
const moduleItems = (layer: any) => arr(layer?.modules ?? layer?.items ?? layer?.components);
const outputItems = (layer: any) => arr<string>(layer?.outputs);
const hasRichStackLayers = stackLayers.some((layer: any) => moduleItems(layer).length > 0 || outputItems(layer).length > 0);
const chartPayload = usesD3Chart ? { id: chartId, type, title: figure?.title, data } : null;
---

<figure class:list={['native-figure', `figure-${type}`, `layout-${layout}`]}>
  <figcaption>{figure.id}: {figure.title}</figcaption>

  {figure.summary && <p class="figure-summary">{figure.summary}</p>}

  {type === 'timeline' && (
    <ol class="timeline-viz">
      {timelineItems.map((item: any) => (
        <li>
          <span class="timeline-marker">{item.date ?? item.label}</span>
          <strong>{item.label}</strong>
          {item.detail && <p>{item.detail}</p>}
        </li>
      ))}
    </ol>
  )}

  {(type === 'flow' || type === 'decision-map' || type === 'evidence-map' || type === 'scenario-tree' || type === 'dependency-map') && <div id={chartId} class="d3-figure chart-relationship" data-chart-type={type}></div>}

  {(type === 'bars' || type === 'waterfall' || type === 'funnel' || type === 'range') && <div id={chartId} class="d3-figure chart-bars" data-chart-type={type}></div>}

  {(type === 'quadrant' || type === 'positioning-map') && (
    <div id={chartId} class="d3-figure chart-quadrant" data-chart-type={type}></div>
  )}

  {(type === 'matrix' || type === 'heatmap' || type === 'cohort') && <div id={chartId} class="d3-figure chart-heatmap" data-chart-type={type}></div>}

  {type === 'stack' && !hasRichStackLayers && (
    <div class="stack-viz">
      {stackLayers.map((layer: any) => (
        <article class:list={['stack-layer', toneClass(layer.tone)]}>
          <span></span>
          <strong>{layerLabel(layer)}</strong>
          {layerDetail(layer) && <p>{layerDetail(layer)}</p>}
        </article>
      ))}
    </div>
  )}

  {type === 'layered-lens' && (
    <div class="market-sizing-viz" aria-label={`${figure.title} market sizing lens`}>
      <div class="market-sizing-axis">
        <span>Broad market envelope</span>
        <span>Served footprint</span>
      </div>
      <div class="market-sizing-stack">
        {marketSizingNodes.map((node: any, index: number) => {
          const label = String(node.label ?? node.id ?? 'Layer');
          const width = index === 0 ? '100%' : index === 1 ? '86%' : index === 2 ? '68%' : '76%';
          return (
            <article class:list={['market-layer', `layer-${index + 1}`, toneClass(node.tone)]} style={`--market-layer-width: ${width}`}>
              <div class="market-layer-head">
                <span>{label}</span>
                <strong>{label === 'TAM' ? 'Addressable universe' : label === 'SAM' ? 'Commercially reachable market' : label === 'SOM' ? 'Evidence-backed served footprint' : node.label}</strong>
              </div>
              {node.detail && <p>{node.detail}</p>}
            </article>
          );
        })}
      </div>
      <div class="market-sizing-warning">
        <strong>No unsupported market math</strong>
        <p>Dollar TAM/SAM/SOM values stay out of the chart unless the evidence ledger contains a defensible source.</p>
      </div>
    </div>
  )}

  {type === 'bridge' && (
    <div class="unit-economics-viz" aria-label={`${figure.title} unit economics waterfall`}>
      <section class="unit-anchor-card">
        <span>Public anchor</span>
        <strong>{unitEconomicsNodes[0]?.label ?? 'Known input'}</strong>
        {unitEconomicsNodes[0]?.detail && <p>{unitEconomicsNodes[0].detail}</p>}
      </section>
      <div class="unit-waterfall-chain">
        {unitEconomicsNodes.slice(1).map((node: any, index: number) => {
          const isOutcome = index === unitEconomicsNodes.slice(1).length - 1;
          return (
            <article class:list={['unit-step-card', toneClass(node.tone), isOutcome && 'is-outcome']}>
              <div class="unit-step-kicker">
                <span>{String(index + 2).padStart(2, '0')}</span>
                <em>{isOutcome ? 'Underwriting blocker' : 'Missing bridge'}</em>
              </div>
              <strong>{node.label}</strong>
              {node.detail && <p>{node.detail}</p>}
            </article>
          );
        })}
      </div>
    </div>
  )}

  {type === 'journey-map' && (
    <div class="customer-surface-viz" aria-label={`${figure.title} customer surface map`}>
      {customerSurfaceNodes.map((node: any, index: number) => {
        let role = 'expansion';
        if (index === 0) role = 'entry';
        else if (index < 3) role = 'segment';
        return (
          <article class:list={['customer-surface-card', `surface-${role}`, `surface-${index + 1}`, toneClass(node.tone)]}>
            <div class="surface-kicker">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <em>{role === 'entry' ? 'Acquisition surface' : role === 'segment' ? 'Customer segment' : 'Expansion loop'}</em>
            </div>
            <strong>{node.label}</strong>
            {node.detail && <p>{node.detail}</p>}
          </article>
        );
      })}
    </div>
  )}

  {type === 'stack' && hasRichStackLayers && (
    <div class="architecture-viz" aria-label={`${figure.title} architecture diagram`}>
      {stackLayers.map((layer: any, index: number) => (
        <article class:list={['arch-layer', toneClass(layer.tone)]}>
          <div class="arch-layer-head">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{layerLabel(layer)}</strong>
            {layerDetail(layer) && <p>{layerDetail(layer)}</p>}
          </div>
          <div class="arch-layer-body">
            {moduleItems(layer).length > 0 ? (
              <div class="arch-modules">
                {moduleItems(layer).map((module: any) => (
                  <section class:list={['arch-module', toneClass(module.tone ?? layer.tone)]}>
                    <strong>{module.label ?? module}</strong>
                    {module.detail && <p>{module.detail}</p>}
                  </section>
                ))}
              </div>
            ) : layerDetail(layer) ? (
              <p class="arch-detail">{layerDetail(layer)}</p>
            ) : null}
            {outputItems(layer).length > 0 && (
              <ul class="arch-outputs" aria-label="Layer outputs">
                {outputItems(layer).map((output) => <li>{output}</li>)}
              </ul>
            )}
          </div>
        </article>
      ))}
    </div>
  )}

  {type === 'logic-chain' && (
    <div class="recommendation-viz" aria-label={`${figure.title} recommendation logic`}>
      {recommendationNodes.map((node: any, index: number) => {
        const isOutcome = /recommendation|decision|outcome/i.test(String(node.label ?? '')) || index === recommendationNodes.length - 1;
        return (
          <article class:list={['logic-card', toneClass(node.tone), isOutcome && 'is-outcome']}>
            <div class="logic-kicker">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <em>{isOutcome ? 'Decision' : node.tone === 'risk' || node.tone === 'critical' || node.tone === 'high' ? 'Constraint' : 'Evidence'}</em>
            </div>
            <strong>{node.label}</strong>
            {node.detail && <p>{node.detail}</p>}
          </article>
        );
      })}
    </div>
  )}

  {type === 'causal-map' && (
    <div class="risk-transmission-viz" aria-label={`${figure.title} risk transmission map`}>
      <section class="risk-column risk-inputs">
        <div class="risk-column-head"><span>01</span><strong>Risk sources</strong></div>
        <div class="risk-card-list">
          {transmissionSources.map((node: any) => (
            <article class:list={['risk-card', toneClass(node.tone)]}>
              <strong>{node.label}</strong>
              {node.detail && <p>{node.detail}</p>}
            </article>
          ))}
        </div>
      </section>
      <section class="risk-column risk-bridge">
        <div class="risk-column-head"><span>02</span><strong>Transmission pressure</strong></div>
        <div class="risk-card-list">
          {(transmissionBridges.length ? transmissionBridges : transmissionNodes.slice(-2, -1)).map((node: any) => (
            <article class:list={['risk-card', 'is-bridge', toneClass(node.tone)]}>
              <strong>{node.label}</strong>
              {node.detail && <p>{node.detail}</p>}
            </article>
          ))}
        </div>
      </section>
      <section class="risk-column risk-outcomes">
        <div class="risk-column-head"><span>03</span><strong>Underwriting impact</strong></div>
        <div class="risk-card-list">
          {(transmissionOutcomes.length ? transmissionOutcomes : transmissionNodes.slice(-1)).map((node: any) => (
            <article class:list={['risk-card', 'is-outcome', toneClass(node.tone)]}>
              <strong>{node.label}</strong>
              {node.detail && <p>{node.detail}</p>}
            </article>
          ))}
        </div>
      </section>
    </div>
  )}

  {type === 'scorecard' && (
    <div class="scorecard-viz" aria-label={`${figure.title} scorecard`}>
      {scorecardItems.map((item: any, index: number) => (
        <article class:list={['scorecard-card', toneClass(item.tone)]}>
          <div class="scorecard-head">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{item.label}</strong>
          </div>
          <div class="scorecard-value">{item.displayValue ?? item.value ?? item.score ?? '—'}</div>
          {item.detail && <p>{item.detail}</p>}
        </article>
      ))}
    </div>
  )}

  {(type === 'sensitivity' || type === 'scatter') && <div id={chartId} class="d3-figure chart-sensitivity" data-chart-type={type}></div>}

  {type === 'other' && (
    <div class="figure-fallback" role="note">
      <strong>Structured figure data available</strong>
      <p>This figure type does not yet have a dedicated renderer. Use a generic type such as <code>logic-chain</code>, <code>causal-map</code>, <code>stack</code>, <code>heatmap</code>, <code>bars</code>, <code>funnel</code>, <code>cohort</code>, <code>range</code>, <code>scorecard</code>, or <code>scatter</code> for automatic visual rendering.</p>
    </div>
  )}

  {figure.approximationNotes && <p class="figure-note">{figure.approximationNotes}</p>}
  <ClaimRefs refs={blockRefs(figure)} claims={claims} sources={sources} />
  {chartPayload && <script type="application/json" class="figure-chart-data" set:html={JSON.stringify(chartPayload)}></script>}
</figure>

<script>
  import * as d3 from 'd3';

  const palette = {
    claret: '#990f3d',
    ink: '#33302e',
    muted: '#6b625c',
    border: '#d8ccc2',
    paper: '#fff7ef',
    positive: '#0f766e',
    risk: '#b42318',
    opportunity: '#b8860b',
    neutral: '#990f3d',
  };

  const arr = (value) => Array.isArray(value) ? value : [];
  const colorForTone = (tone) => {
    if (tone === 'positive' || tone === 'low') return palette.positive;
    if (tone === 'risk' || tone === 'critical' || tone === 'high') return palette.risk;
    if (tone === 'opportunity') return palette.opportunity;
    return palette.neutral;
  };
  const riskValue = (tone) => {
    if (tone === 'high' || tone === 'critical' || tone === 'risk') return 3;
    if (tone === 'medium' || tone === 'neutral') return 2;
    return 1;
  };
  const labelText = (text, max = 24) => String(text ?? '').length > max ? `${String(text).slice(0, max - 1)}…` : String(text ?? '');
  const numberValue = (value) => Number(value) || 0;
  const valueLabel = (item) => item?.displayValue ?? item?.value ?? '';

  const chartFont = { axis: 13, label: 14, small: 12 };
  const svgBase = (element, height = 340) => {
    const width = Math.max(520, Math.floor(element.getBoundingClientRect().width || 760));
    d3.select(element).selectAll('*').remove();
    const svg = d3.select(element)
      .append('svg')
      .attr('viewBox', `0 0 ${width} ${height}`)
      .attr('role', 'img')
      .attr('width', '100%')
      .attr('height', height)
      .style('display', 'block');
    return { svg, width, height };
  };
  const addTitle = (selection, text) => selection.append('title').text(String(text ?? ''));
  const axisBottom = (g, scale, y, ticks = 4) => g.append('g')
    .attr('transform', `translate(0,${y})`)
    .call(d3.axisBottom(scale).ticks(ticks).tickSizeOuter(0))
    .call((axis) => axis.select('.domain').attr('stroke', palette.border))
    .call((axis) => axis.selectAll('line').attr('stroke', palette.border))
    .call((axis) => axis.selectAll('text').attr('fill', palette.muted).attr('font-size', chartFont.axis));
  const axisLeft = (g, scale, x) => g.append('g')
    .attr('transform', `translate(${x},0)`)
    .call(d3.axisLeft(scale).tickSizeOuter(0))
    .call((axis) => axis.select('.domain').remove())
    .call((axis) => axis.selectAll('line').remove())
    .call((axis) => axis.selectAll('text').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', 700));

  const renderGraph = (element, payload) => {
    const nodes = arr(payload.data.nodes);
    const edges = arr(payload.data.edges);
    const columns = Math.min(Math.max(nodes.length, 1), payload.type === 'decision-map' ? 5 : 4);
    const rows = Math.max(1, Math.ceil(nodes.length / columns));
    const { svg, width } = svgBase(element, Math.max(360, rows * 145 + 110));
    const margin = { top: 32, right: 36, bottom: 54, left: 36 };
    const innerW = width - margin.left - margin.right;
    const colW = innerW / columns;
    const rowH = 140;
    const defs = svg.append('defs');
    defs.append('marker').attr('id', `${payload.id}-arrow`).attr('viewBox', '0 -5 10 10').attr('refX', 9).attr('refY', 0).attr('markerWidth', 7).attr('markerHeight', 7).attr('orient', 'auto')
      .append('path').attr('d', 'M0,-5L10,0L0,5').attr('fill', palette.claret);
    const positioned = nodes.map((node, index) => {
      const col = index % columns;
      const row = Math.floor(index / columns);
      return { ...node, x: margin.left + colW * col + colW / 2, y: margin.top + rowH * row + 40 };
    });
    const byId = new Map(positioned.map((node) => [node.id, node]));
    svg.append('g').selectAll('path').data(edges).join('path')
      .attr('d', (edge) => {
        const s = byId.get(edge.from);
        const t = byId.get(edge.to);
        if (!s || !t) return '';
        const midX = (s.x + t.x) / 2;
        return `M${s.x},${s.y + 28} C${midX},${s.y + 56} ${midX},${t.y - 56} ${t.x},${t.y - 31}`;
      })
      .attr('fill', 'none').attr('stroke', palette.claret).attr('stroke-width', 1.7).attr('opacity', 0.72).attr('marker-end', `url(#${payload.id}-arrow)`);
    const card = svg.append('g').selectAll('g').data(positioned).join('g').attr('transform', (node) => `translate(${node.x},${node.y})`);
    card.append('rect').attr('x', -82).attr('y', -31).attr('width', 164).attr('height', 62).attr('rx', 4).attr('fill', '#fff7ef').attr('stroke', (node) => colorForTone(node.tone)).attr('stroke-width', 2);
    card.append('text').attr('text-anchor', 'middle').attr('y', -4).attr('fill', palette.ink).attr('font-size', chartFont.label).attr('font-weight', 800).text((node) => labelText(node.label, 22));
    card.append('text').attr('text-anchor', 'middle').attr('y', 17).attr('fill', palette.muted).attr('font-size', chartFont.small).text((node) => labelText(node.detail, 30));
    card.each(function(node) { addTitle(d3.select(this), `${node.label}${node.detail ? ` — ${node.detail}` : ''}`); });
  };

  const renderBars = (element, payload) => {
    const items = arr(payload.data.items).length ? arr(payload.data.items) : arr(arr(payload.data.series)[0]?.points);
    const { svg, width, height } = svgBase(element, Math.max(240, items.length * 34 + 72));
    const margin = { top: 18, right: 84, bottom: 34, left: 168 };
    const x = d3.scaleLinear().domain([0, d3.max(items, (d) => numberValue(d.value)) || 1]).nice().range([margin.left, width - margin.right]);
    const y = d3.scaleBand().domain(items.map((d) => d.label)).range([margin.top, height - margin.bottom]).padding(0.26);
    axisBottom(svg, x, height - margin.bottom);
    axisLeft(svg, y, margin.left);
    const bars = svg.append('g').selectAll('rect').data(items).join('rect')
      .attr('x', x(0)).attr('y', (d) => y(d.label)).attr('width', (d) => Math.max(2, x(numberValue(d.value)) - x(0))).attr('height', y.bandwidth())
      .attr('rx', 4).attr('fill', (d) => colorForTone(d.tone));
    bars.each(function(d) { addTitle(d3.select(this), `${d.label}: ${valueLabel(d)}`); });
    svg.append('g').selectAll('text').data(items).join('text')
      .attr('x', (d) => x(numberValue(d.value)) + 8).attr('y', (d) => y(d.label) + y.bandwidth() / 2 + 4)
      .attr('fill', palette.ink).attr('font-size', chartFont.label).attr('font-weight', 800).text((d) => valueLabel(d));
  };

  const renderWaterfall = (element, payload) => {
    const items = arr(payload.data.items);
    let running = 0;
    const points = items.map((item) => {
      const value = numberValue(item.value);
      const start = Math.min(running, running + value);
      const end = Math.max(running, running + value);
      running += value;
      return { ...item, value, start, end };
    });
    const { svg, width, height } = svgBase(element, 340);
    const margin = { top: 24, right: 28, bottom: 78, left: 54 };
    const yMin = Math.min(0, d3.min(points, (d) => d.start) || 0, d3.min(points, (d) => d.end) || 0);
    const yMax = Math.max(1, d3.max(points, (d) => d.start) || 0, d3.max(points, (d) => d.end) || 0);
    const x = d3.scaleBand().domain(items.map((d) => d.label)).range([margin.left, width - margin.right]).padding(0.34);
    const y = d3.scaleLinear().domain([yMin, yMax]).nice().range([height - margin.bottom, margin.top]);
    axisBottom(svg, x, height - margin.bottom, 0);
    axisLeft(svg, y, margin.left);
    svg.selectAll('.tick text').attr('font-size', chartFont.small);
    const bars = svg.append('g').selectAll('rect').data(points).join('rect')
      .attr('x', (d) => x(d.label)).attr('width', x.bandwidth()).attr('y', (d) => y(d.end)).attr('height', (d) => Math.max(2, y(d.start) - y(d.end)))
      .attr('fill', (d) => d.value < 0 ? palette.risk : colorForTone(d.tone)).attr('rx', 3);
    bars.each(function(d) { addTitle(d3.select(this), `${d.label}: ${valueLabel(d) || d.value}`); });
    svg.append('g').selectAll('text').data(points).join('text')
      .attr('x', (d) => x(d.label) + x.bandwidth() / 2).attr('y', (d) => y(d.end) - 7).attr('text-anchor', 'middle')
      .attr('fill', palette.ink).attr('font-size', chartFont.small).attr('font-weight', 800).text((d) => valueLabel(d));
  };

  const renderFunnel = (element, payload) => {
    const items = arr(payload.data.items).length ? arr(payload.data.items) : arr(arr(payload.data.series)[0]?.points);
    const { svg, width, height } = svgBase(element, Math.max(280, items.length * 58 + 42));
    const max = Math.max(...items.map((d) => numberValue(d.value)), 1);
    const cx = width / 2;
    const top = 22;
    const stageH = Math.min(54, (height - 44) / Math.max(items.length, 1));
    const maxW = width * 0.78;
    const minW = width * 0.28;
    const widths = items.map((d) => Math.max(minW, maxW * (numberValue(d.value) / max)));
    const group = svg.append('g');
    items.forEach((item, index) => {
      const y = top + index * stageH;
      const w = widths[index];
      const nextW = widths[index + 1] ?? Math.max(minW, w * 0.82);
      const poly = [[cx - w / 2, y], [cx + w / 2, y], [cx + nextW / 2, y + stageH - 5], [cx - nextW / 2, y + stageH - 5]];
      const stage = group.append('g');
      stage.append('polygon').attr('points', poly.map((p) => p.join(',')).join(' ')).attr('fill', colorForTone(item.tone ?? (index === items.length - 1 ? 'positive' : 'neutral'))).attr('opacity', 0.92).attr('stroke', '#fff7ef').attr('stroke-width', 3);
      stage.append('text').attr('x', cx).attr('y', y + stageH / 2 - 3).attr('text-anchor', 'middle').attr('fill', '#fff7ef').attr('font-size', chartFont.label).attr('font-weight', 900).text(labelText(item.label, 24));
      stage.append('text').attr('x', cx).attr('y', y + stageH / 2 + 17).attr('text-anchor', 'middle').attr('fill', '#fff7ef').attr('font-size', chartFont.small).attr('font-weight', 700).text(valueLabel(item));
      addTitle(stage, `${item.label}: ${valueLabel(item)}`);
    });
  };

  const renderRange = (element, payload) => {
    const items = arr(payload.data.items);
    const lows = items.map((item) => numberValue(item.low ?? item.min));
    const highs = items.map((item) => numberValue(item.high ?? item.max ?? item.value));
    const min = Math.min(...lows, 0);
    const max = Math.max(...highs, 1);
    const { svg, width, height } = svgBase(element, Math.max(240, items.length * 38 + 78));
    const margin = { top: 20, right: 98, bottom: 34, left: 168 };
    const x = d3.scaleLinear().domain([min, max]).nice().range([margin.left, width - margin.right]);
    const y = d3.scaleBand().domain(items.map((d) => d.label)).range([margin.top, height - margin.bottom]).padding(0.38);
    axisBottom(svg, x, height - margin.bottom);
    axisLeft(svg, y, margin.left);
    const groups = svg.append('g').selectAll('g').data(items).join('g');
    groups.append('line').attr('x1', (d) => x(numberValue(d.low ?? d.min))).attr('x2', (d) => x(numberValue(d.high ?? d.max ?? d.value))).attr('y1', (d) => y(d.label) + y.bandwidth() / 2).attr('y2', (d) => y(d.label) + y.bandwidth() / 2).attr('stroke', (d) => colorForTone(d.tone)).attr('stroke-width', 9).attr('stroke-linecap', 'round');
    groups.append('circle').attr('cx', (d) => x(numberValue(d.mid ?? d.value ?? ((numberValue(d.low ?? d.min) + numberValue(d.high ?? d.max)) / 2)))).attr('cy', (d) => y(d.label) + y.bandwidth() / 2).attr('r', 5).attr('fill', '#fff7ef').attr('stroke', palette.ink).attr('stroke-width', 2);
    groups.append('text').attr('x', (d) => x(numberValue(d.high ?? d.max ?? d.value)) + 10).attr('y', (d) => y(d.label) + y.bandwidth() / 2 + 4).attr('fill', palette.ink).attr('font-size', chartFont.label).attr('font-weight', 800).text((d) => d.displayValue ?? `${d.low ?? d.min}–${d.high ?? d.max}`);
    groups.each(function(d) { addTitle(d3.select(this), `${d.label}: ${d.displayValue ?? `${d.low ?? d.min}–${d.high ?? d.max}`}`); });
  };

  const renderQuadrant = (element, payload) => {
    const points = arr(payload.data.points);
    const xAxisLabel = payload.data.xAxis ?? 'X';
    const yAxisLabel = payload.data.yAxis ?? 'Y';
    const xs = points.map((p) => Number(p.x)).filter(Number.isFinite);
    const ys = points.map((p) => Number(p.y)).filter(Number.isFinite);
    const safeRange = (vals, anchor = 50) => {
      if (vals.length === 0) return { min: 0, max: 100 };
      const lo = Math.min(...vals);
      const hi = Math.max(...vals);
      const padBase = Math.max((hi - lo) * 0.18, 6);
      let min = Math.floor((lo - padBase) / 5) * 5;
      let max = Math.ceil((hi + padBase) / 5) * 5;
      // Always show the 50 reference line if the data is on one side of it.
      if (lo >= anchor) min = Math.min(min, anchor - 5);
      if (hi <= anchor) max = Math.max(max, anchor + 5);
      min = Math.max(0, min);
      max = Math.min(100, max);
      if (max - min < 20) {
        const center = (min + max) / 2;
        min = Math.max(0, Math.floor((center - 10) / 5) * 5);
        max = Math.min(100, Math.ceil((center + 10) / 5) * 5);
      }
      return { min, max };
    };
    const xRange = safeRange(xs);
    const yRange = safeRange(ys);
    const { svg, width, height } = svgBase(element, 380);
    const margin = { top: 34, right: 48, bottom: 64, left: 62 };
    const x = d3.scaleLinear().domain([xRange.min, xRange.max]).range([margin.left, width - margin.right]);
    const y = d3.scaleLinear().domain([yRange.min, yRange.max]).range([height - margin.bottom, margin.top]);
    svg.append('rect').attr('x', margin.left).attr('y', margin.top).attr('width', width - margin.left - margin.right).attr('height', height - margin.top - margin.bottom).attr('fill', 'rgba(153, 15, 61, 0.025)').attr('stroke', palette.border);
    if (xRange.min < 50 && xRange.max > 50) svg.append('line').attr('x1', x(50)).attr('x2', x(50)).attr('y1', margin.top).attr('y2', height - margin.bottom).attr('stroke', palette.border).attr('stroke-dasharray', '4 4');
    if (yRange.min < 50 && yRange.max > 50) svg.append('line').attr('x1', margin.left).attr('x2', width - margin.right).attr('y1', y(50)).attr('y2', y(50)).attr('stroke', palette.border).attr('stroke-dasharray', '4 4');
    axisBottom(svg, x, height - margin.bottom);
    axisLeft(svg, y, margin.left);
    svg.append('text').attr('x', width / 2).attr('y', height - 18).attr('text-anchor', 'middle').attr('fill', palette.muted).attr('font-size', chartFont.axis).attr('font-weight', 800).text(xAxisLabel);
    svg.append('text').attr('transform', `translate(18,${height / 2}) rotate(-90)`).attr('text-anchor', 'middle').attr('fill', palette.muted).attr('font-size', chartFont.axis).attr('font-weight', 800).text(yAxisLabel);
    const dots = svg.append('g').selectAll('g').data(points).join('g').attr('transform', (d) => `translate(${x(numberValue(d.x))},${y(numberValue(d.y))})`);
    dots.append('circle').attr('r', 9).attr('fill', (d) => colorForTone(d.tone)).attr('stroke', '#fff7ef').attr('stroke-width', 2);
    dots.append('text').attr('x', 13).attr('y', 5).attr('fill', palette.ink).attr('font-size', chartFont.label).attr('font-weight', 800).text((d) => labelText(d.label, 22));
    dots.each(function(d) { addTitle(d3.select(this), `${d.label}: ${xAxisLabel} ${d.x}; ${yAxisLabel} ${d.y}`); });
  };

  const renderHeatmap = (element, payload) => {
    const columns = arr(payload.data.columns);
    const rows = arr(payload.data.rows);
    const heatColors = {
      1: '#dcebe7',
      2: '#f2d8a0',
      3: '#c94f43',
    };
    const heatTextColors = {
      1: palette.ink,
      2: palette.ink,
      3: '#fff7ef',
    };
    const { svg, width, height } = svgBase(element, Math.max(340, rows.length * 68 + 96));
    const margin = { top: 58, right: 24, bottom: 26, left: Math.min(220, Math.max(136, Math.max(...rows.map((row) => String(row.label ?? '').length), 8) * 8)) };
    const x = d3.scaleBand().domain(columns).range([margin.left, width - margin.right]).padding(0.08);
    const y = d3.scaleBand().domain(rows.map((row) => row.label)).range([margin.top, height - margin.bottom]).padding(0.08);
    svg.append('g').selectAll('text').data(columns).join('text').attr('x', (d) => x(d) + x.bandwidth() / 2).attr('y', margin.top - 16).attr('text-anchor', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', 800).text((d) => labelText(d, 14));
    svg.append('g').selectAll('text').data(rows).join('text').attr('x', margin.left - 12).attr('y', (d) => y(d.label) + y.bandwidth() / 2 + 4).attr('text-anchor', 'end').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', 800).text((d) => labelText(d.label, 24));
    const cells = [];
    rows.forEach((row) => arr(row.values).forEach((cell, colIndex) => cells.push({ row: row.label, column: columns[colIndex], cell, value: riskValue(cell.tone) })));
    const g = svg.append('g').selectAll('g').data(cells).join('g');
    g.append('rect').attr('x', (d) => x(d.column)).attr('y', (d) => y(d.row)).attr('width', x.bandwidth()).attr('height', y.bandwidth()).attr('rx', 7).attr('fill', (d) => heatColors[d.value]).attr('stroke', '#fff7ef').attr('stroke-width', 3);
    g.append('text').attr('x', (d) => x(d.column) + x.bandwidth() / 2).attr('y', (d) => y(d.row) + y.bandwidth() / 2 + 5).attr('text-anchor', 'middle').attr('fill', (d) => heatTextColors[d.value]).attr('font-size', chartFont.small).attr('font-weight', 800).text((d) => labelText(d.cell.label ?? d.cell, 18));
    g.each(function(d) { addTitle(d3.select(this), `${d.row} × ${d.column}: ${d.cell.label ?? d.cell}`); });
  };

  const renderCohort = (element, payload) => {
    const columns = arr(payload.data.columns);
    const rows = arr(payload.data.rows);
    const { svg, width, height } = svgBase(element, Math.max(340, rows.length * 58 + 92));
    const margin = { top: 58, right: 24, bottom: 26, left: 156 };
    const x = d3.scaleBand().domain(columns).range([margin.left, width - margin.right]).padding(0.08);
    const y = d3.scaleBand().domain(rows.map((row) => row.label)).range([margin.top, height - margin.bottom]).padding(0.08);
    const color = d3.scaleLinear().domain([0, 50, 100]).range(['#f4c7bd', '#f2d8a0', '#0f766e']);
    svg.append('g').selectAll('text').data(columns).join('text').attr('x', (d) => x(d) + x.bandwidth() / 2).attr('y', margin.top - 16).attr('text-anchor', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', 800).text((d) => labelText(d, 14));
    svg.append('g').selectAll('text').data(rows).join('text').attr('x', margin.left - 12).attr('y', (d) => y(d.label) + y.bandwidth() / 2 + 4).attr('text-anchor', 'end').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', 800).text((d) => labelText(d.label, 22));
    const cells = [];
    rows.forEach((row) => arr(row.values).forEach((cell, colIndex) => {
      const value = Number(cell?.value ?? String(cell?.label ?? '').replace(/[^0-9.-]/g, ''));
      cells.push({ row: row.label, column: columns[colIndex], cell, value: Number.isFinite(value) ? value : 0 });
    }));
    const g = svg.append('g').selectAll('g').data(cells).join('g');
    g.append('rect').attr('x', (d) => x(d.column)).attr('y', (d) => y(d.row)).attr('width', x.bandwidth()).attr('height', y.bandwidth()).attr('rx', 7).attr('fill', (d) => color(d.value)).attr('stroke', '#fff7ef').attr('stroke-width', 3);
    g.append('text').attr('x', (d) => x(d.column) + x.bandwidth() / 2).attr('y', (d) => y(d.row) + y.bandwidth() / 2 + 5).attr('text-anchor', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.small).attr('font-weight', 800).text((d) => labelText(d.cell.label ?? d.cell.displayValue ?? d.value, 14));
    g.each(function(d) { addTitle(d3.select(this), `${d.row} × ${d.column}: ${d.cell.label ?? d.cell.displayValue ?? d.value}`); });
  };

  const renderSensitivity = (element, payload) => {
    const series = arr(payload.data.series)[0] ?? {};
    renderBars(element, { ...payload, data: { items: arr(series.points) } });
  };

  const renderScatter = (element, payload) => {
    const points = arr(payload.data.points).length ? arr(payload.data.points) : arr(arr(payload.data.series)[0]?.points);
    const mapped = points.map((point) => ({ ...point, x: numberValue(point.x ?? point.value?.[0]), y: numberValue(point.y ?? point.value?.[1]) }));
    renderQuadrant(element, { ...payload, data: { ...payload.data, points: mapped } });
  };

  const renderD3 = (element, payload) => {
    if (['flow', 'decision-map', 'evidence-map', 'scenario-tree', 'dependency-map'].includes(payload.type)) renderGraph(element, payload);
    else if (payload.type === 'waterfall') renderWaterfall(element, payload);
    else if (payload.type === 'funnel') renderFunnel(element, payload);
    else if (payload.type === 'range') renderRange(element, payload);
    else if (payload.type === 'bars') renderBars(element, payload);
    else if (['quadrant', 'positioning-map'].includes(payload.type)) renderQuadrant(element, payload);
    else if (payload.type === 'cohort') renderCohort(element, payload);
    else if (['matrix', 'heatmap'].includes(payload.type)) renderHeatmap(element, payload);
    else if (payload.type === 'scatter') renderScatter(element, payload);
    else if (payload.type === 'sensitivity') renderSensitivity(element, payload);
  };

  const renderCharts = () => {
    document.querySelectorAll('script.figure-chart-data').forEach((script) => {
      if (script.dataset.rendered === 'true') return;
      const payload = JSON.parse(script.textContent || '{}');
      const element = document.getElementById(payload.id);
      if (!element) return;
      renderD3(element, payload);
      script.dataset.rendered = 'true';
    });
  };
  renderCharts();
  window.addEventListener('resize', () => {
    document.querySelectorAll('script.figure-chart-data').forEach((script) => {
      script.dataset.rendered = 'false';
    });
    renderCharts();
  });
</script>

