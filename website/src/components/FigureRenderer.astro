      .attr('class', 'funnel-level-track')
      .attr('x', barLeft)
      .attr('y', (d) => d.y)
      .attr('width', barMaxW)
      .attr('height', stageH)
      .attr('rx', 12)
      .attr('fill', 'rgba(212,196,184,0.14)')
      .attr('stroke', 'rgba(212,196,184,0.38)');
