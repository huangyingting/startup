---
import ClaimRefs from './ClaimRefs.astro';
import { RENDERED_FIGURE_TYPES } from '../lib/figures.mjs';

interface Props {
  figure: any;
  claims?: any[];
  sources?: any[];
}

const { figure, claims = [], sources = [] } = Astro.props;
const type = figure?.type ?? 'flow';
const layout = figure?.layout ?? 'standard';
const data = figure?.data ?? {};
const chartTypes = new Set(RENDERED_FIGURE_TYPES);
const usesD3Chart = chartTypes.has(type);
const chartId = `chart-${String(figure?.id ?? 'figure').replace(/[^a-z0-9_-]/gi, '-')}-${Math.random().toString(36).slice(2, 9)}`;
const arr = <T = any>(value: T[] | undefined | null): T[] => Array.isArray(value) ? value : [];
const blockRefs = (block: any) => arr<string>(block?.claimRefs).slice(0, 6);
const chartPayload = usesD3Chart ? { id: chartId, type, title: figure?.title, data } : null;
---

<figure class:list={['native-figure', `figure-${type}`, `layout-${layout}`]}>
  <figcaption>{figure.id}: {figure.title}</figcaption>

  {figure.summary && <p class="figure-summary">{figure.summary}</p>}

  {usesD3Chart && <div id={chartId} class:list={['d3-figure', `chart-${type}`]} data-chart-type={type}></div>}

  {type === 'other' && (
    <div class="figure-fallback" role="note">
      <strong>Generic figure</strong>
      <p>Fallback renderer for generic figures.</p>
    </div>
  )}

  {figure.approximationNotes && <p class="figure-note">{figure.approximationNotes}</p>}
  <ClaimRefs refs={blockRefs(figure)} claims={claims} sources={sources} />
  {chartPayload && <script type="application/json" class="figure-chart-data" set:html={JSON.stringify(chartPayload)}></script>}
</figure>

<script>
  import * as d3 from 'd3';

  const palette = {
    claret: '#990f3d',
    ink: '#33302e',
    muted: '#6b625c',
    border: '#d8ccc2',
    paper: '#fff7ef',
    positive: '#0f766e',
    risk: '#b42318',
    opportunity: '#b8860b',
    neutral: '#990f3d',
  };

  const arr = (value) => Array.isArray(value) ? value : [];
  const colorForTone = (tone) => {
    if (tone === 'positive' || tone === 'low') return palette.positive;
    if (tone === 'risk' || tone === 'critical' || tone === 'high') return palette.risk;
    if (tone === 'opportunity') return palette.opportunity;
    return palette.neutral;
  };
  const riskValue = (tone) => {
    if (tone === 'high' || tone === 'critical' || tone === 'risk') return 3;
    if (tone === 'medium' || tone === 'neutral') return 2;
    return 1;
  };
  const labelText = (text, max = 24) => String(text ?? '').length > max ? `${String(text).slice(0, max - 1)}…` : String(text ?? '');
  const numberValue = (value) => Number(value) || 0;
  const valueLabel = (item) => item?.displayValue ?? item?.value ?? '';
  const fullValueLabel = (item) => item?.displayValue ?? item?.value ?? item?.score ?? item?.label ?? '';

  const chartFont = {
    family: 'var(--font-sans, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif)',
    size: {
      micro: 8,
      tiny: 9.5,
      caption: 10.5,
      small: 12,
      axis: 13,
      label: 14,
      title: 16,
      value: 18,
      large: 20,
      arrow: 24,
      metric: 26,
    },
    weight: {
      regular: 650,
      body: 700,
      medium: 750,
      strong: 800,
      label: 900,
      emphasis: 950,
    },
    tracking: {
      subtle: '0.04em',
      caps: '0.08em',
    },
    lineHeight: {
      compact: 12,
      tight: 13,
      small: 15,
      label: 16,
      title: 18,
    },
    cssVar: {
      kicker: 'var(--chart-fs-kicker)',
      caption: 'var(--chart-fs-caption)',
      body: 'var(--chart-fs-body)',
      note: 'var(--chart-fs-note)',
    },
  };
  chartFont.axis = chartFont.size.axis;
  chartFont.label = chartFont.size.label;
  chartFont.small = chartFont.size.small;
  const fontSize = (name) => chartFont.size[name] ?? name;
  const fontWeight = (name) => chartFont.weight[name] ?? name;
  const tooltip = (() => {
    const node = d3.select('body').selectAll('.d3-chart-tooltip').data([null]).join('div').attr('class', 'd3-chart-tooltip').attr('role', 'tooltip');
    const move = (event) => {
      const gap = window.innerWidth < 520 ? 10 : 14;
      const pad = window.innerWidth < 520 ? 10 : 14;
      const tooltipNode = node.node();
      const box = tooltipNode?.getBoundingClientRect?.() ?? { width: 0, height: 0 };
      const spaceRight = window.innerWidth - event.clientX;
      const spaceBottom = window.innerHeight - event.clientY;
      const placeLeft = spaceRight < box.width + gap + pad && event.clientX > box.width + gap + pad;
      const placeTop = spaceBottom < box.height + gap + pad && event.clientY > box.height + gap + pad;
      const rawLeft = placeLeft ? event.clientX - box.width - gap : event.clientX + gap;
      const rawTop = placeTop ? event.clientY - box.height - gap : event.clientY + gap;
      const left = Math.max(pad, Math.min(window.innerWidth - box.width - pad, rawLeft));
      const top = Math.max(pad, Math.min(window.innerHeight - box.height - pad, rawTop));
      const pointerX = Math.max(18, Math.min(box.width - 18, event.clientX - left));
      const tooltipFont = window.innerWidth < 520 ? chartFont.size.small : window.innerWidth < 760 ? chartFont.axis : 13.8;
      node
        .attr('data-placement-x', placeLeft ? 'left' : 'right')
        .attr('data-placement-y', placeTop ? 'top' : 'bottom')
        .style('left', `${left}px`)
        .style('top', `${top}px`)
        .style('--tooltip-pointer-x', `${pointerX}px`)
        .style('--tooltip-font', `${tooltipFont}px`);
    };
    return {
      show(event, html) {
        node.html(html).classed('is-visible', true);
        move(event);
      },
      move,
      hide() {
        node.classed('is-visible', false);
      },
    };
  })();
  const escapeHtml = (value) => String(value ?? '').replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char]));
  const tooltipHtml = (title, lines = []) => `<strong>${escapeHtml(title)}</strong>${lines.filter(Boolean).map((line) => `<span>${escapeHtml(line)}</span>`).join('')}`;
  const shouldShowTooltip = () => true;
  document.addEventListener('pointerdown', (event) => {
    if (event.target?.closest?.('.d3-figure')) return;
    tooltip.hide();
  });
  const withTooltip = (selection, htmlForDatum) => selection
    .style('cursor', 'default')
    .on('pointerenter', function(event, datum) {
      d3.select(this).classed('is-hovered', true);
      if (!shouldShowTooltip()) return;
      const html = typeof htmlForDatum === 'function' ? htmlForDatum(datum) : htmlForDatum;
      tooltip.show(event, html);
    })
    .on('pointerdown', function(event, datum) {
      event.stopPropagation();
      d3.select(this).classed('is-hovered', true);
      const html = typeof htmlForDatum === 'function' ? htmlForDatum(datum) : htmlForDatum;
      tooltip.show(event, html);
    })
    .on('pointermove', (event) => {
      if (shouldShowTooltip()) tooltip.move(event);
    })
    .on('pointerleave', function() {
      d3.select(this).classed('is-hovered', false);
      tooltip.hide();
    });
  const wrapWords = (text, maxChars = 18, maxLines = 2) => {
    const words = String(text ?? '').split(/\s+/).filter(Boolean);
    if (!words.length) return [''];
    const lines = [];
    let line = '';
    words.forEach((word) => {
      const next = line ? `${line} ${word}` : word;
      if (next.length > maxChars && line) {
        lines.push(line);
        line = word;
      } else {
        line = next;
      }
    });
    if (line) lines.push(line);
    const clipped = lines.slice(0, maxLines);
    if (lines.length > maxLines) clipped[clipped.length - 1] = labelText(clipped[clipped.length - 1], Math.max(4, maxChars - 1));
    return clipped;
  };
  const renderWrappedText = (selection, text, { maxChars = 18, maxLines = 2, lineHeight = chartFont.lineHeight.small, dy = 0 } = {}) => {
    const x = selection.attr('x') ?? 0;
    selection.text(null);
    const lines = wrapWords(text, maxChars, maxLines);
    const offset = dy - ((lines.length - 1) * lineHeight) / 2;
    lines.forEach((line, index) => {
      selection.append('tspan').attr('x', x).attr('dy', index === 0 ? offset : lineHeight).text(line);
    });
  };
  const renderLineBlock = (selection, lines, { x = 0, y = 0, lineHeight = chartFont.lineHeight.small } = {}) => {
    selection.text(null).attr('x', x).attr('y', y);
    lines.forEach((line, index) => {
      selection.append('tspan').attr('x', x).attr('dy', index === 0 ? 0 : lineHeight).text(line);
    });
  };
  const svgBase = (element, height = 340) => {
    const containerWidth = Math.floor(element.getBoundingClientRect().width || 760);
    const minInternalWidth = containerWidth < 420 ? 420 : 520;
    const width = Math.max(minInternalWidth, containerWidth);
    const displayHeight = Math.ceil(height * Math.min(1, containerWidth / width));
    d3.select(element).selectAll('*').remove();
    const svg = d3.select(element)
      .append('svg')
      .attr('viewBox', `0 0 ${width} ${height}`)
      .attr('role', 'img')
      .attr('width', '100%')
      .attr('height', displayHeight)
      .style('font-family', chartFont.family)
      .style('display', 'block');
    return { svg, width, height };
  };
  const addTitle = (selection, text) => selection.attr('aria-label', String(text ?? ''));
  const axisBottom = (g, scale, y, ticks = 4) => g.append('g')
    .attr('transform', `translate(0,${y})`)
    .call(d3.axisBottom(scale).ticks(ticks).tickSizeOuter(0))
    .call((axis) => axis.select('.domain').attr('stroke', palette.border))
    .call((axis) => axis.selectAll('line').attr('stroke', palette.border))
    .call((axis) => axis.selectAll('text').attr('fill', palette.muted).attr('font-size', chartFont.axis));
  const axisLeft = (g, scale, x) => g.append('g')
    .attr('transform', `translate(${x},0)`)
    .call(d3.axisLeft(scale).tickSizeOuter(0))
    .call((axis) => axis.select('.domain').remove())
    .call((axis) => axis.selectAll('line').remove())
    .call((axis) => axis.selectAll('text').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('body')).each(function(d) {
      const text = d3.select(this);
      renderWrappedText(text, d, { maxChars: 19, maxLines: 2, lineHeight: chartFont.lineHeight.tight });
    }));

  const renderDag = (element, payload) => {
    const nodes = arr(payload.data.nodes).map((node, index) => ({ ...node, _key: node.id ?? node.label ?? String(index + 1), _index: index }));
    const edges = arr(payload.data.edges).map((edge, index) => ({ ...edge, _edgeIndex: index, from: edge.from ?? edge.source, to: edge.to ?? edge.target }));
    if (!nodes.length) return;
    const byKey = new Map(nodes.map((node) => [node._key, node]));
    const incoming = d3.group(edges, (edge) => edge.to);
    const outgoing = d3.group(edges, (edge) => edge.from);
    // BFS topological depth from roots. Hub-and-spoke graphs (many inputs, one
    // sink) collapse to 2 layers; deeper chains keep their natural layer count
    // instead of being forced into a fixed 3-stage Inputs/Core/Impact layout.
    const roots = nodes.filter((node) => !incoming.has(node._key));
    const depthByKey = new Map();
    const queue = (roots.length ? roots : [nodes[0]]).map((node) => {
      depthByKey.set(node._key, 0);
      return node;
    });
    while (queue.length) {
      const current = queue.shift();
      const currentDepth = depthByKey.get(current._key) ?? 0;
      for (const edge of arr(outgoing.get(current._key))) {
        const target = byKey.get(edge.to);
        if (!target) continue;
        const nextDepth = currentDepth + 1;
        if (!depthByKey.has(target._key) || depthByKey.get(target._key) < nextDepth) {
          depthByKey.set(target._key, nextDepth);
          queue.push(target);
        }
      }
    }
    for (const node of nodes) if (!depthByKey.has(node._key)) depthByKey.set(node._key, 0);
    const maxDepth = Math.max(0, ...depthByKey.values());
    const stages = Array.from({ length: maxDepth + 1 }, () => []);
    nodes.forEach((node) => stages[depthByKey.get(node._key) ?? 0].push(node));
    const stageNames = stages.length === 1
      ? ['Dependencies']
      : stages.length === 2
        ? ['Inputs', 'Impact']
        : stages.length === 3
          ? ['Inputs', 'Core dependency', 'Impact']
          : stages.map((_stage, index) => `Stage ${index + 1}`);
    const stageRole = (index) => index === 0
      ? 'input'
      : index === stages.length - 1
        ? 'impact'
        : 'core';
    const containerWidth = element.getBoundingClientRect().width || 760;
    const compact = containerWidth < 640;
    const maxRows = Math.max(...stages.map((stage) => stage.length), 1);
    const compactHeight = 74 + stages.reduce((sum, stage) => sum + 30 + stage.length * 76 + Math.max(0, stage.length - 1) * 16 + 36, 0);
    const { svg, width, height } = svgBase(element, compact ? Math.max(520, compactHeight) : Math.max(350, 118 + maxRows * 108));
    const margin = compact ? { top: 36, right: 24, bottom: 34, left: 24 } : { top: 42, right: 34, bottom: 40, left: 34 };
    const innerW = width - margin.left - margin.right;
    const innerH = height - margin.top - margin.bottom;
    const stageW = innerW / Math.max(stages.length, 1);
    const cardW = compact ? Math.min(252, innerW - 18) : Math.min(190, Math.max(140, stageW - 30));
    const cardH = compact ? 66 : 74;
    const stageLabels = [];
    const positions = [];
    if (compact) {
      let y = margin.top;
      stages.forEach((stage, stageIndex) => {
        stageLabels.push({ label: stageNames[stageIndex], x: width / 2, y: y + 2 });
        y += 34;
        stage.forEach((node, index) => {
          positions.push({ ...node, _stage: stageIndex, _role: stageRole(stageIndex), x: width / 2, y: y + cardH / 2 + index * (cardH + 16) });
        });
        y += stage.length * cardH + Math.max(0, stage.length - 1) * 16 + 36;
      });
    } else {
      stages.forEach((stage, stageIndex) => {
        stageLabels.push({ label: stageNames[stageIndex], x: margin.left + stageW * stageIndex + stageW / 2, y: 24 });
        const gap = innerH / Math.max(stage.length, 1);
        stage.forEach((node, index) => {
          positions.push({ ...node, _stage: stageIndex, _role: stageRole(stageIndex), x: margin.left + stageW * stageIndex + stageW / 2, y: margin.top + gap * index + gap / 2 });
        });
      });
    }
    const positionedByKey = new Map(positions.map((node) => [node._key, node]));
    const routedEdges = edges.map((edge, index) => ({ ...edge, _edgeIndex: index, source: positionedByKey.get(edge.from), target: positionedByKey.get(edge.to) })).filter((edge) => edge.source && edge.target);
    const defs = svg.append('defs');
    defs.append('marker').attr('id', `${payload.id}-dependency-arrow`).attr('viewBox', '0 -5 10 10').attr('refX', 8.2).attr('refY', 0).attr('markerWidth', 5.8).attr('markerHeight', 5.8).attr('orient', 'auto')
      .append('path').attr('d', 'M0,-4L9,0L0,4').attr('fill', palette.claret);
    const shadow = defs.append('filter').attr('id', `${payload.id}-dependency-shadow`).attr('x', '-16%').attr('y', '-22%').attr('width', '132%').attr('height', '150%');
    shadow.append('feDropShadow').attr('dx', 0).attr('dy', 4).attr('stdDeviation', 4).attr('flood-color', 'rgba(51,48,46,0.13)');
    svg.append('g').selectAll('text').data(stageLabels).join('text')
      .attr('x', (label) => label.x)
      .attr('y', (label) => label.y)
      .attr('text-anchor', 'middle')
      .attr('fill', palette.claret)
      .attr('font-size', chartFont.small)
      .attr('font-weight', fontWeight('emphasis'))
      .attr('letter-spacing', chartFont.tracking.caps)
      .text((label) => label.label);
    const edgePath = (edge) => {
      if (compact) {
        const sx = edge.source.x + cardW / 2 + 8;
        const sy = edge.source.y;
        const laneOffset = (edge._edgeIndex - (Math.max(routedEdges.length, 1) - 1) / 2) * 16;
        const tx = edge.target.x + Math.max(-cardW / 2 + 26, Math.min(cardW / 2 - 26, laneOffset));
        const ty = edge.target.y - cardH / 2 - 8;
        const busX = Math.min(width - margin.right - 10, sx + 68 + edge._edgeIndex * 8);
        return `M${sx},${sy} C${busX},${sy} ${busX},${ty - 34} ${tx},${ty}`;
      }
      const sx = edge.source.x + cardW / 2 + 10;
      const tx = edge.target.x - cardW / 2 - 12;
      const midX = (sx + tx) / 2;
      return `M${sx},${edge.source.y} C${midX},${edge.source.y} ${midX},${edge.target.y} ${tx},${edge.target.y}`;
    };
    const edgeLayer = svg.append('g');
    edgeLayer.selectAll('path.visible-dependency-edge').data(routedEdges).join('path')
      .attr('class', 'visible-dependency-edge')
      .attr('d', edgePath)
      .attr('fill', 'none')
      .attr('stroke', (edge) => colorForTone(edge.source.tone ?? edge.target.tone))
      .attr('stroke-width', 1.8)
      .attr('opacity', 0.68)
      .attr('marker-end', `url(#${payload.id}-dependency-arrow)`);
    const hitEdges = edgeLayer.selectAll('path.dependency-edge-hit').data(routedEdges).join('path')
      .attr('class', 'dependency-edge-hit')
      .attr('d', edgePath)
      .attr('fill', 'none')
      .attr('stroke', 'transparent')
      .attr('stroke-width', 16);
    hitEdges.each(function(edge) { addTitle(d3.select(this), `${edge.source.label} → ${edge.target.label}${edge.label ? ` — ${edge.label}` : ''}`); });
    withTooltip(hitEdges, (edge) => tooltipHtml(`${edge.source.label} → ${edge.target.label}`, [edge.label ? `Dependency: ${edge.label}` : null, edge.source.detail, edge.target.detail]));
    const cards = svg.append('g').selectAll('g.dependency-card').data(positions).join('g')
      .attr('class', 'dependency-card')
      .attr('transform', (node) => `translate(${node.x},${node.y})`);
    cards.append('rect')
      .attr('x', -cardW / 2)
      .attr('y', -cardH / 2)
      .attr('width', cardW)
      .attr('height', cardH)
      .attr('rx', 18)
      .attr('fill', '#fffaf5')
      .attr('stroke', (node) => colorForTone(node.tone))
      .attr('stroke-opacity', 0.42)
      .attr('stroke-width', 1.2);
    cards.append('rect')
      .attr('x', -cardW / 2 + 14)
      .attr('y', -cardH / 2 + 11)
      .attr('width', cardW - 28)
      .attr('height', 3)
      .attr('rx', 2)
      .attr('fill', (node) => colorForTone(node.tone))
      .attr('opacity', 0.78);
    const glyphs = cards.append('g').attr('transform', `translate(${-cardW / 2 + 24},${-cardH / 2 + 35})`);
    glyphs.append('circle')
      .attr('r', 6)
      .attr('fill', (node) => node._role === 'core' ? colorForTone(node.tone) : 'none')
      .attr('stroke', (node) => colorForTone(node.tone))
      .attr('stroke-width', 2)
      .attr('opacity', 0.88);
    glyphs.filter((node) => node._role === 'core').append('path')
      .attr('d', 'M-5,0 H5 M0,-5 V5')
      .attr('stroke', '#fff7ef')
      .attr('stroke-width', 1.7)
      .attr('stroke-linecap', 'round');
    glyphs.filter((node) => node._role === 'impact').append('path')
      .attr('d', 'M-5,-5 L5,0 L-5,5')
      .attr('fill', 'none')
      .attr('stroke', (node) => colorForTone(node.tone))
      .attr('stroke-width', 2)
      .attr('stroke-linecap', 'round')
      .attr('stroke-linejoin', 'round');
    cards.append('text').attr('x', -cardW / 2 + 42).attr('y', compact ? 4 : 5).attr('fill', palette.ink).attr('font-size', chartFont.label).attr('font-weight', fontWeight('label')).each(function(node) {
      renderWrappedText(d3.select(this), node.label, { maxChars: Math.max(12, Math.floor((cardW - 54) / 8)), maxLines: 2, lineHeight: chartFont.lineHeight.small });
    });
    cards.each(function(node) { addTitle(d3.select(this), `${node.label}${node.detail ? ` — ${node.detail}` : ''}`); });
    withTooltip(cards, (node) => tooltipHtml(node.label, [node.detail, node._role === 'input' ? 'Input dependency' : node._role === 'impact' ? 'Downstream impact' : 'Core dependency']));
  };

  const renderFlow = (element, payload) => {
    const nodes = arr(payload.data.nodes).map((node, index) => ({ ...node, _index: index, _key: node.id ?? node.label ?? String(index + 1) }));
    const edges = arr(payload.data.edges);
    const edgeBetween = (source, target) => edges.find((edge) => {
      const from = edge.from ?? edge.source;
      const to = edge.to ?? edge.target;
      return (from === source._key || from === source.id || from === source.label) && (to === target._key || to === target.id || to === target.label);
    });
    const containerWidth = element.getBoundingClientRect().width || 760;
    const compact = containerWidth < 520;
    const cardH = compact ? 96 : 118;
    const gap = compact ? 18 : 34;
    const margin = compact ? { top: 14, right: 18, bottom: 18, left: 16 } : { top: 24, right: 34, bottom: 30, left: 30 };
    const { svg, width, height } = svgBase(element, Math.max(260, margin.top + margin.bottom + nodes.length * cardH + Math.max(0, nodes.length - 1) * gap));
    const railX = margin.left + (compact ? 24 : 34);
    const cardX = margin.left + (compact ? 64 : 96);
    const cardW = width - cardX - margin.right;
    const defs = svg.append('defs');
    const gradient = defs.append('linearGradient').attr('id', `${payload.id}-flow-card-bg`).attr('x1', '0%').attr('x2', '100%');
    gradient.append('stop').attr('offset', '0%').attr('stop-color', '#fff7ef');
    gradient.append('stop').attr('offset', '100%').attr('stop-color', '#fbf0e8');
    const stepY = (index) => margin.top + index * (cardH + gap);
    const connectorData = nodes.slice(0, -1).map((node, index) => ({ source: node, target: nodes[index + 1], edge: edgeBetween(node, nodes[index + 1]), index }));
    const railRadius = compact ? 17 : 22;
    const connectorStartY = (index) => stepY(index) + cardH / 2 + railRadius + 3;
    const connectorArrowBaseY = (index) => stepY(index + 1) + cardH / 2 - railRadius - (compact ? 9 : 10);
    const connectorArrowTipY = (index) => stepY(index + 1) + cardH / 2 - railRadius - 3;
    const visibleEdgeLabel = (edge) => {
      const label = String(edge?.label ?? '').trim();
      if (!label || ['therefore', 'decision', 'next'].includes(label.toLowerCase())) return null;
      return label;
    };
    svg.append('g')
      .attr('class', 'flow-connector-lines')
      .selectAll('line.flow-connector-line')
      .data(connectorData)
      .join('line')
      .attr('class', 'flow-connector-line')
      .attr('x1', railX)
      .attr('x2', railX)
      .attr('y1', (d) => connectorStartY(d.index))
      .attr('y2', (d) => connectorArrowBaseY(d.index))
      .attr('stroke', (d) => colorForTone(d.source.tone))
      .attr('stroke-width', compact ? 1.8 : 2)
      .attr('stroke-linecap', 'round')
      .attr('stroke-opacity', 0.38);
    svg.select('.flow-connector-lines')
      .selectAll('path.flow-connector-arrow')
      .data(connectorData)
      .join('path')
      .attr('class', 'flow-connector-arrow')
      .attr('d', (d) => {
        const baseY = connectorArrowBaseY(d.index);
        const tipY = connectorArrowTipY(d.index);
