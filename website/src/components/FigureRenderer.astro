    rows.append('text').attr('fill', palette.muted).attr('font-size', chartFont.small).each(function(d) {
      renderLineBlock(d3.select(this), d.detailLines, { x: textX, y: 20 + d.dateLines.length * chartFont.lineHeight.small + 10 + d.labelLines.length * chartFont.lineHeight.title + 10, lineHeight: chartFont.lineHeight.small });
