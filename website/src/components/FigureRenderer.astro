  :global(.d3-chart-tooltip[data-placement-y='bottom']::before) { top: -0.39rem; border-right: 0; border-bottom: 0; }
  :global(.d3-chart-tooltip[data-placement-y='top']::before) { bottom: -0.39rem; border-left: 0; border-top: 0; }
