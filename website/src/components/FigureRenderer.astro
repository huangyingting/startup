  const renderPyramid = (element, payload) => {
    const items = normalizedItems(payload.data);
    // Probe container width up front so we can compute per-layer text wrapping
    // before allocating the SVG canvas. We need final card heights to set
    // svgBase height correctly.
    const containerWidth = Math.floor(element.getBoundingClientRect().width || 760);
    const internalWidth = Math.max(containerWidth < 420 ? 420 : 520, containerWidth);
    const margin = { top: 28, right: 34, bottom: 34, left: 34 };
    const maxW = internalWidth - margin.left - margin.right;
    const padX = 22;
    const labelLineH = 22;
    const detailLineH = 16;
    const padTop = 12;
    const padBottom = 12;
    const gapBetweenLabelDetail = 8;
    const gapBetweenLayers = 10;
    const labelFont = chartFont.size.large;
    const detailFont = chartFont.small;
    // Estimate characters that fit in a layer of width `w` for given font
    // size; `0.55em` is a conservative average glyph width.
    const charsPerLine = (w, fontSize) => Math.max(8, Math.floor((w - padX * 2) / (fontSize * 0.55)));
    const wrap = (text, maxChars) => wrapWords(text, maxChars, 99);
    const layout = items.map((item, index) => {
      const w = maxW * (1 - index * 0.1);
      const labelLines = wrap(item.label, charsPerLine(w, labelFont));
      const detailLines = item.detail ? wrap(item.detail, charsPerLine(w, detailFont)) : [];
      const cardH = Math.max(
        66,
        padTop + labelLines.length * labelLineH + (detailLines.length ? gapBetweenLabelDetail + detailLines.length * detailLineH : 0) + padBottom,
      );
      return { item, index, w, labelLines, detailLines, cardH };
    });
    let cursorY = margin.top;
    for (const entry of layout) { entry.y = cursorY; cursorY += entry.cardH + gapBetweenLayers; }
    const svgHeight = Math.max(300, cursorY - gapBetweenLayers + margin.bottom);
    const { svg, width } = svgBase(element, svgHeight);
    const groups = svg.append('g').selectAll('g').data(layout).join('g').attr('transform', (entry) => `translate(${(width - entry.w) / 2},${entry.y})`);
    groups.append('rect').attr('width', (entry) => entry.w).attr('height', (entry) => entry.cardH).attr('rx', 14).attr('fill', (_entry, index) => d3.interpolateRgb('#fff7ef', '#ead8cf')(index / Math.max(1, layout.length - 1))).attr('stroke', (entry) => colorForTone(entry.item.tone)).attr('stroke-width', 1.7);
    groups.append('text')
      .attr('x', padX)
      .attr('y', padTop + labelFont)
      .attr('fill', palette.claret)
      .attr('font-size', labelFont)
      .attr('font-weight', fontWeight('emphasis'))
      .each(function(entry) { renderLineBlock(d3.select(this), entry.labelLines, { x: padX, y: padTop + labelFont, lineHeight: labelLineH }); });
    groups.filter((entry) => entry.detailLines.length > 0).append('text')
      .attr('x', padX)
      .attr('fill', palette.ink)
      .attr('font-size', detailFont)
      .attr('font-weight', fontWeight('medium'))
      .each(function(entry) {
        const startY = padTop + entry.labelLines.length * labelLineH + gapBetweenLabelDetail + detailFont;
        renderLineBlock(d3.select(this), entry.detailLines, { x: padX, y: startY, lineHeight: detailLineH });
      });
    groups.each(function(entry) { addTitle(d3.select(this), `${entry.item.label}${entry.item.detail ? ` — ${entry.item.detail}` : ''}`); });
  };

  const renderJourneyMap = (element, payload) => {
