  const renderQuadrant = (element, payload) => {
    const points = arr(payload.data.points);
    const axisLabel = (raw, fallback) => {
      if (raw == null) return fallback;
      if (typeof raw === 'string' || typeof raw === 'number') return String(raw);
      if (typeof raw === 'object' && typeof raw.label === 'string') return raw.label;
      return fallback;
    };
    const xAxisLabel = axisLabel(payload.data.xAxis ?? payload.data.xLabel ?? payload.data.x, 'X');
    const yAxisLabel = axisLabel(payload.data.yAxis ?? payload.data.yLabel ?? payload.data.y, 'Y');
    const xs = points.map((p) => Number(p.x)).filter(Number.isFinite);
    const ys = points.map((p) => Number(p.y)).filter(Number.isFinite);
    const allValues = [...xs, ...ys];
    const finiteMin = allValues.length ? Math.min(...allValues) : 0;
    const finiteMax = allValues.length ? Math.max(...allValues) : 100;
    const isTenPointScore = finiteMin >= 0 && finiteMax <= 10;
    const isUnitScore = finiteMin >= 0 && finiteMax <= 1;
    const isPercentScore = !isTenPointScore && !isUnitScore && finiteMin >= 0 && finiteMax <= 100;
    const referenceValue = isTenPointScore ? 5 : isUnitScore ? 0.5 : 50;
    const safeRange = (vals) => {
      if (vals.length === 0) return isTenPointScore ? { min: 0, max: 10 } : isUnitScore ? { min: 0, max: 1 } : { min: 0, max: 100 };
      if (isTenPointScore) return { min: 0, max: 10 };
      if (isUnitScore) return { min: 0, max: 1 };
      if (isPercentScore) return { min: 0, max: 100 };
      const lo = Math.min(...vals);
      const hi = Math.max(...vals);
      const distance = Math.max(Math.abs(lo - referenceValue), Math.abs(hi - referenceValue), 10);
      const roundedDistance = Math.ceil(distance / 5) * 5;
      return { min: referenceValue - roundedDistance, max: referenceValue + roundedDistance };
    };
    const xRange = safeRange(xs);
    const yRange = safeRange(ys);
    const containerWidth = element.getBoundingClientRect().width || 760;
    const compact = containerWidth < 640;
    const { svg, width, height } = svgBase(element, compact ? 520 : 440);
    const margin = compact ? { top: 52, right: 34, bottom: 118, left: 52 } : { top: 54, right: 42, bottom: 104, left: 70 };
    const plotW = width - margin.left - margin.right;
    const plotH = height - margin.top - margin.bottom;
    const x = d3.scaleLinear().domain([xRange.min, xRange.max]).range([margin.left, width - margin.right]);
    const y = d3.scaleLinear().domain([yRange.min, yRange.max]).range([height - margin.bottom, margin.top]);
    const refX = Math.max(margin.left, Math.min(width - margin.right, x(referenceValue)));
    const refY = Math.max(margin.top, Math.min(height - margin.bottom, y(referenceValue)));
    const defs = svg.append('defs');
    const shadow = defs.append('filter').attr('id', `${payload.id}-quadrant-shadow`).attr('x', '-20%').attr('y', '-24%').attr('width', '140%').attr('height', '152%');
    shadow.append('feDropShadow').attr('dx', 0).attr('dy', 5).attr('stdDeviation', 5).attr('flood-color', 'rgba(51,48,46,0.16)');
    const panel = svg.append('g');
    const quadrants = [
      { label: 'Specialist depth', x: margin.left, y: margin.top, w: refX - margin.left, h: refY - margin.top, fill: 'rgba(15,118,110,0.07)' },
      { label: 'Leader zone', x: refX, y: margin.top, w: width - margin.right - refX, h: refY - margin.top, fill: 'rgba(153,15,61,0.07)' },
      { label: 'Watchlist', x: margin.left, y: refY, w: refX - margin.left, h: height - margin.bottom - refY, fill: 'rgba(180,35,24,0.055)' },
      { label: 'Scale path', x: refX, y: refY, w: width - margin.right - refX, h: height - margin.bottom - refY, fill: 'rgba(184,134,11,0.075)' },
    ].filter((q) => q.w > 2 && q.h > 2);
    panel.append('rect')
      .attr('x', margin.left)
      .attr('y', margin.top)
      .attr('width', plotW)
      .attr('height', plotH)
      .attr('rx', 18)
      .attr('fill', '#fffaf5')
      .attr('stroke', palette.border);
    panel.selectAll('rect.quadrant-zone').data(quadrants).join('rect')
      .attr('class', 'quadrant-zone')
      .attr('x', (q) => q.x)
      .attr('y', (q) => q.y)
      .attr('width', (q) => q.w)
      .attr('height', (q) => q.h)
      .attr('fill', (q) => q.fill)
      .attr('clip-path', null);
    panel.append('line').attr('x1', refX).attr('x2', refX).attr('y1', margin.top + 10).attr('y2', height - margin.bottom - 10).attr('stroke', palette.claret).attr('stroke-width', 1.5).attr('stroke-dasharray', '5 6').attr('opacity', 0.58);
    panel.append('line').attr('x1', margin.left + 10).attr('x2', width - margin.right - 10).attr('y1', refY).attr('y2', refY).attr('stroke', palette.claret).attr('stroke-width', 1.5).attr('stroke-dasharray', '5 6').attr('opacity', 0.58);
    panel.append('circle').attr('cx', refX).attr('cy', refY).attr('r', 5).attr('fill', '#fffaf5').attr('stroke', palette.claret).attr('stroke-width', 2).attr('opacity', 0.85);
    panel.selectAll('text.quadrant-label').data(quadrants).join('text')
      .attr('class', 'quadrant-label')
      .attr('x', (q) => q.x + (q.x < refX ? 12 : q.w - 12))
      .attr('y', (q) => q.y + (q.y < refY ? 20 : q.h - 12))
      .attr('text-anchor', (q) => q.x < refX ? 'start' : 'end')
      .attr('fill', palette.muted)
      .attr('font-size', compact ? chartFont.size.tiny : chartFont.size.caption)
      .attr('font-weight', fontWeight('label'))
      .attr('letter-spacing', chartFont.tracking.subtle)
      .text((q) => q.label);
    const tickValues = (range) => Array.from(new Set([range.min, referenceValue, range.max]));
    const tickFormat = isUnitScore ? d3.format('.1f') : d3.format('~g');
    svg.append('g')
      .attr('transform', `translate(0,${height - margin.bottom})`)
      .call(d3.axisBottom(x).tickValues(tickValues(xRange)).tickFormat(tickFormat).tickSizeOuter(0))
      .call((axis) => axis.select('.domain').attr('stroke', palette.border))
      .call((axis) => axis.selectAll('line').attr('stroke', palette.border).attr('opacity', 0.65))
      .call((axis) => axis.selectAll('text').attr('fill', palette.muted).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('strong')));
    svg.append('g')
      .attr('transform', `translate(${margin.left},0)`)
      .call(d3.axisLeft(y).tickValues(tickValues(yRange)).tickFormat(tickFormat).tickSizeOuter(0))
      .call((axis) => axis.select('.domain').attr('stroke', palette.border))
      .call((axis) => axis.selectAll('line').attr('stroke', palette.border).attr('opacity', 0.65))
      .call((axis) => axis.selectAll('text').attr('fill', palette.muted).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('strong')));
    svg.selectAll('.domain').attr('stroke', palette.border);
    svg.selectAll('.tick line').attr('stroke', palette.border).attr('opacity', 0.65);
    svg.append('text').attr('x', margin.left + plotW / 2).attr('y', height - margin.bottom + 42).attr('text-anchor', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('label')).text(xAxisLabel);
    svg.append('text').attr('transform', `translate(${compact ? 18 : 24},${margin.top + plotH / 2}) rotate(-90)`).attr('text-anchor', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('label')).text(yAxisLabel);
    const plotPoints = points.map((point, index) => {
      const targetX = x(numberValue(point.x));
      const targetY = y(numberValue(point.y));
      return { ...point, _index: index, _valueX: point.x, _valueY: point.y, _targetX: targetX, _targetY: targetY, x: targetX, y: targetY };
    });
    d3.forceSimulation(plotPoints)
      .force('x', d3.forceX((d) => d._targetX).strength(0.28))
      .force('y', d3.forceY((d) => d._targetY).strength(0.28))
      .force('collide', d3.forceCollide(compact ? 18 : 20))
      .stop()
      .tick(90);
    plotPoints.forEach((point) => {
      point.x = Math.max(margin.left + 18, Math.min(width - margin.right - 18, point.x));
      point.y = Math.max(margin.top + 18, Math.min(height - margin.bottom - 18, point.y));
    });
    const dots = svg.append('g').selectAll('g.quadrant-point').data(plotPoints).join('g').attr('class', 'quadrant-point').attr('transform', (d) => `translate(${d.x},${d.y})`);
    dots.append('circle').attr('r', compact ? 15 : 17).attr('fill', (d) => colorForTone(d.tone)).attr('stroke', '#fff7ef').attr('stroke-width', 3).attr('opacity', 0.96);
    dots.append('circle').attr('r', compact ? 7 : 8).attr('fill', '#fff7ef').attr('opacity', 0.18);
    dots.append('text').attr('text-anchor', 'middle').attr('dominant-baseline', 'middle').attr('fill', '#fff7ef').attr('font-size', compact ? chartFont.size.caption : chartFont.size.caption).attr('font-weight', fontWeight('emphasis')).text((d) => d._index + 1);
    const labelAnchor = (d) => d.x > refX ? 'end' : 'start';
    dots.append('text')
      .attr('x', (d) => d.x > refX ? -(compact ? 20 : 23) : compact ? 20 : 23)
      .attr('y', 4)
      .attr('text-anchor', labelAnchor)
      .attr('fill', palette.ink)
      .attr('font-size', compact ? chartFont.size.caption : chartFont.small)
      .attr('font-weight', fontWeight('label'))
      .text((d) => labelText(d.label, compact ? 12 : 18));
    dots.each(function(d) { addTitle(d3.select(this), `${d.label}: ${xAxisLabel} ${d._valueX}; ${yAxisLabel} ${d._valueY}`); });
    withTooltip(dots, (d) => tooltipHtml(d.label, [`${xAxisLabel}: ${d._valueX}`, `${yAxisLabel}: ${d._valueY}`, d.detail]));
    const legend = svg.append('g').attr('transform', `translate(${margin.left},${height - margin.bottom + 64})`);
    const legendRows = legend.selectAll('g').data(points.map((point, index) => ({ ...point, _index: index }))).join('g').attr('transform', (_d, index) => {
      const col = compact ? index % 2 : index;
      const row = compact ? Math.floor(index / 2) : 0;
      return `translate(${col * (compact ? plotW / 2 : Math.min(132, plotW / Math.max(points.length, 1)))},${row * 22})`;
    });
    legendRows.append('circle').attr('cx', 7).attr('cy', -4).attr('r', 7).attr('fill', (d) => colorForTone(d.tone));
    legendRows.append('text').attr('x', 7).attr('y', 0).attr('text-anchor', 'middle').attr('fill', '#fff7ef').attr('font-size', chartFont.size.micro).attr('font-weight', fontWeight('label')).text((d) => d._index + 1);
    legendRows.append('text').attr('x', 20).attr('y', 0).attr('fill', palette.ink).attr('font-size', compact ? chartFont.size.caption : chartFont.small).attr('font-weight', fontWeight('strong')).text((d) => labelText(d.label, compact ? 16 : 14));
    withTooltip(legendRows, (d) => tooltipHtml(d.label, [`${xAxisLabel}: ${d.x}`, `${yAxisLabel}: ${d.y}`, d.detail]));
  };

  const renderHeatmap = (element, payload) => {
    const columns = arr(payload.data.columns);
    const rows = arr(payload.data.rows);
    const heatColors = {
      1: '#dcebe7',
      2: '#f2d8a0',
      3: '#c94f43',
    };
    const heatTextColors = {
      1: palette.ink,
      2: palette.ink,
      3: '#fff7ef',
    };
    const { svg, width, height } = svgBase(element, Math.max(340, rows.length * 68 + 96));
    const margin = { top: 58, right: 24, bottom: 26, left: Math.min(220, Math.max(136, Math.max(...rows.map((row) => String(row.label ?? '').length), 8) * 8)) };
    const x = d3.scaleBand().domain(columns).range([margin.left, width - margin.right]).padding(0.08);
    const y = d3.scaleBand().domain(rows.map((row) => row.label)).range([margin.top, height - margin.bottom]).padding(0.08);
    svg.append('g').selectAll('text').data(columns).join('text').attr('x', (d) => x(d) + x.bandwidth() / 2).attr('y', margin.top - 16).attr('text-anchor', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('strong')).text((d) => labelText(d, 14));
    svg.append('g').selectAll('text').data(rows).join('text').attr('x', margin.left - 12).attr('y', (d) => y(d.label) + y.bandwidth() / 2 + 4).attr('text-anchor', 'end').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('strong')).each(function(d) {
      renderWrappedText(d3.select(this), d.label, { maxChars: 22, maxLines: 2, lineHeight: chartFont.lineHeight.tight });
    });
    const cells = [];
    rows.forEach((row) => arr(row.values).forEach((cell, colIndex) => cells.push({ row: row.label, column: columns[colIndex], cell, value: riskValue(cell.tone) })));
    const g = svg.append('g').selectAll('g').data(cells).join('g');
    g.append('rect').attr('x', (d) => x(d.column)).attr('y', (d) => y(d.row)).attr('width', x.bandwidth()).attr('height', y.bandwidth()).attr('rx', 7).attr('fill', (d) => heatColors[d.value]).attr('stroke', '#fff7ef').attr('stroke-width', 3);
    g.append('text').attr('x', (d) => x(d.column) + x.bandwidth() / 2).attr('y', (d) => y(d.row) + y.bandwidth() / 2).attr('text-anchor', 'middle').attr('dominant-baseline', 'middle').attr('fill', (d) => heatTextColors[d.value]).attr('font-size', chartFont.small).attr('font-weight', fontWeight('strong')).each(function(d) {
      renderWrappedText(d3.select(this), d.cell.label ?? d.cell, { maxChars: Math.max(8, Math.floor(x.bandwidth() / 7)), maxLines: Math.max(1, Math.floor(y.bandwidth() / 16)), lineHeight: chartFont.lineHeight.tight });
    });
    g.each(function(d) { addTitle(d3.select(this), `${d.row} × ${d.column}: ${d.cell.label ?? d.cell}`); });
    withTooltip(g, (d) => tooltipHtml(`${d.row} × ${d.column}`, [d.cell.label ?? d.cell, d.cell.detail]));
  };

  const renderCohort = (element, payload) => {
    const columns = arr(payload.data.columns);
    const rows = arr(payload.data.rows);
    const { svg, width, height } = svgBase(element, Math.max(340, rows.length * 58 + 92));
    const margin = { top: 58, right: 24, bottom: 26, left: 156 };
    const x = d3.scaleBand().domain(columns).range([margin.left, width - margin.right]).padding(0.08);
    const y = d3.scaleBand().domain(rows.map((row) => row.label)).range([margin.top, height - margin.bottom]).padding(0.08);
    // Adaptive color scale. Default to retention percentages 0–100 (the
    // canonical cohort use case) but fall back to the observed numeric range
    // so misuses with ordinal scoring (e.g. 0–3) still produce visible
    // contrast instead of a single flat color.
    const numericValues = [];
    for (const row of rows) for (const cell of arr(row.values)) {
      const value = Number(cell?.value ?? String(cell?.label ?? '').replace(/[^0-9.-]/g, ''));
      if (Number.isFinite(value)) numericValues.push(value);
    }
    const dataMin = numericValues.length ? Math.min(...numericValues) : 0;
    const dataMax = numericValues.length ? Math.max(...numericValues) : 100;
    const fitsPercent = dataMin >= 0 && dataMax <= 100 && dataMax > 10;
    const colorDomain = fitsPercent
      ? [0, 50, 100]
      : dataMax === dataMin
        ? [dataMin, dataMin, dataMax + 1]
        : [dataMin, (dataMin + dataMax) / 2, dataMax];
    const color = d3.scaleLinear().domain(colorDomain).range(['#f4c7bd', '#f2d8a0', '#0f766e']);
    svg.append('g').selectAll('text').data(columns).join('text').attr('x', (d) => x(d) + x.bandwidth() / 2).attr('y', margin.top - 16).attr('text-anchor', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('strong')).text((d) => labelText(d, 14));
    svg.append('g').selectAll('text').data(rows).join('text').attr('x', margin.left - 12).attr('y', (d) => y(d.label) + y.bandwidth() / 2 + 4).attr('text-anchor', 'end').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('strong')).each(function(d) {
      renderWrappedText(d3.select(this), d.label, { maxChars: 20, maxLines: 2, lineHeight: chartFont.lineHeight.tight });
    });
    const cells = [];
    rows.forEach((row) => arr(row.values).forEach((cell, colIndex) => {
      const value = Number(cell?.value ?? String(cell?.label ?? '').replace(/[^0-9.-]/g, ''));
      cells.push({ row: row.label, column: columns[colIndex], cell, value: Number.isFinite(value) ? value : 0 });
    }));
    const g = svg.append('g').selectAll('g').data(cells).join('g');
    g.append('rect').attr('x', (d) => x(d.column)).attr('y', (d) => y(d.row)).attr('width', x.bandwidth()).attr('height', y.bandwidth()).attr('rx', 7).attr('fill', (d) => color(d.value)).attr('stroke', '#fff7ef').attr('stroke-width', 3);
    g.append('text').attr('x', (d) => x(d.column) + x.bandwidth() / 2).attr('y', (d) => y(d.row) + y.bandwidth() / 2).attr('text-anchor', 'middle').attr('dominant-baseline', 'middle').attr('fill', palette.ink).attr('font-size', chartFont.small).attr('font-weight', fontWeight('strong')).each(function(d) {
      renderWrappedText(d3.select(this), d.cell.label ?? d.cell.displayValue ?? d.value, { maxChars: Math.max(7, Math.floor(x.bandwidth() / 7)), maxLines: Math.max(1, Math.floor(y.bandwidth() / 16)), lineHeight: chartFont.lineHeight.tight });
    });
    g.each(function(d) { addTitle(d3.select(this), `${d.row} × ${d.column}: ${d.cell.label ?? d.cell.displayValue ?? d.value}`); });
    withTooltip(g, (d) => tooltipHtml(`${d.row} × ${d.column}`, [d.cell.label ?? d.cell.displayValue ?? d.value, d.cell.detail]));
  };

  const RENDERERS = {
    timeline: renderTimeline,
    flow: renderFlow,
    stack: renderStack,
    pyramid: renderPyramid,
    'journey-map': renderJourneyMap,
    kpi: renderKpi,
    waterfall: renderWaterfall,
    funnel: renderFunnel,
    range: renderRange,
    bar: renderBar,
    matrix: renderHeatmap,
    cohort: renderCohort,
    quadrant: renderQuadrant,
    dag: renderDag,
  };

  const normalizeRenderedTypography = (element) => {
    d3.select(element)
      .selectAll('svg text')
      .attr('font-family', chartFont.family);
  };

  const normalizeRenderedFlatStyle = (element) => {
    const svg = d3.select(element).select('svg');
    svg.selectAll('filter').remove();
    svg.selectAll('[filter]').attr('filter', null);
    svg.selectAll('[style*="drop-shadow"], [style*="box-shadow"]').style('filter', null).style('box-shadow', null);
  };

  const renderD3 = (element, payload) => {
    let result;
    result = RENDERERS[payload.type]?.(element, payload);
    normalizeRenderedTypography(element);
    normalizeRenderedFlatStyle(element);
    return result;
  };

  const renderCharts = () => {
    document.querySelectorAll('script.figure-chart-data').forEach((script) => {
      if (script.dataset.rendered === 'true') return;
      const payload = JSON.parse(script.textContent || '{}');
      const element = document.getElementById(payload.id);
      if (!element) return;
      renderD3(element, payload);
      script.dataset.rendered = 'true';
    });
  };
  renderCharts();
  window.addEventListener('resize', () => {
    document.querySelectorAll('script.figure-chart-data').forEach((script) => {
      script.dataset.rendered = 'false';
    });
    renderCharts();
  });
</script>

