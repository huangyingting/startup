      const modules = arr(d.modules).slice(0, compact ? 1 : 2);
      const output = arr(d.outputs)[0];
      const pills = [...modules.map((label) => ({ label, tone: d.tone })), ...(output ? [{ label: `→ ${output}`, tone: 'neutral' }] : [])];
      let xCursor = 0;
      const row = d3.select(this);
      pills.forEach((pill) => {
        const text = labelText(pill.label, compact ? 12 : 16);
