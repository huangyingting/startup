---
import ClaimRefs from './ClaimRefs.astro';
import { RENDERED_FIGURE_TYPES } from '../lib/figures.mjs';

interface Props {
  figure: any;
  claims?: any[];
  sources?: any[];
}

const { figure, claims = [], sources = [] } = Astro.props;
const type = figure?.type ?? 'flow';
const layout = figure?.layout ?? 'standard';
const data = figure?.data ?? {};
const chartTypes = new Set(RENDERED_FIGURE_TYPES);
const usesD3Chart = chartTypes.has(type);
const chartId = `chart-${String(figure?.id ?? 'figure').replace(/[^a-z0-9_-]/gi, '-')}-${Math.random().toString(36).slice(2, 9)}`;
const arr = <T = any>(value: T[] | undefined | null): T[] => Array.isArray(value) ? value : [];
const blockRefs = (block: any) => arr<string>(block?.claimRefs).slice(0, 6);
const chartPayload = usesD3Chart ? { id: chartId, type, ...(layout === 'wide' ? { layout } : {}), data } : null;
---

<figure class:list={['native-figure', `figure-${type}`, `layout-${layout}`]}>
  <figcaption>{figure.id}: {figure.title}</figcaption>

  {figure.summary && <p class="figure-summary">{figure.summary}</p>}

  {usesD3Chart && <div id={chartId} class:list={['d3-figure', `chart-${type}`]}></div>}

  {type === 'other' && (
    <div class="figure-fallback" role="note">
      <strong>Generic figure</strong>
      <p>Fallback renderer for generic figures.</p>
    </div>
  )}

  {figure.approximationNotes && <p class="figure-note">{figure.approximationNotes}</p>}
  <ClaimRefs refs={blockRefs(figure)} claims={claims} sources={sources} />
  {chartPayload && <script type="application/json" class="figure-chart-data" set:html={JSON.stringify(chartPayload)}></script>}
</figure>

<script>
  import * as d3 from 'd3';

  const palette = {
    claret: '#990f3d',
    ink: '#33302e',
    muted: '#6b625c',
    border: '#d8ccc2',
    paper: '#fff7ef',
    positive: '#0f766e',
    risk: '#b42318',
    opportunity: '#b8860b',
    neutral: '#990f3d',
  };

  const arr = (value) => Array.isArray(value) ? value : [];
  const colorForTone = (tone) => {
    if (tone === 'positive' || tone === 'low') return palette.positive;
    if (tone === 'risk' || tone === 'critical' || tone === 'high' || tone === 'negative' || tone === 'adverse') return palette.risk;
    if (tone === 'opportunity' || tone === 'warning' || tone === 'medium') return palette.opportunity;
    return palette.neutral;
  };
  const riskValue = (tone) => {
    if (tone === 'high' || tone === 'critical' || tone === 'risk' || tone === 'negative' || tone === 'adverse') return 3;
    if (tone === 'medium' || tone === 'warning' || tone === 'neutral') return 2;
    return 1;
  };
  const labelText = (text, max = 24) => String(text ?? '').length > max ? `${String(text).slice(0, max - 1)}…` : String(text ?? '');
  const numberValue = (value) => Number(value) || 0;
  const valueLabel = (item) => item?.displayValue ?? item?.value ?? '';
  const fullValueLabel = (item) => item?.displayValue ?? item?.value ?? item?.score ?? item?.label ?? '';
  // Safely render any cell-like value (string, number, or object) as text.
  // Object cells use canonical display fields (`label`, `displayValue`,
  // `value`, `score`); blindly stringifying an object produces
  // "[object Object]". Always route cell text through this helper.
  const safeText = (value) => {
    if (value == null) return '';
    if (typeof value === 'string' || typeof value === 'number') return String(value);
    if (typeof value === 'object') {
      const text = value.label ?? value.displayValue ?? value.value;
      if (text != null && String(text).trim() !== '') return String(text);
      if (value.score != null) return String(value.score);
      return '';
    }
    return String(value);
  };

  const chartFont = {
    family: 'var(--font-sans, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif)',
    size: {
      micro: 8,
      tiny: 9.5,
      caption: 10.5,
      small: 12,
      axis: 13,
      label: 14,
      title: 16,
      value: 18,
      large: 20,
      arrow: 24,
      metric: 26,
    },
    weight: {
      regular: 650,
      body: 700,
      medium: 750,
      strong: 800,
      label: 900,
      emphasis: 950,
    },
    tracking: {
      subtle: '0em',
      caps: '0em',
    },
    lineHeight: {
      compact: 12,
      tight: 13,
      small: 15,
      label: 16,
      title: 18,
    },
    cssVar: {
      kicker: 'var(--chart-fs-kicker)',
      caption: 'var(--chart-fs-caption)',
      body: 'var(--chart-fs-body)',
      note: 'var(--chart-fs-note)',
    },
  };
  chartFont.axis = chartFont.size.axis;
  chartFont.label = chartFont.size.label;
  chartFont.small = chartFont.size.small;
  const fontSize = (name) => chartFont.size[name] ?? name;
  const fontWeight = (name) => chartFont.weight[name] ?? name;
  const tooltip = (() => {
    const node = d3.select('body').selectAll('.d3-chart-tooltip').data([null]).join('div').attr('class', 'd3-chart-tooltip').attr('role', 'tooltip');
    const move = (event) => {
      const gap = window.innerWidth < 520 ? 10 : 14;
      const pad = window.innerWidth < 520 ? 10 : 14;
      const tooltipNode = node.node();
      const box = tooltipNode?.getBoundingClientRect?.() ?? { width: 0, height: 0 };
      const spaceRight = window.innerWidth - event.clientX;
      const spaceBottom = window.innerHeight - event.clientY;
      const placeLeft = spaceRight < box.width + gap + pad && event.clientX > box.width + gap + pad;
      const placeTop = spaceBottom < box.height + gap + pad && event.clientY > box.height + gap + pad;
      const rawLeft = placeLeft ? event.clientX - box.width - gap : event.clientX + gap;
      const rawTop = placeTop ? event.clientY - box.height - gap : event.clientY + gap;
      const left = Math.max(pad, Math.min(window.innerWidth - box.width - pad, rawLeft));
      const top = Math.max(pad, Math.min(window.innerHeight - box.height - pad, rawTop));
      const pointerX = Math.max(18, Math.min(box.width - 18, event.clientX - left));
      const tooltipFont = window.innerWidth < 520 ? chartFont.size.small : window.innerWidth < 760 ? chartFont.axis : 13.8;
      node
        .attr('data-placement-x', placeLeft ? 'left' : 'right')
        .attr('data-placement-y', placeTop ? 'top' : 'bottom')
        .style('left', `${left}px`)
        .style('top', `${top}px`)
        .style('--tooltip-pointer-x', `${pointerX}px`)
        .style('--tooltip-font', `${tooltipFont}px`);
    };
    return {
      show(event, html) {
        node.html(html).classed('is-visible', true);
        move(event);
      },
      move,
      hide() {
        node.classed('is-visible', false);
      },
    };
  })();
  const escapeHtml = (value) => String(value ?? '').replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char]));
  const tooltipHtml = (title, lines = []) => `<strong>${escapeHtml(title)}</strong>${lines.filter(Boolean).map((line) => `<span>${escapeHtml(line)}</span>`).join('')}`;
  const shouldShowTooltip = () => true;
  document.addEventListener('pointerdown', (event) => {
    if (event.target?.closest?.('.d3-figure')) return;
    tooltip.hide();
  });
  const withTooltip = (selection, htmlForDatum) => selection
    .style('cursor', 'default')
    .on('pointerenter', function(event, datum) {
      d3.select(this).classed('is-hovered', true);
      if (!shouldShowTooltip()) return;
      const html = typeof htmlForDatum === 'function' ? htmlForDatum(datum) : htmlForDatum;
      tooltip.show(event, html);
    })
    .on('pointerdown', function(event, datum) {
      event.stopPropagation();
      d3.select(this).classed('is-hovered', true);
      const html = typeof htmlForDatum === 'function' ? htmlForDatum(datum) : htmlForDatum;
      tooltip.show(event, html);
    })
    .on('pointermove', (event) => {
      if (shouldShowTooltip()) tooltip.move(event);
    })
    .on('pointerleave', function() {
      d3.select(this).classed('is-hovered', false);
      tooltip.hide();
    });
  const wrapWords = (text, maxChars = 18, maxLines = 2) => {
    const chunkSize = Math.max(4, Math.floor(maxChars));
    const splitLongWord = (word) => {
      const chars = Array.from(String(word ?? ''));
      if (chars.length <= chunkSize) return [word];
      const chunks = [];
      for (let index = 0; index < chars.length; index += chunkSize) chunks.push(chars.slice(index, index + chunkSize).join(''));
      return chunks;
    };
    const words = String(text ?? '').split(/\s+/).filter(Boolean).flatMap(splitLongWord);
    if (!words.length) return [''];
    const lines = [];
    let line = '';
    words.forEach((word) => {
      const next = line ? `${line} ${word}` : word;
      if (next.length > maxChars && line) {
        lines.push(line);
        line = word;
      } else {
        line = next;
      }
    });
    if (line) lines.push(line);
    const clipped = lines.slice(0, maxLines);
    if (lines.length > maxLines) clipped[clipped.length - 1] = labelText(clipped[clipped.length - 1], Math.max(4, maxChars - 1));
    return clipped;
  };
  const renderWrappedText = (selection, text, { maxChars = 18, maxLines = 2, lineHeight = chartFont.lineHeight.small, dy = 0 } = {}) => {
    const x = selection.attr('x') ?? 0;
    selection.text(null);
    const lines = wrapWords(text, maxChars, maxLines);
    const offset = dy - ((lines.length - 1) * lineHeight) / 2;
    lines.forEach((line, index) => {
      selection.append('tspan').attr('x', x).attr('dy', index === 0 ? offset : lineHeight).text(line);
    });
  };
  const renderLineBlock = (selection, lines, { x = 0, y = 0, lineHeight = chartFont.lineHeight.small } = {}) => {
    selection.text(null).attr('x', x).attr('y', y);
    lines.forEach((line, index) => {
      selection.append('tspan').attr('x', x).attr('dy', index === 0 ? 0 : lineHeight).text(line);
    });
  };
  const svgBase = (element, height = 340, minWidthOverride = null) => {
    const containerWidth = Math.floor(element.getBoundingClientRect().width || 760);
    const minInternalWidth = containerWidth < 420 ? 420 : 520;
    const width = Math.max(minInternalWidth, containerWidth, minWidthOverride ?? 0);
    const displayHeight = Math.ceil(height * Math.min(1, containerWidth / width));
    d3.select(element).selectAll('*').remove();
    const svg = d3.select(element)
      .append('svg')
      .attr('viewBox', `0 0 ${width} ${height}`)
      .attr('role', 'img')
      .attr('width', '100%')
      .attr('height', displayHeight)
      .style('font-family', chartFont.family)
      .style('display', 'block');
    return { svg, width, height };
  };
  const addTitle = (selection, text) => selection.attr('aria-label', String(text ?? ''));
  const axisBottom = (g, scale, y, ticks = 4) => g.append('g')
    .attr('transform', `translate(0,${y})`)
    .call(d3.axisBottom(scale).ticks(ticks).tickSizeOuter(0))
    .call((axis) => axis.select('.domain').attr('stroke', palette.border))
    .call((axis) => axis.selectAll('line').attr('stroke', palette.border))
    .call((axis) => axis.selectAll('text').attr('fill', palette.muted).attr('font-size', chartFont.axis));
  const axisLeft = (g, scale, x) => g.append('g')
    .attr('transform', `translate(${x},0)`)
    .call(d3.axisLeft(scale).tickSizeOuter(0))
    .call((axis) => axis.select('.domain').remove())
    .call((axis) => axis.selectAll('line').remove())
    .call((axis) => axis.selectAll('text').attr('fill', palette.ink).attr('font-size', chartFont.axis).attr('font-weight', fontWeight('body')).each(function(d) {
      const text = d3.select(this);
      renderWrappedText(text, d, { maxChars: 19, maxLines: 2, lineHeight: chartFont.lineHeight.tight });
    }));

  const renderDag = (element, payload) => {
    const nodes = arr(payload.data.nodes).map((node, index) => ({ ...node, _key: node.id ?? node.label ?? String(index + 1), _index: index }));
    const edges = arr(payload.data.edges).map((edge, index) => ({ ...edge, _edgeIndex: index, from: edge.from ?? edge.source, to: edge.to ?? edge.target }));
    if (!nodes.length) return;
    const byKey = new Map(nodes.map((node) => [node._key, node]));
    const incoming = d3.group(edges, (edge) => edge.to);
    const outgoing = d3.group(edges, (edge) => edge.from);
    // Cycle-safe topological-ish depth from roots. Some reports label graphs as
    // DAGs while still containing feedback loops (for example support ↔ users).
    // A longest-path relaxation loop never converges on cycles, so use Kahn's
    // algorithm with provisional depths from already-processed predecessors and
    // preserve unresolved cyclic nodes at their best known stage.
    const roots = nodes.filter((node) => !incoming.has(node._key));
    const depthByKey = new Map();
    const indegreeByKey = new Map(nodes.map((node) => [node._key, arr(incoming.get(node._key)).length]));
    const processed = new Set();
    const queue = (roots.length ? roots : [nodes[0]]).filter(Boolean);
    queue.forEach((node) => depthByKey.set(node._key, 0));
    while (queue.length) {
      const current = queue.shift();
      if (!current || processed.has(current._key)) continue;
      processed.add(current._key);
      const currentDepth = depthByKey.get(current._key) ?? 0;
      for (const edge of arr(outgoing.get(current._key))) {
        const target = byKey.get(edge.to);
        if (!target || processed.has(target._key)) continue;
        depthByKey.set(target._key, Math.max(depthByKey.get(target._key) ?? 0, currentDepth + 1));
        const remaining = Math.max(0, (indegreeByKey.get(target._key) ?? 0) - 1);
        indegreeByKey.set(target._key, remaining);
        if (remaining === 0) queue.push(target);
      }
    }
    for (const node of nodes) if (!depthByKey.has(node._key)) depthByKey.set(node._key, 0);
    const maxDepth = Math.max(0, ...depthByKey.values());
    const stages = Array.from({ length: maxDepth + 1 }, () => []);
    nodes.forEach((node) => stages[depthByKey.get(node._key) ?? 0].push(node));
    // Barycenter pass: reorder nodes within each stage so that edges between
    // adjacent stages cross less often. This makes far more edges qualify for
    // the cheap directOrthogonalPaths route and keeps the visual layout tidy.
    // Skip entirely when no stage has 2+ nodes (linear chains gain nothing).
    if (stages.length > 1 && stages.some((stage) => stage.length >= 2)) {
      const orderInStage = new Map();
      const refreshOrder = () => {
        orderInStage.clear();
        for (const stage of stages) {
          stage.forEach((node, index) => orderInStage.set(node._key, index));
        }
      };
      refreshOrder();
      const barycenter = (node, neighborKeys) => {
        if (!neighborKeys.length) return orderInStage.get(node._key) ?? 0;
        let sum = 0;
        let count = 0;
        for (const key of neighborKeys) {
          const idx = orderInStage.get(key);
          if (idx == null) continue;
          sum += idx;
          count += 1;
        }
        return count ? sum / count : (orderInStage.get(node._key) ?? 0);
      };
      const sweep = (direction) => {
        const range = direction === 'down'
          ? Array.from({ length: stages.length - 1 }, (_, i) => i + 1)
          : Array.from({ length: stages.length - 1 }, (_, i) => stages.length - 2 - i);
        for (const stageIndex of range) {
          const stage = stages[stageIndex];
          if (stage.length < 2) continue;
          const decorated = stage.map((node, originalIndex) => {
            const neighborGroup = direction === 'down'
              ? arr(incoming.get(node._key)).map((edge) => edge.from)
              : arr(outgoing.get(node._key)).map((edge) => edge.to);
            return { node, originalIndex, b: barycenter(node, neighborGroup) };
          });
          decorated.sort((a, b) => (a.b - b.b) || (a.originalIndex - b.originalIndex));
          stages[stageIndex] = decorated.map((entry) => entry.node);
          refreshOrder();
        }
      };
      sweep('down');
      sweep('up');
      sweep('down');
    }
    /* Stage names: derive directly from the nodes that landed in each
     * column. This is more informative than generic "Stage N" / "Tier N"
     * labels because the reader sees the actual dependency name (e.g.
     * "input / tts → express2 → renderer → cdn → api → lms") above each
     * column. When a column has multiple nodes we join their ids with
     * " / "; when an id is missing we fall back to the node label. */
    const stageNodeLabel = (node) => {
      const raw = node.id ?? node.label ?? '';
      return String(raw).trim().toUpperCase();
    };
    const stageNames = stages.map((stage) => stage.map(stageNodeLabel).filter(Boolean).join(' / '));
    const stageRole = (index) => index === 0
      ? 'input'
      : index === stages.length - 1
        ? 'impact'
        : 'core';
    const containerWidth = element.getBoundingClientRect().width || 760;
    const prefersWide = payload.layout === 'wide';
    /* Keep explicitly-wide DAGs horizontal unless the viewport is truly
     * phone-sized. Risk transmission maps are much more readable as
     * left-to-right systems diagrams; deep standard DAGs still switch to
     * vertical stacked mode. */
    const compact = containerWidth < (prefersWide ? 520 : 640) || (!prefersWide && stages.length >= 5);
    const maxRows = Math.max(...stages.map((stage) => stage.length), 1);
    const cardH = compact ? 74 : 78;
    const compactHeight = 74 + stages.reduce((sum, stage) => sum + 30 + stage.length * cardH + Math.max(0, stage.length - 1) * 16 + 36, 0);
    const horizontalMinWidth = compact ? null : Math.max(containerWidth, prefersWide && stages.length > 4 ? stages.length * 190 : 0, 760);
    const { svg, width, height } = svgBase(element, compact ? Math.max(540, compactHeight) : Math.max(380, 126 + maxRows * (cardH + 42)), horizontalMinWidth);
    const margin = compact ? { top: 36, right: 24, bottom: 34, left: 24 } : { top: 42, right: 22, bottom: 40, left: 22 };
    const innerW = width - margin.left - margin.right;
    const innerH = height - margin.top - margin.bottom;
    const stageW = innerW / Math.max(stages.length, 1);
    /* In compact (vertical) mode reserve horizontal gutter space around the
     * centered cards. Edges alternate between left and right gutters by
     * stage-pair so the chart does not collapse into one cable bundle. */
    const compactGutter = compact ? Math.min(128, Math.max(72, innerW * 0.18)) : 0;
    const horizontalGap = stages.length >= 4 ? 28 : 36;
    const preferredCardW = prefersWide ? 184 : 176;
    const horizontalCardW = stages.length
      ? (innerW - horizontalGap * Math.max(0, stages.length - 1)) / stages.length
      : preferredCardW;
    const cardW = compact ? Math.max(220, Math.min(420, innerW - 18 - compactGutter)) : Math.max(136, Math.min(preferredCardW, horizontalCardW));
    const compactCenterX = width / 2;
    const stageCenterXs = compact ? [] : stages.map((_stage, stageIndex) => {
      if (stages.length <= 1) return compactCenterX;
      const firstCenter = margin.left + cardW / 2;
      const lastCenter = width - margin.right - cardW / 2;
      return firstCenter + ((lastCenter - firstCenter) * stageIndex) / (stages.length - 1);
    });
    const stageCenterX = (stageIndex) => stageCenterXs[stageIndex] ?? compactCenterX;
    const stageGapW = stageCenterXs.length > 1 ? Math.abs(stageCenterXs[1] - stageCenterXs[0]) : stageW;
    const stageBoundaryX = (stageIndex) => (stageCenterX(stageIndex) + stageCenterX(Math.min(stageIndex + 1, stages.length - 1))) / 2;
    const stageLabels = [];
    const positions = [];
    if (compact) {
      let y = margin.top;
      stages.forEach((stage, stageIndex) => {
        stageLabels.push({ label: stageNames[stageIndex], x: compactCenterX, y: y + 2 });
        y += 34;
        stage.forEach((node, index) => {
          positions.push({ ...node, _stage: stageIndex, _role: stageRole(stageIndex), x: compactCenterX, y: y + cardH / 2 + index * (cardH + 16) });
        });
        y += stage.length * cardH + Math.max(0, stage.length - 1) * 16 + 36;
      });
    } else {
      stages.forEach((stage, stageIndex) => {
        stageLabels.push({ label: stageNames[stageIndex], x: stageCenterX(stageIndex), y: 24 });
        const gap = innerH / Math.max(stage.length, 1);
        stage.forEach((node, index) => {
          positions.push({ ...node, _stage: stageIndex, _role: stageRole(stageIndex), x: stageCenterX(stageIndex), y: margin.top + gap * index + gap / 2 });
        });
      });
    }
    const positionedByKey = new Map(positions.map((node) => [node._key, node]));
    const routedEdges = edges.map((edge, index) => ({ ...edge, _edgeIndex: index, source: positionedByKey.get(edge.from), target: positionedByKey.get(edge.to) })).filter((edge) => edge.source && edge.target);
    /* Route edges through explicit ports rather than every line entering /
     * leaving a card at its centre. This is the key to keeping DAGs readable:
     * a node with three outgoing edges gets three different right-side exit
     * points; a node with two incoming edges gets two different left-side
     * entry points. Lanes are also allocated per stage-pair gutter instead of
     * globally, so parallel edges only compete with neighbours in the same
     * gutter. */
    const portOffsetForSpan = (index, count, span) => {
      if (count <= 1) return 0;
      const usable = Math.max(24, span - 28);
      // Spread parallel ports across the full usable span when reasonable, but
      // hold a generous minimum gap so two edges from the same side stay
      // visually distinct rather than collapsing into one stub line.
      const step = Math.min(44, Math.max(16, usable / Math.max(1, count - 1)));
      return (index - (count - 1) / 2) * step;
    };
    const bySource = d3.group(routedEdges, (edge) => edge.source._key);
    const byTarget = d3.group(routedEdges, (edge) => edge.target._key);
    const byStagePair = d3.group(routedEdges, (edge) => `${edge.source._stage}->${edge.target._stage}`);
    for (const group of bySource.values()) {
      [...group].sort((a, b) => (a.target.y - b.target.y) || (a.target.x - b.target.x)).forEach((edge, index) => { edge._sourcePortIndex = index; edge._sourcePortCount = group.length; });
    }
    for (const group of byTarget.values()) {
      [...group].sort((a, b) => (a.source.y - b.source.y) || (a.source.x - b.source.x)).forEach((edge, index) => { edge._targetPortIndex = index; edge._targetPortCount = group.length; });
    }
    for (const group of byStagePair.values()) {
      [...group].sort((a, b) => (a.source.y - b.source.y) || (a.target.y - b.target.y)).forEach((edge, index) => { edge._laneIndex = index; edge._laneCount = group.length; });
    }
    const defs = svg.append('defs');
    defs.append('marker').attr('id', `${payload.id}-dependency-arrow`).attr('viewBox', '0 -5 10 10').attr('refX', 8.2).attr('refY', 0).attr('markerWidth', 5.5).attr('markerHeight', 5.5).attr('orient', 'auto')
      .append('path').attr('d', 'M0,-4L9,0L0,4').attr('fill', palette.claret);
    const shadow = defs.append('filter').attr('id', `${payload.id}-dependency-shadow`).attr('x', '-16%').attr('y', '-22%').attr('width', '132%').attr('height', '150%');
    shadow.append('feDropShadow').attr('dx', 0).attr('dy', 4).attr('stdDeviation', 4).attr('flood-color', 'rgba(51,48,46,0.13)');
    svg.append('g').selectAll('text').data(stageLabels).join('text')
      .attr('x', (label) => label.x)
      .attr('y', (label) => label.y)
      .attr('text-anchor', 'middle')
      .attr('fill', palette.claret)
      .attr('font-size', chartFont.small)
      .attr('font-weight', fontWeight('emphasis'))
      .attr('letter-spacing', chartFont.tracking.caps)
      .each(function(label) {
        renderWrappedText(d3.select(this), label.label, {
          maxChars: compact ? Math.max(18, Math.floor((width - 68) / 7.2)) : Math.max(10, Math.floor(stageGapW / 8.2)),
          maxLines: compact ? 2 : 1,
          lineHeight: chartFont.lineHeight.tight,
        });
      });
    const padRect = 10;
    const routeGap = compact ? 18 : 22;
    const stub = compact ? 14 : 16;
    const norm = (value) => Math.round(value * 100) / 100;
    const nodeRects = new Map(positions.map((node) => [node._key, {
      key: node._key,
      left: node.x - cardW / 2 - padRect,
      right: node.x + cardW / 2 + padRect,
      top: node.y - cardH / 2 - padRect,
