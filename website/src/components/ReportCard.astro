---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../lib/i18n';
import { displayLabel } from '../lib/display';
import { loadLocalizedIndex } from '../content/reports-loader';

interface Props { entry: CollectionEntry<'reports'>; lang?: Lang; }
const { entry, lang = 'en' } = Astro.props;
const localized = lang === 'zh' ? loadLocalizedIndex(entry.id, 'zh') : null;
const data = localized ? { ...entry.data, ...localized } : entry.data;
const base = import.meta.env.BASE_URL;
const href = lang === 'zh' ? `${base}zh/${entry.data.folderSlug}/` : `${base}${entry.data.folderSlug}/`;
const labels = lang === 'zh'
  ? { valuation: '估值', revenue: '收入 run-rate', arr: 'ARR', growth: '增长', nrr: 'NRR', risk: '风险', confidence: '置信度', sources: '来源', report: '报告', rating: '评分' }
  : { valuation: 'Valuation', revenue: 'Revenue run-rate', arr: 'ARR', growth: 'Growth', nrr: 'NRR', risk: 'Risk', confidence: 'confidence', sources: 'sources', report: 'report', rating: 'Rating' };

function metric(value: number | null | undefined, suffix = '') {
  if (value === null || value === undefined) return null;
  return `${value.toLocaleString()}${suffix}`;
}
function moneyM(value: number | null | undefined) {
  if (value === null || value === undefined) return null;
  if (Math.abs(value) >= 1000) return `$${(value / 1000).toLocaleString(undefined, { maximumFractionDigits: 1 })}B`;
  return `$${value.toLocaleString(undefined, { maximumFractionDigits: 1 })}M`;
}
const metrics = data.keyMetrics;
const metricRows = [
  [labels.valuation, moneyM(metrics?.valuationUsdM)],
  [labels.revenue, moneyM(metrics?.revenueRunRateUsdM)],
  [labels.arr, moneyM(metrics?.arrUsdM)],
  [labels.growth, metric(metrics?.revenueGrowthYoYPct, '%')],
  [labels.nrr, metric(metrics?.nrrPct, '%')],
].filter(([, value]) => value);
---
<a class="report-card" href={href}>
  <div class="card-topline">
    <span>{data.company.name}</span>
    <span>{data.company.sector ?? 'other'}</span>
  </div>
  <h3>{data.title}</h3>
  <p>{data.headline}</p>
  <div class="card-badges">
    <span>{displayLabel(data.recommendation)}</span>
    <span>{displayLabel(data.valuationStance)}</span>
    <span>{labels.risk}: {displayLabel(data.riskRating)}</span>
  </div>
  {metricRows.length > 0 && (
    <dl class="card-metrics">
      {metricRows.map(([name, value]) => <><dt>{name}</dt><dd>{value}</dd></>)}
    </dl>
  )}
  <div class="card-footer">
    <strong>{data.overallScore.toFixed(1)}</strong>
    <span>{labels.rating}</span>
    <span>·</span>
    <span>{data.sourceStats.sourcesRetained} {labels.sources}</span>
    <span>·</span>
    <span>{data.figureCount} figs / {data.tableCount} tables</span>
  </div>
</a>
<style>
  .report-card {
    display: block;
    min-height: 100%;
    border: var(--report-rule);
    background: var(--surface-paper);
    padding: var(--space-4);
    color: inherit;
    text-decoration: none;
    transition: border-color 120ms ease, background-color 120ms ease;
  }
  .report-card:hover { border-color: var(--claret); background: color-mix(in srgb, var(--claret) 4%, var(--surface-paper)); }
  .card-topline, .card-footer, .card-badges { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2); font-family: var(--font-sans); font-size: var(--fs-xs); font-weight: 800; color: var(--caption-gray); text-transform: uppercase; }
  .card-topline { justify-content: space-between; color: var(--claret); }
  h3 { margin: var(--space-3) 0 var(--space-2); font-size: var(--fs-xl); line-height: 1.05; }
  p { color: var(--caption-gray); }
  .card-badges span { border: var(--report-rule); padding: 3px 8px; background: var(--paper); color: var(--ink-page); }
  .card-metrics { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-1) var(--space-3); margin: var(--space-4) 0; font-family: var(--font-sans); font-size: var(--fs-sm); }
  .card-metrics dt { color: var(--caption-gray); }
  .card-metrics dd { margin: 0; font-weight: 800; color: var(--ink-page); }
  .card-footer strong { display: inline-grid; place-items: center; min-width: 34px; height: 34px; border: 1px solid var(--claret); background: var(--claret); color: white; padding-inline: var(--space-2); }
</style>
