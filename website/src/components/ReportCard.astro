---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../lib/i18n';
import { displayLabel } from '../lib/display';
import { loadLocalizedIndex } from '../content/reports-loader';

interface Props { entry: CollectionEntry<'reports'>; lang?: Lang; }
const { entry, lang = 'en' } = Astro.props;
const localized = lang === 'zh' ? loadLocalizedIndex(entry.id, 'zh') : null;
const data = localized ? { ...entry.data, ...localized } : entry.data;
const base = import.meta.env.BASE_URL;
const href = lang === 'zh' ? `${base}zh/${entry.data.folderSlug}/` : `${base}${entry.data.folderSlug}/`;
const sector = data.company?.sector ?? (lang === 'zh' ? '其他' : 'other');
const stage = data.company?.stage;
const metrics = data.keyMetrics;
const labels = lang === 'zh'
  ? { valuation: '估值', arr: 'ARR', growth: '增长', nrr: 'NRR', confidence: '置信度', sources: '来源', overallRating: '整体评分' }
  : { valuation: 'Valuation', arr: 'ARR', growth: 'Growth', nrr: 'NRR', confidence: 'confidence', sources: 'sources', overallRating: 'Overall rating' };
const zhDisplayMap: Record<string, string> = { 'Research More': '继续研究', 'Medium': '中等', 'High': '高', 'Low': '低', 'Critical': '关键' };
function labelValue(value: unknown) {
  const rendered = displayLabel(value);
  return lang === 'zh' ? (zhDisplayMap[rendered] ?? rendered) : rendered;
}
function metric(value: number | null | undefined, suffix = '') {
  if (value === null || value === undefined) return null;
  return `${value.toLocaleString()}${suffix}`;
}
function moneyM(value: number | null | undefined) {
  if (value === null || value === undefined) return null;
  if (Math.abs(value) >= 1000) return `$${(value / 1000).toLocaleString(undefined, { maximumFractionDigits: 1 })}B`;
  return `$${value.toLocaleString(undefined, { maximumFractionDigits: 1 })}M`;
}
const metricRows = [
  [labels.valuation, moneyM(metrics?.postMoneyValuationUsdM)],
  [labels.arr, moneyM(metrics?.arrUsdM)],
  [labels.growth, metric(metrics?.revenueGrowthYoYPct, '%')],
  [labels.nrr, metric(metrics?.nrrPct, '%')],
].filter(([, value]) => value);
---
<a class="sr-card" href={href}>
  <div class="sr-meta sr-kicker">
    <span>{data.company.name}</span>
    <span>·</span>
    <span>{sector}</span>
  </div>
  <h3>{data.headline}</h3>
  <p>{labelValue(data.recommendation)} · {labelValue(data.confidence)} {labels.confidence} · {data.sourceStats.sourcesRetained} {labels.sources}</p>
  {metricRows.length > 0 && (
    <dl class="card-metrics">
      {metricRows.map(([name, value]) => <><dt>{name}</dt><dd>{value}</dd></>)}
    </dl>
  )}
  <div class="sr-meta">
    <span class="sr-score">{data.overallScore.toFixed(1)}</span>
    <span>{labels.overallRating} {data.overallScore.toFixed(1)}</span>
    <span>·</span>
    <span>{data.runDate}</span>
    {stage && <><span>·</span><span>{stage}</span></>}
  </div>
</a>
<style>
  .card-metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-1) var(--space-3);
    margin: var(--space-3) 0;
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
  }
  .card-metrics dt {
    color: var(--caption-gray);
  }
  .card-metrics dd {
    margin: 0;
    font-weight: 700;
    color: var(--ink-page);
  }
</style>
