---
import type { CollectionEntry } from 'astro:content';
import { displayLabel } from '../lib/display';
import { t } from '../lib/i18n';
import type { Locale } from '../lib/locale';
import { localePath } from '../lib/locale';

interface Props {
  entry: CollectionEntry<'reports'>;
  locale?: Locale;
  // Optional Chinese overlay produced by loadCardOverlayZh(). When set and
  // locale === 'zh', individual fields fall back to English when the overlay
  // does not provide them.
  overlay?: Record<string, any> | null;
}
const { entry, locale = 'en', overlay = null } = Astro.props;
const data = entry.data;
const base = import.meta.env.BASE_URL;
const href = locale === 'zh'
  ? localePath(base, 'zh', entry.data.folderSlug)
  : `${base}${entry.data.folderSlug}/`;
const isSuperseded = data.revision?.status === 'superseded';
const labels = {
  valuation: t('cardValuation', locale),
  revenue: t('cardRevenue', locale),
  arr: t('cardArr', locale),
  growth: t('cardGrowth', locale),
  nrr: t('cardNrr', locale),
  risk: t('cardRisk', locale),
  confidence: t('cardConfidence', locale),
  sources: t('cardSources', locale),
  report: t('cardReport', locale),
  rating: t('cardRating', locale),
  superseded: t('cardSuperseded', locale),
  other: t('cardOther', locale),
};

const headline = (overlay?.headline as string | null) ?? data.headline;
const sector = (overlay?.companySector as string | null) ?? data.company.sector ?? labels.other;
const stage = (overlay?.companyStage as string | null) ?? data.company.stage;

function metric(value: number | null | undefined, suffix = '') {
  if (value === null || value === undefined) return null;
  return `${value.toLocaleString()}${suffix}`;
}
function moneyM(value: number | null | undefined) {
  if (value === null || value === undefined) return null;
  if (Math.abs(value) >= 1000) return `$${(value / 1000).toLocaleString(undefined, { maximumFractionDigits: 1 })}B`;
  return `$${value.toLocaleString(undefined, { maximumFractionDigits: 1 })}M`;
}
const metrics = data.keyMetrics;
const metricRows = [
  [labels.valuation, moneyM(metrics?.valuationUsdM)],
  [labels.revenue, moneyM(metrics?.revenueRunRateUsdM)],
  [labels.arr, moneyM(metrics?.arrUsdM)],
  [labels.growth, metric(metrics?.revenueGrowthYoYPct, '%')],
  [labels.nrr, metric(metrics?.nrrPct, '%')],
].filter(([, value]) => value);
---
<a class="report-card" href={href}>
  <div class="card-topline">
    <span class="card-sector">{sector}</span>
    {stage && <span class="card-stage">{stage}</span>}
    {isSuperseded && <span class="card-stage card-stage--superseded">{labels.superseded}</span>}
  </div>
  <h3>{data.company.name}</h3>
  <p class="card-headline">{headline}</p>
  <div class="card-badges">
    <span>{displayLabel(data.recommendation, locale)}</span>
    <span>{displayLabel(data.valuationStance, locale)}</span>
    <span>{labels.risk}: {displayLabel(data.riskRating, locale)}</span>
  </div>
  {metricRows.length > 0 && (
    <dl class="card-metrics">
      {metricRows.map(([name, value]) => <><dt>{name}</dt><dd>{value}</dd></>)}
    </dl>
  )}
  <div class="card-footer">
    <strong>{data.overallScore.toFixed(1)}</strong>
    <span>{labels.rating}</span>
    <span>·</span>
    <span>{data.sourceStats.sourcesRetained} {labels.sources}</span>
  </div>
</a>
<style>
  .report-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    border: var(--report-rule);
    background: var(--surface-paper);
    padding: var(--space-4);
    color: inherit;
    text-decoration: none;
    transition: border-color 120ms ease, background-color 120ms ease;
  }
  .report-card:hover { border-color: var(--claret); background: color-mix(in srgb, var(--claret) 4%, var(--surface-paper)); }
  .card-topline, .card-footer, .card-badges { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2); font-family: var(--font-sans); font-size: var(--fs-xs); font-weight: 800; color: var(--caption-gray); text-transform: uppercase; letter-spacing: 0.02em; }
  .card-topline { justify-content: space-between; color: var(--claret); gap: var(--space-3); }
  .card-topline .card-sector,
  .card-topline .card-stage { min-width: 0; max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .card-topline .card-stage { color: var(--caption-gray); }
  .card-topline .card-stage--superseded { color: var(--risk-red); }
  h3 { margin: var(--space-3) 0 var(--space-2); font-size: var(--fs-xl); line-height: 1.05; overflow-wrap: anywhere; }
  .card-headline { color: var(--caption-gray); margin: 0; display: -webkit-box; -webkit-line-clamp: 3; line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .card-badges span { border: var(--report-rule); padding: 3px 8px; background: var(--paper); color: var(--ink-page); }
  .card-metrics { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-1) var(--space-3); margin: var(--space-4) 0; font-family: var(--font-sans); font-size: var(--fs-sm); }
  .card-metrics dt { color: var(--caption-gray); }
  .card-metrics dd { margin: 0; font-weight: 800; color: var(--ink-page); }
  .card-footer { margin-top: auto; padding-top: var(--space-3); }
  .card-footer strong { display: inline-grid; place-items: center; min-width: 34px; height: 34px; border: 1px solid var(--claret); background: var(--claret); color: white; padding-inline: var(--space-2); }
</style>
