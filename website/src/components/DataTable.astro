---
import { displayLabel } from '../lib/display';
import type { Lang } from '../lib/i18n';
import ClaimRefs from './ClaimRefs.astro';

interface Column {
  heading: string;
  key?: string;
  render?: (row: any) => unknown;
}
interface Props {
  title: string;
  rows?: any[];
  columns: Column[];
  emptyLabel?: string;
  lang?: Lang;
  claims?: any[];
  sources?: any[];
}
const { title, rows = [], columns, emptyLabel = 'Not disclosed', lang = 'en', claims = [], sources = [] } = Astro.props;
const evidenceHeading = lang === 'zh' ? '证据' : 'Evidence';
const hasClaimRefs = rows.some((row) => Array.isArray(row?.claimRefs) && row.claimRefs.length > 0);
const zhDisplayMap: Record<string, string> = {
  'Yes': '是', 'No': '否', 'Medium': '中等', 'High': '高', 'Low': '低', 'Critical': '关键',
  'Strong': '强', 'Moderate': '中等', 'Weak': '弱', 'Public': '公开', 'Independent': '独立', 'Company': '公司', 'Third Party': '第三方'
};
function formatCell(value: unknown) {
  if (value === null || value === undefined || value === '') return emptyLabel;
  const rendered = displayLabel(value);
  return lang === 'zh' ? (zhDisplayMap[rendered] ?? rendered) : rendered;
}
---
{rows.length > 0 && (
  <div class="table-wrap">
    <table class="sr-table report-table">
      <caption>{title}</caption>
      <thead>
        <tr>{columns.map((column) => <th>{column.heading}</th>)}{hasClaimRefs && <th>{evidenceHeading}</th>}</tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            {columns.map((column) => <td>{formatCell(column.render ? column.render(row) : column.key ? row?.[column.key] : undefined)}</td>)}
            {hasClaimRefs && <td class="refs-cell"><ClaimRefs refs={row?.claimRefs ?? []} claims={claims} sources={sources} /></td>}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
<style>
  .table-wrap {
    overflow-x: auto;
    margin: var(--space-5) 0;
    border: var(--report-rule);
    border-top: 3px solid var(--claret);
    background: var(--surface-paper);
  }
  .report-table {
    min-width: 780px;
    border-collapse: separate;
    border-spacing: 0;
    background: transparent;
  }
  .report-table caption {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--report-rule);
    background: color-mix(in srgb, var(--claret) 6%, var(--surface-paper));
    font-family: var(--font-sans);
    font-variant-caps: all-small-caps;
    font-size: var(--report-fs-kicker, var(--fs-sm));
    font-weight: 800;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--claret);
    caption-side: top;
  }
  .report-table th,
  .report-table td {
    border-bottom: var(--report-rule);
    padding: var(--space-3) var(--space-4);
    vertical-align: top;
    font-size: var(--report-fs-table, var(--fs-md));
    line-height: 1.55;
  }
  .report-table th {
    background: color-mix(in srgb, var(--paper) 78%, white);
    color: color-mix(in srgb, var(--claret) 88%, var(--ink-page));
    font-variant-caps: all-small-caps;
    font-weight: 800;
    letter-spacing: var(--tracking-eyebrow);
    white-space: nowrap;
  }
  .report-table tbody tr:nth-child(2n) {
    background: color-mix(in srgb, var(--surface-paper) 68%, transparent);
  }
  .report-table tbody tr:hover {
    background: color-mix(in srgb, var(--claret) 5%, var(--surface-paper));
  }
  .report-table tbody tr:last-child td {
    border-bottom: 0;
  }
  .report-table td {
    max-width: 420px;
    color: var(--ink-page);
  }
  .report-table td:first-child {
    font-weight: 650;
  }
  .refs-cell {
    min-width: 120px;
    white-space: nowrap;
  }
  .table-wrap :global(.claim-ref) {
    font-size: var(--report-fs-caption, var(--fs-xs));
    white-space: nowrap;
  }
</style>
