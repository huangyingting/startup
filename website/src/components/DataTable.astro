---
import { displayLabel } from '../lib/display';
import type { Lang } from '../lib/i18n';

interface Column {
  heading: string;
  key?: string;
  render?: (row: any) => unknown;
}
interface Props {
  title: string;
  rows?: any[];
  columns: Column[];
  emptyLabel?: string;
  lang?: Lang;
}
const { title, rows = [], columns, emptyLabel = 'Not disclosed', lang = 'en' } = Astro.props;
const zhDisplayMap: Record<string, string> = {
  'Yes': '是', 'No': '否', 'Medium': '中等', 'High': '高', 'Low': '低', 'Critical': '关键',
  'Strong': '强', 'Moderate': '中等', 'Weak': '弱', 'Public': '公开', 'Independent': '独立', 'Company': '公司', 'Third Party': '第三方'
};
function formatCell(value: unknown) {
  if (value === null || value === undefined || value === '') return emptyLabel;
  const rendered = displayLabel(value);
  return lang === 'zh' ? (zhDisplayMap[rendered] ?? rendered) : rendered;
}
---
{rows.length > 0 && (
  <div class="table-wrap">
    <table class="sr-table report-table">
      <caption>{title}</caption>
      <thead>
        <tr>{columns.map((column) => <th>{column.heading}</th>)}</tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            {columns.map((column) => <td>{formatCell(column.render ? column.render(row) : column.key ? row?.[column.key] : undefined)}</td>)}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
<style>
  .table-wrap {
    overflow-x: auto;
    margin-top: var(--space-5);
    border: var(--report-rule);
    border-radius: 12px;
    background: color-mix(in srgb, var(--surface-paper) 92%, white);
    box-shadow: 0 1px 0 color-mix(in srgb, var(--hairline) 45%, transparent);
  }
  .report-table {
    min-width: 720px;
    border: 0;
    border-collapse: separate;
    border-spacing: 0;
    background: transparent;
  }
  .report-table caption {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--report-rule);
    background: color-mix(in srgb, var(--claret) 6%, transparent);
    font-family: var(--font-sans);
    font-variant-caps: all-small-caps;
    font-weight: 800;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--claret);
    caption-side: top;
  }
  .report-table th,
  .report-table td {
    border-bottom: var(--report-rule);
    padding: var(--space-3) var(--space-4);
    vertical-align: top;
  }
  .report-table th {
    background: color-mix(in srgb, var(--paper) 80%, white);
    color: color-mix(in srgb, var(--claret) 88%, var(--ink-page));
    white-space: nowrap;
  }
  .report-table tbody tr:nth-child(even) {
    background: color-mix(in srgb, var(--paper) 72%, white);
  }
  .report-table tbody tr:hover {
    background: color-mix(in srgb, var(--claret) 5%, transparent);
  }
  .report-table tbody tr:last-child td {
    border-bottom: 0;
  }
  .report-table td {
    max-width: 420px;
    color: var(--ink-page);
    line-height: 1.48;
  }
</style>
