---
interface Props { refs?: string[]; }
const { refs = [] } = Astro.props;
---
{refs.length > 0 && <span class="claim-ref">[{refs.join(', ')}]</span>}
<style>
  .claim-ref {
    color: var(--caption-gray);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    white-space: nowrap;
  }
</style>
